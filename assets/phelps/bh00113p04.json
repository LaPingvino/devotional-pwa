{"pin":"BH00113P04","subcodes":[{"code":"BH00113P04","anchor":"","full_text_parts":["O Son of Justice! Whither can a lover go but to the land of his beloved? and what seeker findeth rest away from his heart’s desire? To the true lover reunion is life, and separation is death. His breast is void of patience and his heart hath no peace. A myriad lives he would forsake to hasten to the abode of his beloved."],"translations":[{"language":"eu","lang_name":"Basque"},{"language":"no","lang_name":"Norwegian"},{"language":"sr","lang_name":"Serbian"}],"writing_refs":[{"type":"hidden-words","type_name":"The Hidden Words","language":"ms","lang_name":"Malay"},{"type":"hidden-words","type_name":"The Hidden Words","language":"te","lang_name":"Telugu"},{"type":"hidden-words","type_name":"The Hidden Words","language":"et","lang_name":"Estonian"},{"type":"hidden-words","type_name":"The Hidden Words","language":"fa","lang_name":"Persian"},{"type":"hidden-words","type_name":"The Hidden Words","language":"hy","lang_name":"Armenian"},{"type":"hidden-words","type_name":"The Hidden Words","language":"tr","lang_name":"Turkish"},{"type":"hidden-words","type_name":"The Hidden Words","language":"ha","lang_name":"Hausa"},{"type":"hidden-words","type_name":"The Hidden Words","language":"hi","lang_name":"Hindi"},{"type":"hidden-words","type_name":"The Hidden Words","language":"hu","lang_name":"Hungarian"},{"type":"hidden-words","type_name":"The Hidden Words","language":"ja","lang_name":"Japanese"},{"type":"hidden-words","type_name":"The Hidden Words","language":"sv","lang_name":"Swedish"},{"type":"hidden-words","type_name":"The Hidden Words","language":"tvl","lang_name":"Tuvalu"},{"type":"hidden-words","type_name":"The Hidden Words","language":"bn","lang_name":"Bengali"},{"type":"hidden-words","type_name":"The Hidden Words","language":"el","lang_name":"Greek"},{"type":"hidden-words","type_name":"The Hidden Words","language":"fi","lang_name":"Finnish"},{"type":"hidden-words","type_name":"The Hidde