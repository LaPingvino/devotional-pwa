[{"phelps":"BH10505","text":"¡Ay Dius Tatay! ¡Ay Dius Tatay! Juntuchamaya taqi wawanakamaru, chuymanakaparu ucharakimaya jumana jach'a amuyasiñamjja, ukatjja atipjjaspawa arkana, kamachitanakamar sujitasiña. Yanapt'amay Dius Tatay, ch'amaskirinakaru churamaya ch'ama jumaru sirwiñapataki.\n\n¡Ay Dius Tatay! Jani jaytaramti jupanakaru irptamay, sarnaqawipanjja chuymachamaya chuymanakaparu jumana munañamampu, Cheqapiniwa jumajja yanapt'iritajja art'asirinakaru, ukhamaraki Awkiparajja.","source":"bahaiprayers.org","version":"ac127261-2bb7-43cd-818d-f56462439ff8","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"hy","lang_name":"Armenian"},{"language":"eu","lang_name":"Basque"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"bn","lang_name":"Bengali"},{"language":"bs","lang_name":"Bosnian"},{"language":"ch","lang_name":"Chamorro"},{"language":"chr","lang_name":"Cherokee"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"cs","lang_name":"Czech"},{"language":"dgz","lang_name":"Daga"},{"language":"dak","lang_name":"Dakota"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fo","lang_name":"Faroese"},{"language":"fj","lang_name":"Fijian"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"el","lang_name":"Greek"},{"language":"gu","lang_name":"Gujarati"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"hz","lang_name":"Herero"},{"language":"hi","lang_name":"Hindi"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"ik","lang_name":"Inupiaq"},{"language":"it","lang_name":"Ita