{"prayers":[{"phelps":"BH11209","text":"# Short Obligatory Prayer\n## To be recited once in twenty-four hours, at noon.\n\nHai Ishwar! Hum gawaahi det haïn ki Tohké chinhé ká aūr tohur pooja karé khatir Tou hamké païda kaïlé hawa. Hum haï ghari ma nat haïn ki hum bahout kamjor haïn aur tou sab sakti se bharam hawa. Hum garib haïn aur Tou sab parkaar ké dhan-dawlat se bharpour hawa. Tohké chorké dousra koyi Parmãtmã naï ha. Touhi sankat sé chorawé aula hawa aur Touhi sab Jagah mein samaail baara.","name":"Short Obligatory Prayer","source":"sop_pdf","version":"c896b5bf-71c6-4fd7-b43d-7ce4915c82d4","v":"bvifq9y1c85rk7omga3yoxn10","book_cats":{"af:bpnet":{"cat":"Kort verpligte gebed","order_in_cat":1},"am:bpnet":{"cat":"አጭሩ (Short)","order_in_cat":1},"ar:bpnet":{"cat":"الصلاة   الصغيرة","order_in_cat":1},"az:bpnet":{"cat":"Qısa Namaz","order_in_cat":1},"be:bpapp":{"cat":"Абавязковая малітвы","cat_order":1,"order_in_cat":1},"be:bpnet":{"cat":"Кароткая абавязковая малітва","order_in_cat":1},"bg:bpnet":{"cat":"Кратка задължителна молитва","order_in_cat":1},"bi:bpnet":{"cat":"SOTFALA  OBLIGATORI  PREA","order_in_cat":1},"bs:bpnet":{"cat":"Kratka Obavezna Molitva","order_in_cat":1},"ca:bpnet":{"cat":"Oració obligatòria curta","order_in_cat":1},"co:bpnet":{"cat":"Preghera dì tutti i ghjorni","order_in_cat":1},"cs:bpnet":{"cat":"Krátká denní modlitba","order_in_cat":1},"cy:bpnet":{"cat":"Short Obligatory Prayer","order_in_cat":1},"da:bpnet":{"cat":"Kort Obligatorisk Bøn","order_in_cat":1},"de:bpapp":{"cat":"Pflichtgebete","cat_order":1,"order_in_cat":2},"de:bpnet":{"cat":"Das kurze Pflichtgebet","order_in_cat":1},"dgz:bpnet":{"cat":"Marek Iyanupe U’uraewa (Short Obligatory Prayer)","order_in_cat":1},"el:bpnet":{"cat":"ΜΙΚΡΗ ΥΠΟΧΡΕΩΤΙΚΗ ΠΡΟΣΕΥΧΗ","order_in_cat":1},"en:bpnet":{"cat":"Short Obligatory Prayer","order_in_cat":1},"eo:bel-malnova":{"cat":"Devigaj Preĝoj","cat_order":11,"order_in_cat":1},"eo:bpapp":{"cat":"Devigaj Preĝoj","cat_order":11,"order_in_cat":2},"eo:bpnet":{"