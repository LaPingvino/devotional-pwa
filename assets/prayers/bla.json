kfoot / Siksika\n\nAtsée-moyeh’kapee un-óm, ki kokónahn, keetáw-pop, ki akápeeyoyis, kyoos-kee-tsée-paXpee, ki mee-stúkee, keetáyk-sasohp, ki ata-níksin, ki ist-sikúm, ki isksáXko, ki mo-tíy-oXkee, ki mée-nee, ki ápoX-keepee kyám-ost-skiy;\n\nApistotokee eeh-tsee-tésk-sinowa kyot-sokáp-sinee áXkeetso-keetseesinee.\n\nBlessed is the spot, and the house, and the place, and the city, and the heart, and the mountain, and the refuge, and the cave, and the valley, and the land, and the sea, and the island, and the meadow where mention of God hath been made, and His praise glorified.","name":"Blackfoot / Siksika","category":"Blackfoot / Siksika","order_in_cat":2,"source":"bahaiprayers.net","version":"295442ea-23be-4577-b0fc-77eee4305d88","book_cats":{"be:bp":{"cat":"Блаславёны","order_in_cat":1},"ca:bp":{"cat":"Qualitats Espirituals","order_in_cat":10},"de:bp":{"cat":"Allgemein","order_in_cat":1},"en:bp":{"cat":"Gatherings","order_in_cat":8},"et:bp":{"cat":"Katsumused ja raskused","order_in_cat":3},"fa:bp":{"cat":"طلب مدد و حمایت","order_in_cat":1},"fr:bp":{"cat":"Familles","order_in_cat":6},"hu:bp":{"cat":"Család","order_in_cat":3},"is:bp":{"cat":"Lofgjörð og þökk","order_in_cat":12},"kl:bp":{"cat":"Katerisimaarnerit","order_in_cat":1},"km:bp":{"cat":"General Prayers","order_in_cat":1},"lt:bp":{"cat":"Vaikai","order_in_cat":1},"ml:bp":{"cat":"ഐക്യം","order_in_cat":2},"nai-CA:bp":{"cat":"Chippewa","order_in_cat":1},"nai-US:bp":{"cat":"Lakota","order_in_cat":1},"pt:bp":{"cat":"Orações","order_in_cat":1},"ro:bp":{"cat":"Pentru cei Răposaţi","order_in_cat":2},"sq:bp":{"cat":"i përgjithshëm","order_in_cat":1},"tk:bp":{"cat":"Dostluk We Agzybirlik","order_in_cat":5},"ur:bp":{"cat":"بچوں کے لیے دعائیں","order_in_cat":1}},"translations":[{"language":"ur","lang_name":"Urdu"},{"language":"sq","lang_name":"Albanian"},{"language":"nl","lang_name":"Dutch"},{"language":"lg","lang_name":"Ganda"},{"language":"it","lang_name":"Italian"},{"language":"co","lang_name":"Corsican"},{"language"