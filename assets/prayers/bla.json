[{"phelps":"BB00623","text":"Apistotokeewa keeták-oXkotspómok-owa, kútat-sits-eéh’pa keeták-oXkot-spomókee? Ah-yoh Apistotokee! UnúX-kiy Apistotokee! Kunáy-tapee otés-pomok ki óXkunoX-pokee-woh-yah.\n\n* Is there any Remover of difficulties save God? Say: Praised be God! He is God! All are His servants, and all abide by His bidding!.","name":"Remover of Difficulties","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"be","lang_name":"Belarusian"},{"language":"bn","lang_name":"Bengali"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"ch","lang_name":"Chamorro"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"cs","lang_name":"Czech"},{"language":"da","lang_name":"Danish"},{"language":"en","lang_name":"English"},{"language":"fo","lang_name":"Faroese"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"gu","lang_name":"Gujarati"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hz","lang_name":"Herero"},{"language":"hi","lang_name":"Hindi"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"ik","lang_name":"Inupiaq"},{"language":"ga","lang_name":"Irish"},{"language":"it","lang_name":"Italian"},{"language":"ja","lang_name":"Japanese"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"kiw","lang_name":"Kiwai"},{"language":"ko","lang_name":"Korean"},{"language":"lkt","lang_name":"Lakota"},{"language":"lo","lang_name":"Lao"},{"language":"lv","lang_name":"Latvian"},{"language":"mg","lang_name":"Malagasy"},{"language":"ms","lang_name":"Malay"},{"language":"ml","lang_name":"Malayalam"},{"language":"mi","lang_name":"Maori"},{"language":"mh","lang_name":"Marshallese"},{"language":"moh","lang_name":"Mohawk"},{"language":"mn","lang_name":"Mongolian"},{"language":"cnr","lang_name":"Montenegrin"},{"language":"meu","lang_name":"Motu"},{"language":"nv","lang_name":"Navajo"},{"language":"ne","lang_name":"Nepali"},{"language":"no","lang_name":"Norwegian"},{"language":"pap","lang_name":"Papiamento"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"sm","lang_name":"Samoan"},{"language":"zh-Hans","lang_name":"Simplified Chinese"},{"language":"sk","lang_name":"Slovak"},{"language":"sl","lang_name":"Slovenian"},{"language":"es","lang_name":"Spanish"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"th","lang_name":"Thai"},{"language":"tpi","lang_name":"Tok Pisin"},{"language":"tk","lang_name":"Turkmen"},{"language":"uk","lang_name":"Ukrainian"},{"language":"wam","lang_name":"Wampanoag"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH00074BLE","text":"Atsée-moyeh’kapee un-óm, ki kokónahn, keetáw-pop, ki akápeeyoyis, kyoos-kee-tsée-paXpee, ki mee-stúkee, keetáyk-sasohp, ki ata-níksin, ki ist-sikúm, ki isksáXko, ki mo-tíy-oXkee, ki mée-nee, ki ápoX-keepee kyám-ost-skiy;\nApistotokee eeh-tsee-tésk-sinowa kyot-sokáp-sinee áXkeetso-keetseesinee.\n\n* Blessed is the spot, and the house, and the place, and the city, and the heart, and the mountain, and the refuge, and the cave, and the valley, and the land, and the sea, and the island, and the meadow where mention of God hath been made, and His praise glorified.","name":"Blessed is the Spot","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"be","lang_name":"Belarusian"},{"language":"bs","lang_name":"Bosnian"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"chr","lang_name":"Cherokee"},{"language":"co","lang_name":"Corsican"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"gwi","lang_name":"Gwich'in"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hu","lang_name":"Hungarian"},{"language":"is","lang_name":"Icelandic"},{"language":"ga","lang_name":"Irish"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kiw","lang_name":"Kiwai"},{"language":"lkt","lang_name":"Lakota"},{"language":"lt","lang_name":"Lithuanian"},{"language":"lut","lang_name":"Lushootseed"},{"language":"ml","lang_name":"Malayalam"},{"language":"moh","lang_name":"Mohawk"},{"language":"meu","lang_name":"Motu"},{"language":"nv","lang_name":"Navajo"},{"language":"oj","lang_name":"Ojibwe"},{"language":"pap","lang_name":"Papiamento"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"ro","lang_name":"Romanian"},{"language":"slh","lang_name":"Sliammon"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH01313NAM","text":"Kitsíneh’ka-seemee tóXta-sókimoX-see, áh-yoh Apistotokee, ki ikúmoks-tay-ksím-stay-neekee tákoXt-seets.\nKeetóta-powáX-kaX-see noXtóh-tamee-túkee ki eh’tóX-pokow-op keeta-wákomin-oX-sinee. Kitsee-kím-oX-sinee nitoX-\ntáh-sokaps ki nitóX-tah-spom-ókoh unoyee isk-sáX-koy ki iy-yá-keeta-popay-nyókee. Gee-stóa keetsee-kím-apee, keetóX-kunes-ksineéh’p éehpóX-sinee kitsee-kók-akee.\n\n* Thy name is my healing, O my God, and remembrance of Thee is my remedy. Nearness to Thee is my hope, and love for Thee is my companion. Thy mercy to me is my healing and my succour in both this world and the world to come. Thou, verily, art the All-Bountiful, the All-Knowing, the All-Wise.","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"bn","lang_name":"Bengali"},{"language":"bi","lang_name":"Bislama"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"ceb","lang_name":"Cebuano"},{"language":"ch","lang_name":"Chamorro"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"cs","lang_name":"Czech"},{"language":"dak","lang_name":"Dakota"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fo","lang_name":"Faroese"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"ha","lang_name":"Hausa"},{"language":"haw","lang_name":"Hawaiian"},{"languag