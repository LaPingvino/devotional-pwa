ame":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"diu","lang_name":"Rugciriku"},{"language":"ru","lang_name":"Russian"},{"language":"sr","lang_name":"Serbian"},{"language":"zh-Hans","lang_name":"Simplified Chinese"},{"language":"sk","lang_name":"Slovak"},{"language":"sl","lang_name":"Slovenian"},{"language":"st","lang_name":"Southern Sotho"},{"language":"es","lang_name":"Spanish"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"th","lang_name":"Thai"},{"language":"tk","lang_name":"Turkmen"},{"language":"uk","lang_name":"Ukrainian"},{"language":"ur","lang_name":"Urdu"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH10505","text":"O Myha! O Myah!\nMut-my-um mi-a-chesh peri-wee mup muk-u-wik, cun-up-uwip Ya-wu quaw-tie. Pi-cha me-na Myha chu-wutch wu-chow new-y Myha chu-wutch na. Ma-wik tea-pie nea chums, O Myha, we-ik-um nea ya-wu we-e, mingum super ach-chopie Myha.\nO Myha! Ma-eye con-muck-um-tung-u-way mauw, ma -qua-chatch ma pu-usch qu’l-auw mu-ow, me-yeah-han ya chesh Myha yea-ma-a\nQua-han, Myha Muk-u-wik Myha Quaw-tie.\n\n* O my God! O my God! Unite the hearts of Thy servants, and reveal to them Thy great purpose. May they follow Thy commandments and abide in Thy law. Help them, O God, in their endeavour, and grant them strength to serve Thee.  O God! Leave them not to themselves, but guide their steps by the light of Thy knowledge, and cheer their hearts by Thy love. Verily, Thou art their helper and their Lord.","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"hy","lang_name":"Armenian"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"bn","lang_name":"Bengali"},{"language":"bs","lang_name":"Bosnian"},{"language":"ch","lang_name":"Chamorro"},{"lang