[{"phelps":"BH00074BLE","text":"NA SOON DI SEEKH, DEAS DA GANIH, DEAS SOOKH DEAS DA SOH GANIH, DEAS DA BEYUH, DEAS DA DOYA BEH, DEAS BUNGH DA NAMA GWEEJOOH NI KHANDH DEAS DA DIMBEE GANIH, DEAS DA DOIYA HU-NO HA-BEEDTH DEAS DA SO-GOP-H DEAS DA BAH, DEAS DA SO-GOP-H-BAH DE-BEE-YANDH, DEAS DA ZA BOOWHEE NEH-SOO GA KHANDH DOIYA BA B-UT OGOI PU-INH. BUNGH DAUMEH UPEH NAN-IH DUN DA-GWAP. DEAS OOH NE-SHOO-WOO GINDH SUCA NANA-SOO-WOO GINDH.\n \n* Blessed is the spot, and the house, and the place, and the city, and the heart, and the mountain, and the refuge, and the cave, and the valley, and the land, and the sea, and the island, and the meadow where mention of God hath been made, and His praise glorified.","name":"Blessed is the Spot","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"sq","lang_name":"Albanian"},{"language":"be","lang_name":"Belarusian"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"bs","lang_name":"Bosnian"},{"language":"ca","lang_name":"Catalan"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"km","lang_name":"Central Khmer"},{"language":"co","lang_name":"Corsican"},{"language":"co","lang_name":"Corsican"},{"language":"en","lang_name":"English"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"et","lang_name":"Estonian"},{"language":"fr","lang_name":"French"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"de","lang_name":"German"},{"language":"gwi","lang_name":"Gwich'in"},{"language":"gwi","lang_name":"Gwich'in"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"hur","lang_name":"Halkomelem"},{"language":"haw","lang_name":"Hawaiian"},{"language":"haw","lang_name":"Hawaiian"},