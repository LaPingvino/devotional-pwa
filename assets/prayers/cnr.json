[{"phelps":"AB04427GUI","text":"O Bože,vodi me, zaštiti me, načini od mene sjajnu svjetiljku i blistavu zvijezdu. Ti si Moćan i Snažan.","category":"Djeca","order_in_cat":1,"source":"bahaiprayers.net","version":"272ff3a3-baf2-4baf-a0ee-0695fff4a6ed","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"be","lang_name":"Belarusian"},{"language":"bn","lang_name":"Bengali"},{"language":"bi","lang_name":"Bislama"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"ch","lang_name":"Chamorro"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"hai","lang_name":"Haida"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"hz","lang_name":"Herero"},{"language":"hu","lang_name":"Hungarian"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"ik","lang_name":"Inupiaq"},{"language":"it","lang_name":"Italian"},{"language":"kn","lang_name":"Kannada"},{"language":"lkt","lang_name":"Lakota"},{"language":"lo","lang_name":"Lao"},{"language":"lv","lang_name":"Latvian"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"ne","lang_name":"Nepali"},{"language":"no","lang_name":"Norwegian"},{"language":"pap","lang_name":"Papiamento"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"diu","lang_name":"Rugciriku"},{"language":"ru","lang_name":"Russian"},{"language":"shs","lang_name":"Shuswap (Secwepemctsín)"},{"language":"sk","lang_name":"Slovak"},{"language":"sl","lang_name":"Slovenian"},{"language":"es","lang_name":"Spanish"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"zh-Hant","lang_name":"Traditional Chinese"},{"language":"tsm","lang_name":"Tsimshian"},{"language":"ur","lang_name":"Urdu"},{"language":"vi","lang_name":"Vietnamese"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"ABU0129EDU","text":"O Bože! Odgoji ovu djecu. Ova djeca su biljke u Tvom voćnjaku, cvjetovi na Tvojoj livadi, ruže u Tvome vrtu. Nek tvoja kiša pada po njima; neka ih sunce Stvarnosti obasja Tvojom ljubavlju. Neka ih osvježe Tvoji lahori da bi se obrazovali, rasli i razvijali i pojavili se u konačnoj ljepoti. Ti si Davalac. Ti si Saosjećajni.","category":"Djeca","order_in_cat":2,"source":"bahaiprayers.net","version":"49df0ed2-b452-438f-9536-52e677793cd7","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"bi","lang_name":"Bislama"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ceb","lang_name":"Cebuano"},{"language":"ch","lang_name":"Chamorro"},{"language":"co","lang_name":"Corsican"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fo","lang_name":"Faroese"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hz","lang_name":"Herero"},{"language":"hu","lang_name":"Hungarian"},{"language":"is","lang_name":"Icelandic"},{"language":"it","lang_name":"Italian"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"ky","lang_name":"Kirghiz"},{"language":"lv","lang_name":"Latvian"},{"language":"mg","lang_name":"Malagasy"},{"language":"mr","lang_name":"Marathi"},{"language":"mh","lang_name":"Marshallese"},{"language":"mn","lang_name":"Mongolian"},{"language":"nal","lang_name":"Nalik"},{"language":"no","lang_name":"Norwegian"},{"language":"kj","lang_name":"Oshikwanyama"},{"language":"pap","lang_name":"Papiamento"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"diu","lang_name":"Rugciriku"},{"language":"se","lang_name":"Sami"},{"language":"sm","lang_name":"Samoan"},{"language":"sk","lang_name":"Slovak"},{"language":"st","lang_name":"Southern Sotho"},{"language":"es","lang_name":"Spanish"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"te","lang_name":"Telugu"},{"language":"tet","lang_name":"Tetum"},{"language":"tpi","lang_name":"Tok Pisin"},{"language":"zh-Hant","lang_name":"Traditional Chinese"},{"language":"uk","lang_name":"Ukrainian"},{"language":"cy","lang_name":"Welsh"}]},{"phelps":"BH00531TRA","text":"O moj Gospode! Daj da mi Tvoja ljepota bude hrana, a Tvoje prisustvo piće, mogućnost da Ti ugodim moja nada, moje djelanje da bude veličanje Tebe, pomen na Tebe moj sadrug, moć Tvoje vlasti moja potpora,Tvoje prebivalište moj dom, a postojbina moja sjedište oslobođeno od ograničenja nametnutih onima koji kao da su velom odvojeni od Tebe.\nTi si, odista, Svemoćni, Najdivniji, Najmoćniji.","category":"Duhovne Vrline","cat_order":1,"order_in_cat":1,"source":"bahaiprayers.net","version":"21e4d827-4c72-4e1c-a3d6-d8ef9bd3b649","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"az","lang_name":"Azerbaijani"},{"language":"ca","lang_name":"Catalan"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"fr","lang_name":"French"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"ml","lang_name":"Malayalam"},{"language":"pl","lang_name":"Polish"},{"language":"ro","lang_name":"Romanian"},{"language":"sv","lang_name":"Swedish"},{"language":"cy","lang_name":"Welsh"}]},{"phelps":"BH04421HEA","text":"Stvori u meni čisto srce, o moj Bože, i mirnu savjest obnovi u meni, o Nado moja! Duhom moći ojačaj me da služim Tvojoj Stvari, o Najljubljeniji moj, i svijetlom Svoje slave pokaži mi put Tvoj, o Ti koji si cilj čežnje moje! Snagom Svoje nenadmašne moći uzdigni me do nebesa Svoje svetosti, o Izvorištu moga bića, i razgali me lahorima Svoje vječnosti o Ti Koji si Bog moj! Neka me Tvoje melodije vječnosti ispune spokojem, o moj Sadruže, i neka me raskoš ljepote Tvog drevnog lika izbavi od svega osim Tebe, o Učitelju moj, i neka mi vijest o otkrovenju Tvoje nepromjenljive Suštine donese radost, o Ti Koji si najvidljiviji od svega vidljivoga i najskriveniji od svega skrivenoga!","category":"Duhovne Vrline","cat_order":1,"order_in_cat":2,"source":"bahaiprayers.net","version":"79d9d290-f958-40f7-9d1d-24b1be4a125e","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"be","lang_name":"Belarusian"},{"language":"bn","lang_name":"Bengali"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"cs","lang_name":"Czech"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fj","lang_name":"Fijian"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"el","lang_name":"Greek"},{"language":"gu","lang_name":"Gujarati"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"ha","lang_name":"Hausa"},{"language":"hz","lang_name":"Herero"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"it","lang_name":"Italian"},{"language":"ky","lang_name":"Kirghiz"},{"language":"lt","lang_name":"Lithuanian"},{"language":"mg","lang_name":"Malagasy"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"ne","lang_name":"Nepali"},{"language":"kj","lang_name":"Oshikwanyama"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"diu","lang_name":"Rugciriku"},{"language":"ru","lang_name":"Russian"},{"language":"se","lang_name":"Sami"},{"language":"sm","lang_name":"Samoan"},{"language":"st","lang_name":"Southern Sotho"},{"language":"es","lang_name":"Spanish"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"tet","lang_name":"Tetum"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH00009HOW","text":"O Bože! Osvježi mi i razgali dušu. Očisti mi srce. Prosvijetli moje moći. Sve svoje poslove polažem u Tvoje ruke. Ti si mi Vodič i Utočište. Više neću biti nesrećan i pun jada; postaću zadovoljan i srećan. O Bože! Više neću biti pun strepnje, niti ću dopustiti da me muče brige. Neću biti zaokupljen neprijatnim stvarima u životu.\nO Bože! Ti si mi veći prijatelj no što sam ja samome sebi. Posvećujem se Tebi, O Gospode.","category":"Duhovne Vrline","cat_order":1,"order_in_cat":3,"source":"bahaiprayers.net","version":"99cabb97-faf0-42ae-8ed4-8fdd93106864","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"az","lang_name":"Azerbaijani"},{"language":"bi","lang_name":"Bislama"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"ceb","lang_name":"Cebuano"},{"language":"hr","lang_name":"Croatian"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"gux","lang_name":"Gourmanchéma"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"ha","lang_name":"Hausa"},{"language":"hi","lang_name":"Hindi"},{"language":"hu","lang_name":"Hungarian"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"it","lang_name":"Italian"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"ko","lang_name":"Korean"},{"language":"lv","lang_name":"Latvian"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"mg","lang_name":"Malagasy"},{"language":"ml","lang_name":"Malayalam"},{"language":"no","lang_name":"Norwegian"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"zh-Hans","lang_name":"Simplified Chinese"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"cy","lang_name":"Welsh"}]},{"phelps":"BH02898MAG","text":"O Bože, moj Bože! Zaklinjem te, Okeanom Tvojih iscjeljiteljskih moći, i sjajnom Danicom Tvog milosrđa, i Tvojim Imenom kojem se pokoravaju Tvoje sluge, i sveprožimajućom snagom Tvoje najuzvišenije Riječi, i silom Tvog najdivnijeg Pera, i Tvojom milošću, koja je prethodila stvaranju svega što obitava na nebu i na zemlji, pročisti me vodom svoje dobrote, speri sa mene svaku nesreću i bolest, svaku slabost i nemoć.\nTi vidiš, O moj Gospode, molioca koji čeka pred vratima Tvoje darežljivosti, onoga koji je svu svoju nadu položio u Tebe, držeći se za uže Tvoje plemenitosti. Preklinjem Te da mu ne uskratiš ono što traži od Okeana Tvoje milosti i od Danice Tvog saosjećanja. Ti imaš moć da činiš šta god poželiš. Nema drugog Boga osim Tebe, Koji sve praštaš, Najvelikodušnijeg.","category":"Iscjeljenje","cat_order":2,"order_in_cat":2,"source":"bahaiprayers.net","version":"464d8a28-b3b8-45b9-9ad6-7011fbbcc63b","translations":[{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"ca","lang_name":"Catalan"},{"language":"en","lang_name":"English"},{"language":"fr","lang_name":"French"},{"language":"gil","lang_name":"Gilbertese"},{"language":"el","lang_name":"Greek"},{"language":"hu","lang_name":"Hungarian"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"sv","lang_name":"Swedish"}]},{"phelps":"AB07709CON","text":"O Bože moj! O Bože moj! Ujedini srca Svojih slugu, i otkrij im Svoju veliku namjeru. Neka slijede Tvoje zapovjesti i drže se Tvog zakona. Pomozi im, o Bože, u njihovom pregalaštvu, i daj im snage da Te služe. O Bože! Ne prepuštaj ih samima sebi, već im svjetlošću Svog znanja vodi korake, i raduj im srca Svojom ljubavlju. Uistinu, Ti si im Pomagač i Gospod.","category":"Jedinstvo i Mir","cat_order":3,"order_in_cat":1,"source":"bahaiprayers.net","version":"81ff60a5-ef16-488e-974d-fb59b29ec826","translations":[{"language":"az","lang_name":"Azerbaijani"},{"language":"bs","lang_name":"Bosnian"},{"language":"ca","lang_name":"Catalan"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"is","lang_name":"Icelandic"},{"language":"it","lang_name":"Italian"},{"language":"lv","lang_name":"Latvian"},{"language":"pl","lang_name":"Polish"},{"language":"tl","lang_name":"Tagalog"}]},{"phelps":"BH00009SHE","text":"Probudio sam se u Tvom okrilju, O moj Bože, a priliči onome koji za tim utočištem čezne, da boravi u Šatoru Tvoje zaštite i u Tvrđavi Tvoje odbrane. Obasjaj moje unutrašnje biće, O moj Gospode, raskošnim sjajem Svanuća Tvog Otkrovenja, kao što si moje spoljašnje biće obasjao jutarnjom svjetlošću.","category":"Jutro","cat_order":4,"order_in_cat":1,"source":"bahaiprayers.net","version":"768e3bf8-827c-43f0-8a30-b4ff43dc3eb5","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"az","lang_name":"Azerbaijani"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"be","lang_name":"Belarusian"},{"language":"bn","lang_name":"Bengali"},{"language":"bi","lang_name":"Bislama"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"ch","lang_name":"Chamorro"},{"language":"ny","lang_name":"Chichewa"},{"language":"hr","lang_name":"Croatian"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hz","lang_name":"Herero"},{"language":"hu","lang_name":"Hungarian"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"ik","lang_name":"Inupiaq"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"naq","lang_name":"Khoekhoegowab"},{"language":"ky","lang_name":"Kirghiz"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"mg","lang_name":"Malagasy"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"ne","lang_name":"Nepali"},{"language":"no","lang_name":"Norwegian"},{"language":"kj","lang_name":"Oshikwanyama"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"diu","lang_name":"Rugciriku"},{"language":"ru","lang_name":"Russian"},{"language":"se","lang_name":"Sami"},{"language":"sk","lang_name":"Slovak"},{"language":"st","lang_name":"Southern Sotho"},{"language":"es","lang_name":"Spanish"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"tpi","lang_name":"Tok Pisin"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"vi","lang_name":"Vietnamese"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH00009SER","text":"O moj Bože, Učitelju moj, Odredištu za kojim žudim! Ovaj Tvoj sluga čezne da zaspi u skloništu tvoga milosrđa, i da otpočine pod baldahinom Tvoje milosti, preklinjući Te da se o njemu brineš i da ga štitiš.\nMolim Te, O moj Gospode, tako Ti oka Tvoga koje nikad ne spava, čuvaj moje oči da ne gledaju ni u šta drugo do u Tebe. Izoštri mi, dakle, vid, da mogu razaznavati Tvoje znake i ugledati Horizont Tvog Otkrovenja. Ti si Onaj pred čijim je otkrovenjima svemoći zadrhtala i sama suština moći.\nNema drugog Boga osim Tebe, Svemogućeg, Onog Koji sve pokorava, Neuslovljenog.","category":"Noć","cat_order":5,"order_in_cat":1,"source":"bahaiprayers.net","version":"b7cfd7a0-6cf7-42f4-b29d-afe53e30bdc2","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"be","lang_name":"Belarusian"},{"language":"bn","lang_name":"Bengali"},{"language":"bi","lang_name":"Bislama"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"ch","lang_name":"Chamorro"},{"language":"hr","lang_name":"Croatian"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"gux","lang_name":"Gourmanchéma"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hu","lang_name":"Hungarian"},{"language":"is","lang_name":"Icelandic"},{"language":"it","lang_name":"Italian"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"naq","lang_name":"Khoekhoegowab"},{"language":"ky","lang_name":"Kirghiz"},{"language":"lv","lang_name":"Latvian"},{"language":"lt","lang_name":"Lithuanian"},{"language":"mg","lang_name":"Malagasy"},{"language":"med","lang_name":"Melpa"},{"language":"mn","lang_name":"Mongolian"},{"language":"no","lang_name":"Norwegian"},{"language":"kj","lang_name":"Oshikwanyama"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"diu","lang_name":"Rugciriku"},{"language":"se","lang_name":"Sami"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"tpi","lang_name":"Tok Pisin"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"ur","lang_name":"Urdu"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH00662FLO","text":"O moj Bože! Molim Te da mi, po Svom Preslavnom Imenu, pomogneš u onome što će omogućiti da poslovi Tvojih slugu budu uspješni, i da Tvoji gradovi cvjetaju. Ti, zaista imaš moć nad svim stvarima!","category":"Pomoć","cat_order":6,"order_in_cat":1,"source":"bahaiprayers.net","version":"bd6d1e87-34e9-4f6a-ad71-76382d144cdb","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"be","lang_name":"Belarusian"},{"language":"bn","lang_name":"Bengali"},{"language":"bi","lang_name":"Bislama"},{"language":"bs","lang_name":"Bosnian"},{"language":"ch","lang_name":"Chamorro"},{"language":"da","lang_name":"Danish"},{"language":"en","lang_name":"English"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"gux","lang_name":"Gourmanchéma"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"ho","lang_name":"Hiri Motu"},{"language":"hu","lang_name":"Hungarian"},{"language":"is","lang_name":"Icelandic"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"lv","lang_name":"Latvian"},{"language":"lt","lang_name":"Lithuanian"},{"language":"ml","lang_name":"Malayalam"},{"language":"ne","lang_name":"Nepali"},{"language":"no","lang_name":"Norwegian"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"diu","lang_name":"Rugciriku"},{"language":"ru","lang_name":"Russian"},{"language":"sm","lang_name":"Samoan"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"cy","lang_name":"Welsh"}]},{"phelps":"AB00431PIT","text":"Gospode! Jadni smo, podari nam naklonost Svoju; siroti smo, udijeli nam iz okeana blaga Svoga; nemamo šta nam je potrebno, Ti zadovolji naše potrebe; poniženi smo, podaj nam Svoju slavu. Ptice na nebu i zvijeri u polju svakoga dana dobijaju hranu od Tebe i sva bića imaju udjela u Tvojoj brizi i božanskoj ljubavi.\n\nNe lišavaj ovog nejakog stvora Svoje čudotvorne milosti i, po sili Svojoj, udostoji ovu bespomoćnu dušu Svoje dobrote.\nHljeb naš nasušni daj nam danas, i podaj nam više od životnih potrepština tako da ne zavisimo ni od koga drugog do od Tebe; da se u potpunosti možemo družiti s Tobom, da možemo hoditi Tvojim stazama i objavljivati Tvoje tajne.\nTi si Svemogući, Onaj koji ljubi i brine se za čitavo čovječanstvo.","category":"Pomoć","cat_order":6,"order_in_cat":2,"source":"bahaiprayers.net","version":"d7cfa843-3094-4f93-b165-d0233a7d6822","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"bi","lang_name":"Bislama"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"ch","lang_name":"Chamorro"},{"language":"hr","lang_name":"Croatian"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fr","lang_name":"French"},{"language":"gil","lang_name":"Gilbertese"},{"language":"el","lang_name":"Greek"},{"language":"gu","lang_name":"Gujarati"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hz","lang_name":"Herero"},{"language":"hu","lang_name":"Hungarian"},{"language":"it","lang_name":"Italian"},{"language":"lv","lang_name":"Latvian"},{"language":"mt","lang_name":"Maltese"},{"language":"ne","lang_name":"Nepali"},{"language":"pap","lang_name":"Papiamento"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"tk","lang_name":"Turkmen"},{"language":"tvl","lang_name":"Tuvalu"}]},{"phelps":"AB10275","text":"Ne sklanjaj, o Gospode, prazničnu trpezu koja je postavljena u Tvoje Ime, i ne gasi plamen koji je razgorjela Tvoja neuništiva vatra. Ne zaustavljaj tok svoje žive vode što žubori pjesmom Tvoje slave i Tvoga pomena, i ne lišavaj Svoje sluge Svojih slasnih miomirisa što donose daške Tvoje ljubavi.\nGospode! Preobrazi opterećujuće brige Tvojih svetih u olakšanje, njihove patnje u utjehu, njihovo poniženje u slavu, njihovu tugu u blaženu radost, o Ti koji Svojom rukom upravljaš čitavim ljudskim rodom!\nTi si, zaista, Jedan, Jedini, Moćni, Sveznajući, Premudri.","category":"Pomoć","cat_order":6,"order_in_cat":3,"source":"bahaiprayers.net","version":"848469f4-a51e-4dc6-b74f-667b5758442e","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"hr","lang_name":"Croatian"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"el","lang_name":"Greek"},{"language":"hu","lang_name":"Hungarian"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"it","lang_name":"Italian"},{"language":"ja","lang_name":"Japanese"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"ky","lang_name":"Kirghiz"},{"language":"lv","lang_name":"Latvian"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"mg","lang_name":"Malagasy"},{"language":"ml","lang_name":"Malayalam"},{"language":"ne","lang_name":"Nepali"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"tpi","lang_name":"Tok Pisin"},{"language":"tvl","lang_name":"Tuvalu"}]},{"phelps":"BH00223MAG","text":"Neka je sva hvala Tebi, O moj Bože, koji si Izvor svake slave i uzvišenosti, veličine i časti, vlasti i gospodstva, dostojanstva i milosti, strahopoštovanja i moći. Ti privlačiš koga hoćeš do blizine Najuzvišenijeg Okeana, i kome god že- liš ukazuješ čast da prepozna Tvoje Najdrevnije Ime. Niko na nebu i na zemlji, ne može odoljeti djelovanju Tvoje vrhovne Volje. Od vječnosti Ti vladaš čitavim stvorenim svijetom i zauvjek ćeš gospodariti svime što je stvoreno. Nema drugog Boga osim Tebe, Svemoćnog, Najuzvišenijeg, Najsilnijeg, Najmudrijeg.\nOzari svijetlom, O Gospode, lica svojih slugu, da Te mogu gledati; i srca im pročisti, da bi se okrenuli ka dvoru Tvoje nebeske dobrote i prepoznali Onoga Koji je Objava Tebe Samoga i Osvit Tvoje Suštine. Ti, odista, jesi Gospodar svih svijetova. Nema drugog Boga osim Tebe, Neograničenog, Kome se sve pokorava.","category":"Slava Bogu","cat_order":7,"order_in_cat":1,"source":"bahaiprayers.net","version":"0578dd82-4a77-4f98-9da3-4b31df835fa1","translations":[{"language":"ca","lang_name":"Catalan"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"fr","lang_name":"French"},{"language":"lv","lang_name":"Latvian"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"es","lang_name":"Spanish"},{"language":"tl","lang_name":"Tagalog"}]},{"phelps":"BB00100EXI","text":"Slava Tebi, O moj Bože! Da nije patnji na putu Tvome kako bi se oni što Te istinski ljube mogli prepoznati; i da nema kušnji što se trpe zarad ljubavi Tvoje, kako bi se uzvišenost onih koji za Tobom žude mogla pokazati? Tvoja moć mi je svjedok! Družbenice svih koji Te ljube su suze što se prolivaju, a utjehe onih koji Te traže su jauci njihovi, dok je hrana onih koji k Tebi hitaju od komadića njihovih slomljenih srca.\nKako li je slatka mojim nepcima gorčina smrti podnesene na Tvome putu, a dragocjenost meni najveća, izloženost kopljima Tvojih neprijatelja radi uzdizanja riječi Tvoje! Daj mi da u Vjeri Tvojoj okusim, o moj Bože, šta god Ti poželiš, i u ljubavi Svojoj daj mi ono što si Ti odredio.\nTako mi Slave Tvoje! Želim samo ono što Ti želiš i volim samo ono što Ti voliš. U svakom trenutku u Tebe sam polagao svu nadu svoju, u Tebe se potpuno uzdao. Ti si odista Gospodar Svega, Najviši.\nPreklinjem Te, O moj Bože, podstakni pomoćnike ovom Otkrovenju koji su takvi da će se smatrati dostojnima Tvoga imena i Tvoje Svevlasti, da će Te spominjati među Tvojim stvorenjima i podizati barjake Tvoje pobjede u zemlji Tvojoj i zaodjeni ih vrlinama i zapovjestima Tvojim.\nMoćan si Ti da činiš kako Ti volja. Nema drugog Boga osim Tebe, Pomagača u nevolji, Samodovoljnog.","category":"Teškoće","cat_order":8,"order_in_cat":1,"source":"bahaiprayers.net","version":"10d53710-ed41-4453-9939-ed3709681141","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"cs","lang_name":"Czech"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"is","lang_name":"Icelandic"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"lt","lang_name":"Lithuanian"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"es","lang_name":"Spanish"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"cy","lang_name":"Welsh"}]},{"phelps":"BB00623","text":"Ima li drugog Uklonitelja teškoća osim Boga?Recite: Neka je hvaljen Bog! On je Bog! Svi su Njegove sluge, i svi se pokoravaju zapovjesti Njegovoj!","category":"Teškoće","cat_order":8,"order_in_cat":2,"source":"bahaiprayers.net","version":"178210a0-57c3-4e8a-a121-5eca18769b1c","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"be","lang_name":"Belarusian"},{"language":"bn","lang_name":"Bengali"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"ch","lang_name":"Chamorro"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"cs","lang_name":"Czech"},{"language":"dgz","lang_name":"Daga"},{"language":"da","lang_name":"Danish"},{"language":"en","lang_name":"English"},{"language":"fo","lang_name":"Faroese"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"gux","lang_name":"Gourmanchéma"},{"language":"el","lang_name":"Greek"},{"language":"gu","lang_name":"Gujarati"},{"language":"ha","lang_name":"Hausa"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hz","lang_name":"Herero"},{"language":"hi","lang_name":"Hindi"},{"language":"ho","lang_name":"Hiri Motu"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"ik","lang_name":"Inupiaq"},{"language":"ga","lang_name":"Irish"},{"language":"it","lang_name":"Italian"},{"language":"ja","lang_name":"Japanese"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"ky","lang_name":"Kirghiz"},{"language":"kiw","lang_name":"Kiwai"},{"language":"ko","lang_name":"Korean"},{"language":"ksd","lang_name":"Kuanua"},{"language":"kgf","lang_name":"Kube"},{"language":"dih","lang_name":"Kumiai"},{"language":"lkt","lang_name":"Lakota"},{"language":"lo","lang_name":"Lao"},{"language":"lv","lang_name":"Latvian"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"mg","lang_name":"Malagasy"},{"language":"ms","lang_name":"Malay"},{"language":"ml","lang_name":"Malayalam"},{"language":"mi","lang_name":"Maori"},{"language":"mr","lang_name":"Marathi"},{"language":"mh","lang_name":"Marshallese"},{"language":"moh","lang_name":"Mohawk"},{"language":"mn","lang_name":"Mongolian"},{"language":"meu","lang_name":"Motu"},{"language":"nal","lang_name":"Nalik"},{"language":"nv","lang_name":"Navajo"},{"language":"ne","lang_name":"Nepali"},{"language":"no","lang_name":"Norwegian"},{"language":"one","lang_name":"Oneida"},{"language":"pap","lang_name":"Papiamento"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"diu","lang_name":"Rugciriku"},{"language":"ru","lang_name":"Russian"},{"language":"se","lang_name":"Sami"},{"language":"sm","lang_name":"Samoan"},{"language":"zh-Hans","lang_name":"Simplified Chinese"},{"language":"sk","lang_name":"Slovak"},{"language":"sl","lang_name":"Slovenian"},{"language":"st","lang_name":"Southern Sotho"},{"language":"es","lang_name":"Spanish"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"th","lang_name":"Thai"},{"language":"tpi","lang_name":"Tok Pisin"},{"language":"tk","lang_name":"Turkmen"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"uk","lang_name":"Ukrainian"},{"language":"wam","lang_name":"Wampanoag"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"AB07304","text":"O moj Bože! O Ti, koji praštaš grijehe! Darodavče! Ti Koji odaginješ patnje!\nNajiskrenije Ti se molim da oprostiš grijehe onima koji su napustili svoje tjelesno ruho i uznijeli se u duhovni svijet.\nO moj Gospode! Očisti ih od prestupa, rasprši njihovu tugu, a njihovu tamu pretvori u svjetlost. Daj da uđu u vrt sreće, operi ih najčistijom vodom, i podaj im da ugledaju Tvoj sjaj na najvišoj gori.","category":"Za Preminule","cat_order":9,"order_in_cat":1,"source":"bahaiprayers.net","version":"708cc3c9-8c45-4e9f-b2df-22488a1680cf","translations":[{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"be","lang_name":"Belarusian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"co","lang_name":"Corsican"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"lt","lang_name":"Lithuanian"},{"language":"mg","lang_name":"Malagasy"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ru","lang_name":"Russian"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"tk","lang_name":"Turkmen"}]},{"phelps":"ABU0826WEA","text":"O Bože! Mi smo slabi; daj nam snage.Siromašni smo; podari nam Svoje neizmjerno blago. Bolesni smo; pošalji nam Svoje božansko iscjeljenje. Nemoćni smo; daj nam udio Svoje nebeske moći. O Gospode! Omogući nam da budemo od koristi u ovom svijetu; oslobodi nas sebičnosti i žudnje. O Gospode! Podrži nas Svojom ljubavlju i uputi nas kako da volimo čitavo čovječanstvo. Osnaži nas u službi ljudima širom svijeta, da budemo sluge Tvojih slugu, da možemo da volimo sva Tvoja stvorenja i osjetimo saosjećanje za sve Tvoje narode. O Gospode! Ti si Svemoćni! Ti si Milosrdni! Ti si Onaj koji prašta! Ti si Svemogući.","source":"bahaiprayers.net","version":"fe9fc649-4966-4680-bc81-47e4968abb04","translations":[{"language":"ch","lang_name":"Chamorro"},{"language":"en","lang_name":"English"},{"language":"lg","lang_name":"Ganda"},{"language":"iba","lang_name":"Iban"},{"language":"lt","lang_name":"Lithuanian"},{"language":"ne","lang_name":"Nepali"},{"language":"sw","lang_name":"Swahili"}]},{"phelps":"BH01313NAM","text":"Tvoje ime je moje iscjeljenje, o Bože moj, pomen na Tebe moj je lijek. Tvoja blizina je meni uzdanje, a ljubav prema Tebi moj je sadrug. Milost koju mi ukazuješ je moje ozdravljenje i potpora u ovom i u narednom svijetu. Ti si, uistinu, Najvelikodušniji, Sveznajući, Premudri.","source":"bahaiprayers.net","version":"3aabc6b8-bb16-48e7-a49e-107e63edf365","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"bn","lang_name":"Bengali"},{"language":"bi","lang_name":"Bislama"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"ceb","lang_name":"Cebuano"},{"language":"ch","lang_name":"Chamorro"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"cs","lang_name":"Czech"},{"language":"dgz","lang_name":"Daga"},{"language":"dak","lang_name":"Dakota"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fo","lang_name":"Faroese"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"gux","lang_name":"Gourmanchéma"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"ha","lang_name":"Hausa"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hz","lang_name":"Herero"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"ik","lang_name":"Inupiaq"},{"language":"it","lang_name":"Italian"},{"language":"ja","lang_name":"Japanese"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"naq","lang_name":"Khoekhoegowab"},{"language":"ky","lang_name":"Kirghiz"},{"language":"ko","lang_name":"Korean"},{"language":"ksd","lang_name":"Kuanua"},{"language":"kgf","lang_name":"Kube"},{"language":"dih","lang_name":"Kumiai"},{"language":"lkt","lang_name":"Lakota"},{"language":"lo","lang_name":"Lao"},{"language":"lv","lang_name":"Latvian"},{"language":"lt","lang_name":"Lithuanian"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"mg","lang_name":"Malagasy"},{"language":"ms","lang_name":"Malay"},{"language":"ml","lang_name":"Malayal