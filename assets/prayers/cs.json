[{"phelps":"BH09401","text":"Všechna chvála, ó můj Pane, budiž Tobě, Jenž jsi Pramen vší slávy a vznešenosti, velikosti a důstojnosti, svrchovanosti a vlády, ušlechtilosti a přízně, bázně a moci. K Největšímu Oceánu přivedeš kohokoliv si přeješ, a dle Své tužby udělíš komukoli čest rozpoznat Tvé Nejdávnější Jméno. Ze všech, kdož jsou v nebi a na zemi, nikdo nemůže odolat působení Tvé svrchované Vůle. Ode vší věčnosti jsi vládl veškerému stvoření a navždy budeš všem bytostem panovat. Není Boha krom Tebe, Všemocného, Nejvznešenějšího, nadevše Silného a Nejmoudřejšího.\n\nOsvit, ó Pane, tváře Svých služebníků, aby Tě mohli spatřit, a očisti jejich srdce, aby se mohli obrátit ke dvoru Tvé nebeské laskavosti a rozpoznat Toho, Jenž je Projevem Tebe Sama a Pramenem úsvitu Tvé Podstaty. Vpravdě, Ty jsi Pán všech světů. Není Boha krom Tebe, Nespoutaného, Vše si Podmaňujícího.","category":"Chvála a vděčnost","order_in_cat":1,"source":"bahaiprayers.net","version":"8012188b-789a-439e-9bdc-dcc7654d61a2","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"am","lang_name":"Amharic"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"bi","lang_name":"Bislama"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fi","lang_name":"Finnish"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"ha","lang_name":"Hausa"},{"language":"iba","lang_name":"Iban"},{"language":"id","lang_name":"Indonesian"},{"language":"it","lang_name":"Italian"},{"language":"lv","lang_name":"Latvian"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"no","lang_name":"Norwegian"},{"language":"kj","lang_name":"Oshikwanyama"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ru","lang_name":"Russian"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"tk","lang_name":"Turkmen"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"uk","lang_name":"Ukrainian"}]},{"phelps":"BH10505","text":"Ó můj Bože, ó můj Bože!\n\nSjednot srdce Svých služebníků a odhal jim Svůj veliký záměr. Kéž následují Tvá přikázání a řídí se Tvými zákony. Pomoz jim, ó Bože, v jejich úsilí a propůjč jim sílu, aby Ti mohli sloužit. Ó Bože, neponechávej je sobě samým, nýbrž ved jejich kroky světlem Svého poznání a potěš jejich srdce Svou láskou. Vpravdě, Ty jsi jejich Pomocník a Pán.","category":"Jednota","cat_order":1,"order_in_cat":1,"source":"bahaiprayers.net","version":"70676774-2897-4604-aba3-986ad6defecf","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"hy","lang_name":"Armenian"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"bn","lang_name":"Bengali"},{"language":"bs","lang_name":"Bosnian"},{"language":"ch","lang_name":"Chamorro"},{"language":"chr","lang_name":"Cherokee"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"dgz","lang_name":"Daga"},{"language":"dak","lang_name":"Dakota"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fo","lang_name":"Faroese"},{"language":"fj","lang_name":"Fijian"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"el","lang_name":"Greek"},{"language":"gu","lang_name":"Gujarati"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"hz","lang_name":"Herero"},{"language":"hi","lang_name":"Hindi"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"ik","lang_name":"Inupiaq"},{"language":"it","lang_name":"Italian"},{"language":"ja","lang_name":"Japanese"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"naq","lang_name":"Khoekhoegowab"},{"language":"ko","lang_name":"Korean"},{"language":"ksd","lang_name":"Kuanua"},{"language":"dih","lang_name":"Kumiai"},{"language":"lkt","lang_name":"Lakota"},{"language":"lv","lang_name":"Latvian"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"ms","lang_name":"Malay"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"mi","lang_name":"Maori"},{"language":"mh","lang_name":"Marshallese"},{"language":"med","lang_name":"Melpa"},{"language":"mic","lang_name":"Mikmaq"},{"language":"mn","lang_name":"Mongolian"},{"language":"meu","lang_name":"Motu"},{"language":"nal","lang_name":"Nalik"},{"language":"nv","lang_name":"Navajo"},{"language":"ne","lang_name":"Nepali"},{"language":"no","lang_name":"Norwegian"},{"language":"pap","lang_name":"Papiamento"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"diu","lang_name":"Rugciriku"},{"language":"sm","lang_name":"Samoan"},{"language":"sr","lang_name":"Serbian"},{"language":"shh","lang_name":"Shoshoni"},{"language":"zh-Hans","lang_name":"Simplified Chinese"},{"language":"sk","lang_name":"Slovak"},{"language":"sl","lang_name":"Slovenian"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"te","lang_name":"Telugu"},{"language":"th","lang_name":"Thai"},{"language":"tpi","lang_name":"Tok Pisin"},{"language":"zh-Hant","lang_name":"Traditional Chinese"},{"language":"tk","lang_name":"Turkmen"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"uk","lang_name":"Ukrainian"},{"language":"ur","lang_name":"Urdu"},{"language":"vi","lang_name":"Vietnamese"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BHU0004SUF","text":"Dosvědčuji, ó můj Bože, že jsi mne stvořil, abych Tě znal a uctíval.\n\nDoznávám v tomto okamžiku svou bezmocnost a Tvoji moc, svou chudobu a Tvé bohatství.\n\nNení Boha kromě Tebe, Pomocníka v nebezpečí, Skrze Sebe Jsoucího.","name":"Short Obligatory Prayer","category":"Krátká denní modlitba","cat_order":2,"order_in_cat":1,"source":"bahaiprayers.net","version":"d2fe9bf7-1de3-44fe-95ce-a9c266acf239","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"am","lang_name":"Amharic"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"be","lang_name":"Belarusian"},{"language":"bi","lang_name":"Bislama"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fj","lang_name":"Fijian"},{"language":"de","lang_name":"German"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hz","lang_name":"Herero"},{"language":"hu","lang_name":"Hungarian"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"lv","lang_name":"Latvian"},{"language":"lt","lang_name":"Lithuanian"},{"language":"ml","lang_name":"Malayalam"},{"language":"meu","lang_name":"Motu"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"sl","lang_name":"Slovenian"},{"language":"tl","lang_name":"Tagalog"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"ABU0023UNI","text":"Ó můj Bože! Ó Ty, Jenž odpouštíš hříchy! Ty, Jenž propůjčuješ dary! Ty, Jenž zbavuješ utrpení!\n\nVpravdě, vroucně Tě prosím, odpuse\u0001 hříchy těm, kteří odložili pozemské roucho a vystoupili do duchovního světa.\n\nÓ můj Bože! Očisti je od provinění, rozptyl jejich zármutek a změň jejich temno ve světlo. Neche\u0001 vejdou do zahrady blaženosti, omyj je nejčistší vodou a dovol jim spatřit Tvou slávu a nádheru na nejvznešenější hoře.","category":"Modlitba za zesnulé","cat_order":3,"order_in_cat":1,"source":"bahaiprayers.net","version":"03ede3ff-c034-4e43-953c-1fb71dd5659c","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"am","lang_name":"Amharic"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"az","lang_name":"Azerbaijani"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"bi","lang_name":"Bislama"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"hr","lang_name":"Croatian"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"is","lang_name":"Icelandic"},{"language":"it","lang_name":"Italian"},{"language":"lv","lang_name":"Latvian"},{"language":"mg","lang_name":"Malagasy"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"pt","lang_name":"Portuguese"},{"language":"sk","lang_name":"Slovak"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"vi","lang_name":"Vietnamese"}]},{"phelps":"AB07155WOM","text":"Můj Pane! Můj Pane! Vzdávám Ti chválu a díky za to, čím jsi vyznamenal Svou pokornou služebnici, Svou snažně prosící a pokorně se modlící otrokyni, neboe\u0001 jsi ji vpravdě uvedl do Svého zjeveného království a dal jsi jí uslyšet Své vznešené volání a spatřit Svá znamení, jež dokazují, že je nade všemi věcmi ustanovena Tvá vítězná vláda.\n\nÓ můj Pane, to, co nosím ve svém lůně, zasvěcuji Tobě. Dej pak, ae\u0001 je mé dítě hodno chvály ve Tvém Království, ae\u0001 je obše\u0001astněno Tvou přízní a Tvou štědrostí a ae\u0001 se rozvíjí a vyrůstá pod Tvým vedením. Vpravdě, Tys Milostivý. Vpravdě, Tys Pán veliké přízně.","category":"Nastávající matky","cat_order":4,"order_in_cat":1,"source":"bahaiprayers.net","version":"654059a1-871c-4599-baf4-291f7988b85b","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"be","lang_name":"Belarusian"},{"language":"bn","lang_name":"Bengali"},{"language":"ca","lang_name":"Catalan"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hu","lang_name":"Hungarian"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"it","lang_name":"Italian"},{"language":"lv","lang_name":"Latvian"},{"language":"mt","lang_name":"Maltese"},{"language":"no","lang_name":"Norwegian"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ru","lang_name":"Russian"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"}]},{"phelps":"BB00522","text":"Ó Pane! K Tobě se utíkám pro přístřeší a své srdce obracím ke všem Tvým znamením.\n\nPane! At na cestách či doma, při své práci či ve svém povolání, vkládám všechnu svou důvěru v Tebe.\n\nPane! Uděl mi Svou pomoc, jež postačuje, aby mne učinila nezávislým na čemkoliv, Ó Ty, Jehož milost nezná sobě rovné.\n\nPoskytni mi můj díl, Pane, jak se Ti zlíbí, a dej, at naleznu uspokojení v čemkoliv, co jsi pro mne určil.\n\nTobě náleží úplná pravomoc, abys přikazoval.","category":"Ochrana","cat_order":5,"order_in_cat":1,"source":"bahaiprayers.net","version":"a4a17311-3f64-470a-b596-b51bf197fcce","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"ceb","lang_name":"Cebuano"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hz","lang_name":"Herero"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"it","lang_name":"Italian"},{"language":"lv","lang_name":"Latvian"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"mt","lang_name":"Maltese"},{"language":"mh","lang_name":"Marshallese"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"sm","lang_name":"Samoan"},{"language":"sk","lang_name":"Slovak"},{"language":"sl","lang_name":"Slovenian"},{"language":"es","lang_name":"Spanish"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"zh-Hant","lang_name":"Traditional Chinese"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"vi","lang_name":"Vietnamese"}]},{"phelps":"BH10581","text":"Jsem ten, ó můj Pane, který k Tobě obrací tvář a upíná naděje na zázraky Tvé milosti a zjevení Tvého dobrodiní. Modlím se k Tobě, Pane, nedopust, abych se odvracel zklamaný ode dveří Tvé milosti a neponechávej mne prosím napospas těm, kteří zavrhli Tvou Věc.\n\nJsem, ó můj Bože, Tvůj služebník a syn Tvého služebníka. Poznal jsem Tvou pravdu ve Tvých dnech a namířil své kroky ke břehům Tvé jedinosti. Uznávám Tvou jedinečnost, dotvrzuji Tvou jednotu a doufám ve Tvé odpuštění a prominutí. V moci Tvé je činit, jak se Ti zlíbí. Není Boha kromě Tebe, Přeslavného, Vždy Odpouštějícího.","category":"Odpuštění","cat_order":6,"order_in_cat":1,"source":"bahaiprayers.net","version":"d1f2f654-6080-49b6-9b8b-7b750e9a9618","translations":[{"language":"am","lang_name":"Amharic"},{"language":"az","lang_name":"Azerbaijani"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"ca","lang_name":"Catalan"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"fi","lang_name":"Finnish"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"is","lang_name":"Icelandic"},{"language":"it","lang_name":"Italian"},{"language":"ky","lang_name":"Kirghiz"},{"language":"ms","lang_name":"Malay"},{"language":"mn","lang_name":"Mongolian"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"tvl","lang_name":"Tuvalu"}]},{"phelps":"BB00617","text":"Snažně Tě prosím, ó můj Pane, odpust mi každou zmínku, jež není zmínkou o Tobě a každou chválu, jež není chválou Tebe a každé štěstí, jež není štěstím ve Tvé blízkosti a každé potěšení, jež není potěšením z rozmlouvaní s Tebou a každou radost, jež není radostí ze Tvé lásky a libosti a všechno, co mi přináleží, ale nemá žádné spojitosti s Tebou, ó Ty, Jenž jsi Pánem pánů, Ty, Jenž poskytuješ prostředky a odemykáš dveře.","category":"Odpuštění","cat_order":6,"order_in_cat":2,"source":"bahaiprayers.net","version":"a7a49205-6424-4b88-85b7-5d8556ef526e","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"hr","lang_name":"Croatian"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"gux","lang_name":"Gourmanchéma"},{"language":"el","lang_name":"Greek"},{"language":"gu","lang_name":"Gujarati"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hz","lang_name":"Herero"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"it","lang_name":"Italian"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"ky","lang_name":"Kirghiz"},{"language":"ko","lang_name":"Korean"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"mg","lang_name":"Malagasy"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"mh","lang_name":"Marshallese"},{"language":"ne","lang_name":"Nepali"},{"language":"kj","lang_name":"Oshikwanyama"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"diu","lang_name":"Rugciriku"},{"language":"ru","lang_name":"Russian"},{"language":"zh-Hans","lang_name":"Simplified Chinese"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"tet","lang_name":"Tetum"},{"language":"zh-Hant","lang_name":"Traditional Chinese"},{"language":"tk","lang_name":"Turkmen"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"uk","lang_name":"Ukrainian"}]},{"phelps":"AB09794CHI","text":"Ó můj Bože! Žádám Tě při Tvém nejskvostnějším Jménu, abys mi pomáhal v tom, co přinese prospěch záležitostem Tvých služebníků a rozkvět Tvým městům. Tobě, vskutku, náleží moc nade vším.","category":"Pomoc a podpora","cat_order":7,"order_in_cat":1,"source":"bahaiprayers.net","version":"63be00df-6fd8-4027-ac45-4ddd0be49938","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"az","lang_name":"Azerbaijani"},{"language":"ca","lang_name":"Catalan"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fj","lang_name":"Fijian"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hz","lang_name":"Herero"},{"language":"hu","lang_name":"Hungarian"},{"language":"id","lang_name":"Indonesian"},{"language":"it","lang_name":"Italian"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"ksd","lang_name":"Kuanua"},{"language":"lv","lang_name":"Latvian"},{"language":"mg","lang_name":"Malagasy"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"no","lang_name":"Norwegian"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"vi","lang_name":"Vietnamese"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BB00623","text":"Je nějaký Vysvoboditel z těžkostí kromě Boha?\n\nRci: Chválen bud Bůh! On je Bůh! Všichni jsou Jeho služebníci a všichni se řídí Jeho příkazem.","category":"Pomoc a podpora","cat_order":7,"order_in_cat":2,"source":"bahaiprayers.net","version":"f68632b7-8863-47b8-92c1-5e417569c936","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"be","lang_name":"Belarusian"},{"language":"bn","lang_name":"Bengali"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"ch","lang_name":"Chamorro"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"dgz","lang_name":"Daga"},{"language":"da","lang_name":"Danish"},{"language":"en","lang_name":"English"},{"language":"fo","lang_name":"Faroese"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"gux","lang_name":"Gourmanchéma"},{"language":"el","lang_name":"Greek"},{"language":"gu","lang_name":"Gujarati"},{"language":"ha","lang_name":"Hausa"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hz","lang_name":"Herero"},{"language":"hi","lang_name":"Hindi"},{"language":"ho","lang_name":"Hiri Motu"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"ik","lang_name":"Inupiaq"},{"language":"ga","lang_name":"Irish"},{"language":"it","lang_name":"Italian"},{"language":"ja","lang_name":"Japanese"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"ky","lang_name":"Kirghiz"},{"language":"kiw","lang_name":"Kiwai"},{"language":"ko","lang_name":"Korean"},{"language":"ksd","lang_name":"Kuanua"},{"language":"kgf","lang_name":"Kube"},{"language":"dih","lang_name":"Kumiai"},{"language":"lkt","lang_name":"Lakota"},{"language":"lo","lang_name":"Lao"},{"language":"lv","lang_name":"Latvian"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"mg","lang_name":"Malagasy"},{"language":"ms","lang_name":"Malay"},{"language":"ml","lang_name":"Malayalam"},{"language":"mi","lang_name":"Maori"},{"language":"mr","lang_name":"Marathi"},{"language":"mh","lang_name":"Marshallese"},{"language":"moh","lang_name":"Mohawk"},{"language":"mn","lang_name":"Mongolian"},{"language":"cnr","lang_name":"Montenegrin"},{"language":"meu","lang_name":"Motu"},{"language":"nal","lang_name":"Nalik"},{"language":"nv","lang_name":"Navajo"},{"language":"ne","lang_name":"Nepali"},{"language":"no","lang_name":"Norwegian"},{"language":"one","lang_name":"Oneida"},{"language":"pap","lang_name":"Papiamento"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"diu","lang_name":"Rugciriku"},{"language":"ru","lang_name":"Russian"},{"language":"se","lang_name":"Sami"},{"language":"sm","lang_name":"Samoan"},{"language":"zh-Hans","lang_name":"Simplified Chinese"},{"language":"sk","lang_name":"Slovak"},{"language":"sl","lang_name":"Slovenian"},{"language":"st","lang_name":"Southern Sotho"},{"language":"es","lang_name":"Spanish"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"th","lang_name":"Thai"},{"language":"tpi","lang_name":"Tok Pisin"},{"language":"tk","lang_name":"Turkmen"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"uk","lang_name":"Ukrainian"},{"language":"wam","lang_name":"Wampanoag"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BB00015","text":"Rci: Bůh postačuje všem věcem a nade vše a nic na nebesích ani na zemi nepostačuje, jen Bůh. Vpravdě On Sám v Sobě je Vědoucí, Zachovávající, Všemohoucí.","category":"Pomoc a podpora","cat_order":7,"order_in_cat":3,"source":"bahaiprayers.net","version":"444d1863-ffd6-4720-a5d6-3323a99ca037","translations":[{"language":"hy","lang_name":"Armenian"},{"language":"en","lang_name":"English"},{"language":"ja","lang_name":"Japanese"},{"language":"ms","lang_name":"Malay"},{"language":"med","lang_name":"Melpa"},{"language":"mn","lang_name":"Mongolian"},{"language":"sm","lang_name":"Samoan"},{"language":"zh-Hans","lang_name":"Simplified Chinese"},{"language":"ta","lang_name":"Tamil"},{"language":"th","lang_name":"Thai"},{"language":"tpi","lang_name":"Tok Pisin"},{"language":"zh-Hant","lang_name":"Traditional Chinese"},{"language":"uk","lang_name":"Ukrainian"}]},{"phelps":"BB00100EXI","text":"Ó ty, jenž obracíš svou tvář k Bohu! Zavři oči před vším ostatním a otevři je říši Nadevše Slavného.\n\nŽádej vše, co si přeješ, pouze od Něho;\nhledej vše, co hledáš, pouze u Něho.\n\nJedním pohledem dává sto tisíc nadějí,\njedním ohlédnutím uzdravuje sto tisíc nevyléčitelných nemocí,\njedním mžikem oka klade balzám na každou ránu,\njediným kývnutím osvobozuje srdce z okovů zármutku.\n\nOn činí, jak činí, a co nám zbývá?\nOn uskutečňuje Svou Vůli a nařizuje, co si přeje.\nPak je pro tebe lepší sklonit hlavu v odevzdanosti\na vložit svou důvěru v Nadevše Milosrdného Pána.","category":"Pomoc a podpora","cat_order":7,"order_in_cat":4,"source":"bahaiprayers.net","version":"9a14e218-1283-4c0a-9627-2094dc9d3bd0","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"is","lang_name":"Icelandic"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"lt","lang_name":"Lithuanian"},{"language":"cnr","lang_name":"Montenegrin"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"es","lang_name":"Spanish"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"cy","lang_name":"Welsh"}]},{"phelps":"BH04421HEA","text":"Stvoř ve mně čisté srdce, ó můj Bože, a obnov ve mně klidné svědomí, ó má Naděje! Mocným duchem upevni mne ve Své Věci, ó můj Nejmilovanější, a odhal Svou cestu světlem Své slávy, ó Ty Cíli mé touhy! Silou Své všepřesahující moci pozvedni mne do nebes Své svatosti, ó Zdroji mého bytí, a vánkem Své věčnosti oblaž mne, ó Ty, Kterýž jsi můj Bůh! Dej, at Tvé věčné melodie na mne dýchají klid a mír, ó můj Společníku, a necht mne bohatství Tvého pradávného zjevu osvobodí ode všeho kromě Tebe, ó můj Pane, a necht mi zvěst o zjevení Tvé nepomíjející Podstaty přinese radost, ó Ty, Jenž jsi nejprojevenějším z projeveného a nejskrytějším ze skrytého!","category":"Prosba o duchovní vlastnosti","cat_order":8,"order_in_cat":1,"source":"bahaiprayers.net","version":"a059f15a-05cf-44c4-b50f-458399bfdaf8","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"be","lang_name":"Belarusian"},{"language":"bn","lang_name":"Bengali"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fj","lang_name":"Fijian"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"el","lang_name":"Greek"},{"language":"gu","lang_name":"Gujarati"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"ha","lang_name":"Hausa"},{"language":"hz","lang_name":"Herero"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"it","lang_name":"Italian"},{"language":"ky","lang_name":"Kirghiz"},{"language":"lt","lang_name":"Lithuanian"},{"language":"mg","lang_name":"Malagasy"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"cnr","lang_name":"Montenegrin"},{"language":"ne","lang_name":"Nepali"},{"language":"kj","lang_name":"Oshikwanyama"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"diu","lang_name":"Rugciriku"},{"language":"ru","lang_name":"Russian"},{"language":"se","lang_name":"Sami"},{"language":"sm","lang_name":"Samoan"},{"language":"st","lang_name":"Southern Sotho"},{"language":"es","lang_name":"Spanish"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"tet","lang_name":"Tetum"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"ABU1863","text":"Ó Bože, osvěž a potěš mého ducha. Očisti mé srdce. Občerstvi mé síly. Všechny své záležitosti vkládám do Tvých rukou. Ty jsi můj Průvodce a mé Útočiště. Nebudu se již nadále trápit a rmoutit, budu štastná a veselá bytost. Ó Bože, nebudu již pln netrpělivosti a napětí, nenechám se skličovat strastmi. Nebudu ulpívat na neuspokojivých věcech tohoto života.\n\nÓ Bože, Ty jsi mi lepším přítelem nežli já sám sobě. Odevzdávám se Ti, ó Pane!","category":"Prosba o duchovní vlastnosti","cat_order":8,"order_in_cat":2,"source":"bahaiprayers.net","version":"e9d8822a-9261-430b-978e-6b7f9cbd9790","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"hy","lang_name":"Armenian"},{"language":"bn","lang_name":"Bengali"},{"language":"bi","lang_name":"Bislama"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fj","lang_name":"Fijian"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"hz","lang_name":"Herero"},{"language":"id","lang_name":"Indonesian"},{"language":"ky","lang_name":"Kirghiz"},{"language":"lo","lang_name":"Lao"},{"language":"lv","lang_name":"Latvian"},{"language":"lt","lang_name":"Lithuanian"},{"language":"ms","lang_name":"Malay"},{"language":"ml","lang_name":"Malayalam"},{"language":"mr","lang_name":"Marathi"},{"language":"no","lang_name":"Norwegian"},{"language":"ru","lang_name":"Russian"},{"language":"sr","lang_name":"Serbian"},{"language":"zh-Hans","lang_name":"Simplified Chinese"},{"language":"sl","lang_name":"Slovenian"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"te","lang_name":"Telugu"},{"language":"tet","lang_name":"Tetum"},{"language":"th","lang_name":"Thai"}]},{"phelps":"BH02806","text":"Vidíš, Ó Pane, naše ruce pozvednuté v pokorné prosbě k nebi Tvé přízně a štědrosti. Dej, ae\u0001 je naplní poklady Tvé velkomyslnosti a štědré přízně. Odpuse\u0001 nám, našim otcům a matkám a vyplň všechna naše přání z oceánu Své milosti a Božské přízně. Přijmi, Ó Milovaný našich srdcí, všechno naše konání na Tvé stezce. Tys, vpravdě, Nejmocnější, Nejvznešenější, Neporovnatelný, Jediný, Odpouštějící, Milostivý.","category":"Rodina","cat_order":9,"order_in_cat":1,"source":"bahaiprayers.net","version":"de12bc14-5ec2-4e9f-b430-d808729f293b","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"hy","lang_name":"Armenian"},{"language":"bn","lang_name":"Bengali"},{"language":"hr","lang_name":"Croatian"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fr","lang_name":"French"},{"language":"kgf","lang_name":"Kube"},{"language":"lt","lang_name":"Lithuanian"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"sm","lang_name":"Samoan"},{"language":"sr","lang_name":"Serbian"},{"language":"es","lang_name":"Spanish"},{"language":"tpi","lang_name":"Tok Pisin"}]},{"phelps":"BH07469","text":"Ó Pane! V tomto Největším Zřízení přijímáš přímluvy dětí za jejich rodiče. Je to jeden z pozoruhodných a nekonečných darů tohoto Zřízení. Přijmi tedy, ó laskavý Pane, prosbu Svého služebníka na prahu Tvé jedinosti a ponoř jeho otce do oceánu Své milosti. Vždye\u0001 jeho syn povstal, aby se oddal Tvé službě, a po všechen čas vynakládal úsilí na stezce Tvé lásky. Vpravdě, Tys Dárce, Odpouštějící a Laskavý.","category":"Rodina","cat_order":9,"order_in_cat":2,"source":"bahaiprayers.net","version":"2d4bbd1b-74f7-4a7b-8190-c3a79e9db4d9","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"az","lang_name":"Azerbaijani"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"is","lang_name":"Icelandic"},{"language":"it","lang_name":"Italian"},{"language":"lv","lang_name":"Latvian"},{"language":"no","lang_name":"Norwegian"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"}]},{"phelps":"AB05652WIS","text":"On je Bůh!\n\nÓ nedostižný Pane! Ve Své všemohoucí moudrosti jsi uložil lidem vstupovat ve sňatek, aby tak v tomto pomíjivém světě mohlo následovat jedno pokolení za druhým a aby, dokud bude svět světem, všichni mohli na Prahu Tvé jedinosti prokazovat službu a ponořit se v uctívání, oslavu, blahořečení a chválu.\n\n„A duchy a lidi jsem jedině proto stvořil, aby Mne uctívali.“¹. Oddej proto v nebi Svého milosrdenství tato dvě ptáčata z hnízda Své lásky, dej, ae\u0001 vyvolávají Tvou věčnou milost, aby ze svazku těchto dvou moří lásky povstala vlna něžnosti a vynesla na břeh života perly potomstva ctnostného a pohledného.\n\n„A volně dal téci oběma mořím, jež se setkají,\nvšak mezi nimi překážka stojí, již nezdolají.\nKteré z dobrodiní Pána svého můžete popírat?\nA z obou moří se perly velké i malé loví.“²\n\nÓ laskavý Pane. Dej, aby toto manželství rodilo korály a perly. Ty, vpravdě, jsi Nejmocnější, Nejvyšší, Vždy Odpouštějící.\n\n¹ Korán 51:56\n² Korán 55:19-22","category":"Sňatek","cat_order":10,"order_in_cat":1,"source":"bahaiprayers.net","version":"a4b0b81c-43cc-4cb6-9cc1-2aed914442de","translations":[{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"is","lang_name":"Icelandic"},{"language":"it","lang_name":"Italian"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"ne","lang_name":"Nepali"},{"language":"no","lang_name":"Norwegian"},{"language":"ro","lang_name":"Romanian"},{"language":"es","lang_name":"Spanish"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"tk","lang_name":"Turkmen"},{"language":"uk","lang_name":"Ukrainian"}]},{"phelps":"BH08600TES","text":"Ó Ty, Jehož zkoušky jsou uzdravujícím lékem pro Ty, kteří jsou Ti blízcí, Jehož meč je horoucí touhou všech, kteří Tě milují, Jehož šípy jsou nejdražším přáním těch srdcí, která po Tobě touží, Jehož výnos je jedinou nadějí těch, kteří uznali Tvou pravdu! Snažně Tě prosím při Tvé božské líbeznosti a při lesku a nádheře slávy Tvé tváře, sešli nám ze Svého útočiště na výšinách to, co nám pomůže se Ti přiblížit. Učiň naše kroky jistými ve Tvé Věci, ó můj Pane, a osvie\u0001 naše srdce září Svého poznání a prosvětli naši hru\u000f\u0001 jasem Svých jmen.","category":"Zkoušky a obtíže","cat_order":12,"order_in_cat":1,"source":"bahaiprayers.net","version":"f019622c-e82f-4f4c-a67f-868a6d96e047","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"ceb","lang_name":"Cebuano"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"it","lang_name":"Italian"},{"language":"kn","lang_name":"Kannada"},{"language":"ky","lang_name":"Kirghiz"},{"language":"lv","lang_name":"Latvian"},{"language":"mg","lang_name":"Malagasy"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"ne","lang_name":"Nepali"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"sm","lang_name":"Samoan"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"vi","lang_name":"Vietnamese"}]},{"phelps":"BH03629GRI","text":"Rozptyl můj zármutek Svou štědrostí a šlechetností, ó Bože, můj Bože, a zažeň mou úzkost Svou vládou a mocí. Vidíš, ó můj Bože, jak obracím tváří k Tobě v době, kdy jsem ze všech stran skličován bolestí a zármutkem. Vroucně Tě prosím, ó Ty, Který jsi Pánem všeho bytí a zastiňuješ všechny věci viditelné i neviditelné, při Tvém Jménu, kterým jsi podmanil srdce a duše lidí a při vlnách Oceánu Tvé milosti a skvoucí záři Denice Tvé štědrosti, abys mne započítal k těm, kterým nikdy nic nezabrání obracet tvář k Tobě, ó Pane všech jmen a Stvořiteli nebes.\n\nVidíš, ó můj Pane, co mne postihlo ve Tvých dnech. Úpěnlivě Tě žádám při Tom, Jenž je Rozbřeskem Tvých Jmen a Místem úsvitu Tvých přívlastků, abys pro mne určil to, co mi umožní povstat ke Tvé službě a velebit Tvé ctnosti. Ty jsi, vpravdě, Nejmocnější, Ty odpovídáš na modlitby lidí.\n\nA konečně Tě prosím při světle Tvého tváře, abys požehnal mému konání, zprostil mne dluhů a uspokojil mé potřeby. Tvou moc a vládu doznávala každá ústa a Tvou svrchovanost a Tvůj majestát poznalo každé chápající srdce. Není Boha krom Tebe, Který slyšíš naše modlitby a jsi připraven odpovědět.","category":"Zkoušky a obtíže","cat_order":12,"order_in_cat":2,"source":"bahaiprayers.net","version":"eb24c0be-a587-4e9a-bd86-7a48ed1c9ed8","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"bn","lang_name":"Bengali"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"it","lang_name":"Italian"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"ky","lang_name":"Kirghiz"},{"language":"lv","lang_name":"Latvian"},{"language":"mg","lang_name":"Malagasy"},{"language":"mt","lang_name":"Maltese"},{"language":"mn","lang_name":"Mongolian"},{"language":"no","lang_name":"Norwegian"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"uk","lang_name":"Ukrainian"}]},{"phelps":"BH01313NAM","text":"Tvé Jméno mne hojí, ó můj Bože a vzpomínka na Tebe je mým lékem. Tvá blízkost je mou nadějí a láska k Tobě je mým průvodcem. Tvé milosrdenství mne léčí a pomáhá mi v obou světech, v tomto i příštím. Ty jsi vpravdě Přeštědrý, Vševědoucí, Nejmoudřejší.","source":"bahaiprayers.net","version":"ca52f744-b146-4070-8d1c-a3b318692259","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"bn","lang_name":"Bengali"},{"language":"bi","lang_name":"Bislama"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"ceb","lang_name":"Cebuano"},{"language":"ch","lang_name":"Chamorro"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"dgz","lang_name":"Daga"},{"language":"dak","lang_name":"Dakota"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"