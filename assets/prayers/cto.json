{"prayers":[{"phelps":"BH11209","text":"# Short Obligatory Prayer\n## To be recited once in twenty-four hours, at noon.\n\nBútru mua asia Béra caira cawabamanea Béra zhi biara jaraita. Mũa jaraya jõmaũa Bũ ne ẽaba mũa o be ẽa. Béra wárinu obeya. Mùra zhi supuriata Béra shi wai bua bara buta.\nBéra Caragabia tewara ne ẽa. Shi dai ne cazhirua cawade ni mi buru ewate Bé tru careba bua Béra to aba bua tewara waĩ ẽa bu ẽa.","name":"Short Obligatory Prayer","source":"bw17","version":"8697940e-c0be-4485-a3b7-e4923ef7cee5","v":"7yurbnnj4famx3zgegckwxvqd","book_cats":{"af:bpnet":{"cat":"Kort verpligte gebed","order_in_cat":1},"am:bpnet":{"cat":"አጭሩ (Short)","order_in_cat":1},"ar:bpnet":{"cat":"الصلاة   الصغيرة","order_in_cat":1},"az:bpnet":{"cat":"Qısa Namaz","order_in_cat":1},"be:bpapp":{"cat":"Абавязковая малітвы","cat_order":1,"order_in_cat":1},"be:bpnet":{"cat":"Кароткая абавязковая малітва","order_in_cat":1},"bg:bpnet":{"cat":"Кратка задължителна молитва","order_in_cat":1},"bi:bpnet":{"cat":"SOTFALA  OBLIGATORI  PREA","order_in_cat":1},"bs:bpnet":{"cat":"Kratka Obavezna Molitva","order_in_cat":1},"ca:bpnet":{"cat":"Oració obligatòria curta","order_in_cat":1},"co:bpnet":{"cat":"Preghera dì tutti i ghjorni","order_in_cat":1},"cs:bpnet":{"cat":"Krátká denní modlitba","order_in_cat":1},"cy:bpnet":{"cat":"Short Obligatory Prayer","order_in_cat":1},"da:bpnet":{"cat":"Kort Obligatorisk Bøn","order_in_cat":1},"de:bpapp":{"cat":"Pflichtgebete","cat_order":1,"order_in_cat":2},"de:bpnet":{"cat":"Das kurze Pflichtgebet","order_in_cat":1},"dgz:bpnet":{"cat":"Marek Iyanupe U’uraewa (Short Obligatory Prayer)","order_in_cat":1},"el:bpnet":{"cat":"ΜΙΚΡΗ ΥΠΟΧΡΕΩΤΙΚΗ ΠΡΟΣΕΥΧΗ","order_in_cat":1},"en:bpnet":{"cat":"Short Obligatory Prayer","order_in_cat":1},"eo:bel-malnova":{"cat":"Devigaj Preĝoj","cat_order":11,"order_in_cat":1},"eo:bpapp":{"cat":"Devigaj Preĝoj","cat_order":11,"order_in_cat":2},"eo:bpnet":{"cat":"Devigaj Preĝoj - La Mallonga","order_in_cat":1},"es:bpnet":{"cat":"Oración o