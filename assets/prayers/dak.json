language":"sl","lang_name":"Slovenian"},{"language":"ch","lang_name":"Chamorro"},{"language":"te","lang_name":"Telugu"},{"language":"en","lang_name":"English"},{"language":"fj","lang_name":"Fijian"},{"language":"naq","lang_name":"Khoekhoegowab"},{"language":"kn","lang_name":"Kannada"},{"language":"gu","lang_name":"Gujarati"},{"language":"cy","lang_name":"Welsh"},{"language":"shh","lang_name":"Shoshoni"},{"language":"ny","lang_name":"Chichewa"},{"language":"mt","lang_name":"Maltese"}]},{"phelps":"BH11209","text":"Waayantanin bluha\nWakantanka mitawa\nSloci in kta un makakaga\nNa ci yu onihan te\nLe oape ki el\nOmahiti ke sni\nNa niye onihitike\nWamahpa nica\nNa Niye winisica\nNisnala wakan ni tanka\nWokokipe el wayokiya\nNa iye oiciya\n\n\n* I bear witness, O my God, that Thou hast created me to know Thee and to worship Thee. I testify, at this moment, to my powerlessness and to Thy might, to my poverty and to Thy wealth.\nThere is none other God but Thee, the Help in Peril, the Self-Subsisting.","source":"bahaiprayers.net","version":"4a6b4a9b-d117-4063-bf66-7ec044666969","book_cats":{"af":{"cat":"Kort verpligte gebed","cat_order":18,"order_in_cat":1},"am":{"cat":"አጭሩ (Short)","cat_order":30,"order_in_cat":1},"ar":{"cat":"الصلاة   الصغيرة","cat_order":22,"order_in_cat":1},"ar-translit":{"cat":"الصلاة   الصغيرة","cat_order":22,"order_in_cat":1},"az":{"cat":"Qısa Namaz","cat_order":26,"order_in_cat":1},"be":{"cat":"Кароткая абавязковая малітва","cat_order":13,"order_in_cat":1},"bg":{"cat":"Кратка задължителна молитва","cat_order":13,"order_in_cat":1},"bi":{"cat":"SOTFALA  OBLIGATORI  PREA","cat_order":22,"order_in_cat":1},"bs":{"cat":"Kratka Obavezna Molitva","cat_order":12,"order_in_cat":1},"ca":{"cat":"Oració obligatòria curta","cat_order":24,"order_in_cat":1},"co":{"cat":"Preghera dì tutti i ghjorni","cat_order":4,"order_in_cat":1},"da":{"cat":"Kort Obligatorisk Bøn","cat_order":21,"order_in_cat":1},"de":{"cat":"Das kurze Pflichtgebet","cat_order":7,"order_in_cat":1