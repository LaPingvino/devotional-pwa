[{"phelps":"BH00074BLE","text":"## Gwich'in\n\n\"Blessed is the Spot\" in the language of the Gwich'in First Nations.\n\nBAHA'I EENJIT GIGIINJIK\n\nGwiizrii gwijuu'ee gwahtsii,\n\nts'at jii nakhwahzheh,\n\nts'at jii diikaiik'it,\n\nts'at jii diidrii,\n\nts'at ddhah,\n\nts'at galchiijaa,\n\nts'at nin an,\n\nts'at antl'at,\n\nts'at nanh,\n\nts'at chuu choo\n\nts'at njuu,\n\nK'agwaadhat nijin nanh chyah gwaltsaii,\n\nts'at yinji'gwichil'ee ts'at ch'agwahdit.","name":"Gwich'in","source":"bahaiprayers.net","version":"5cd6bd26-8d8f-4386-bd45-3b24b2e9f11d","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"be","lang_name":"Belarusian"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"chr","lang_name":"Cherokee"},{"language":"co","lang_name":"Corsican"},{"language":"dgz","lang_name":"Daga"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"ik","lang_name":"Inupiaq"},{"language":"ga","lang_name":"Irish"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kiw","lang_name":"Kiwai"},{"language":"ksd","lang_name":"Kuanua"},{"language":"kgf","lang_name":"Kube"},{"language":"lkt","lang_name":"Lakota"},{"language":"lt","lang_name":"Lithuanian"},{"language":"lut","lang_name":"Lushootseed"},{"language":"ml","lang_name":"Malayalam"},{"language":"med","lang_name":"Melpa"},{"language":"moh","lang_name":"Mohawk"},{"language":"meu","lang_name":"Motu"},{"language":"nv","lang_name":"Na