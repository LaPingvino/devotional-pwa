[{"phelps":"BH00074BLE","text":"*\"Blessed is the Spot\" in the language of the Gwich'in First Nations.\n\n\n\nBAHA'I EENJIT GIGIINJIK\n\nGwiizrii gwijuu'ee gwahtsii,\nts'at jii nakhwahzheh,\nts'at jii diikaiik'it,\nts'at jii diidrii,\nts'at ddhah,\nts'at galchiijaa,\nts'at nin an,\nts'at antl'at,\nts'at nanh,\nts'at chuu choo\nts'at njuu,\nK'agwaadhat nijin nanh chyah gwaltsaii,\nts'at yinji'gwichil'ee ts'at ch'agwahdit.","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"sq","lang_name":"Albanian"},{"language":"be","lang_name":"Belarusian"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"bs","lang_name":"Bosnian"},{"language":"ca","lang_name":"Catalan"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"km","lang_name":"Central Khmer"},{"language":"chr","lang_name":"Cherokee"},{"language":"co","lang_name":"Corsican"},{"language":"co","lang_name":"Corsican"},{"language":"en","lang_name":"English"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"et","lang_name":"Estonian"},{"language":"fr","lang_name":"French"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"de","lang_name":"German"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"hur","lang_name":"Halkomelem"},{"language":"haw","lang_name":"Hawaiian"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hu","lang_name":"Hungarian"},{"language":"hu","lang_name":"Hungarian"},{"language":"is","lang_name":"Icelandic"},{"language":"is","lang_name":"Icelandic"},{"language":"ga","lang_name":"Irish"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kiw","lang_name":"Kiwai"},{"language":"lkt","l