{"prayers":[{"phelps":"BH11209","text":"# Short Obligatory Prayer\n## To be recited once in twenty-four hours, at noon.\n\nAku jaji saksi ndug tanpa aku, akam mbuh ngundah supaya aku empuan akam serta lalu nyembah akam. Aku besaksi ndug iti seh, minan semoa pengurang kuasa aku ndug semoa pengagah akam, serta dingan pinyiranta aku dengan pingiraja akam.\n Anyap tanpa da bekun masu akam, pinulung masa susah, pinulung adup.","name":"Short Obligatory Prayer","source":"bw17","version":"b3964e43-c011-41e0-879c-03430ce44b27","v":"amr29a8zrrn0sz120il54rrc7","book_cats":{"af:bp":{"cat":"Kort verpligte gebed","order_in_cat":1},"am:bp":{"cat":"አጭሩ (Short)","order_in_cat":1},"ar:bp":{"cat":"الصلاة   الصغيرة","order_in_cat":1},"az:bp":{"cat":"Qısa Namaz","order_in_cat":1},"be:bp":{"cat":"Кароткая абавязковая малітва","order_in_cat":1},"bg:bp":{"cat":"Кратка задължителна молитва","order_in_cat":1},"ca:bp":{"cat":"Oració obligatòria curta","order_in_cat":1},"cs:bp":{"cat":"Krátká denní modlitba","order_in_cat":1},"da:bp":{"cat":"Kort Obligatorisk Bøn","order_in_cat":1},"de:bp":{"cat":"Das kurze Pflichtgebet","order_in_cat":1},"en:bp":{"cat":"Short Obligatory Prayer","order_in_cat":1},"eo:bp":{"cat":"Devigaj Preĝoj - La Mallonga","order_in_cat":1},"es:bp":{"cat":"Oración obligatoria corta","order_in_cat":1},"fa:bp":{"cat":"نماز صغیر","order_in_cat":1},"fi:bp":{"cat":"Lyhyt velvollisuusrukous","order_in_cat":1},"fr:bp":{"cat":"Prières prescrites","order_in_cat":1},"ha:bp":{"cat":"Sallar Farilla Gajera","order_in_cat":1},"hi:bp":{"cat":"लघु अनिवार्य प्रार्थना","order_in_cat":1},"hu:bp":{"cat":"Rövid kötelező ima","order_in_cat":1},"hy:bp":{"cat":"ՀԱՄԱՌՈՏ ՊԱՐՏԱԴԻՐ ԱՂՈԹՔ","order_in_cat":1},"is:bp":{"cat":"Stutta skyldubænin","order_in_cat":1},"it:bp":{"cat":"Preghiera Obbligatoria Breve","order_in_cat":1},"ja:bp":{"cat":"短い必須の祈り","order_in_cat":1},"kl:bp":{"cat":"Pinngitsoorani Qinnutissaq Naatsoq","order_in_cat":1},"km:bp":{"cat":"Short Obligatory Prayer","order_in_cat":1},"kn:bp":{"c