munupe tau wepi den.","source":"bahaiprayers.net","version":"15c2889b-029f-4777-af33-f3ad21e69c41","book_cats":{"af":{"cat":"Vergifnis","cat_order":29,"order_in_cat":1},"de":{"cat":"Führung und Erkenntnis","cat_order":18,"order_in_cat":10},"hz":{"cat":"Rukwangali: EDILIRO","cat_order":13,"order_in_cat":1},"ko":{"cat":"확고한 믿음","cat_order":38,"order_in_cat":4},"sv":{"cat":"Bistånd","cat_order":9,"order_in_cat":4}},"translations":[{"language":"ko","lang_name":"Korean"},{"language":"hz","lang_name":"Herero"},{"language":"af","lang_name":"Afrikaans"},{"language":"sv","lang_name":"Swedish"},{"language":"zh-Hant","lang_name":"Traditional Chinese"},{"language":"de","lang_name":"German"},{"language":"en","lang_name":"English"}]},{"phelps":"BB00623","text":"## RAUSIM OL TRABEL\n\nGod Yet i ken rausim ol trabel.  I gat arapela samting i ken mekim dispela wok?  Tok olsem: Litimapim nem bilong God.  Em Yet I God. Olgeta manmeri i wokman bilong En na olgeta i bihainim tok bilong En.","source":"bahaiprayers.net","version":"90948408-34e4-41b3-83e0-750ee36f0b2f","book_cats":{"ar":{"cat":"الامتحانات والبلايا","cat_order":7,"order_in_cat":7},"ar-translit":{"cat":"الامتحانات والبلايا","cat_order":7,"order_in_cat":7},"az":{"cat":"Sinaq və çətinliklərdə oxunan dualar","cat_order":34,"order_in_cat":5},"be":{"cat":"Выпрабаванні і цяжкасці","cat_order":5,"order_in_cat":1},"bg":{"cat":"Помощ в изпитания","cat_order":22,"order_in_cat":3},"bn":{"cat":"পরীক্ষা ও  বিপদের সময়ের প্রার্থনা","cat_order":23,"order_in_cat":2},"bs":{"cat":"Pomoć u Nevolji","cat_order":22,"order_in_cat":3},"ca":{"cat":"Proves i Dificultats","cat_order":29,"order_in_cat":12},"ch":{"cat":"OTRO SIHA NA TINAITAI","cat_order":7,"order_in_cat":6},"cnr":{"cat":"Teškoće","cat_order":8,"order_in_cat":2},"co":{"cat":"Assistenza","order_in_cat":1},"cs":{"cat":"Pomoc a podpora","cat_order":7,"order_in_cat":2},"cy":{"cat":"Assistance","order_in_cat":2},"da":{"cat":"Prøvelser Og Vanskeligheder","cat_order":31,"order_in_cat":7},"de