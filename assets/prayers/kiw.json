{"prayers":[{"phelps":"AB00044PRO","text":"## WADIDI U'URAEWA\n* Teaching\nMaman! Ge om gega da uon!  Ge Ayop wande iram!  Iyan ma Ge kwiman ita dun gegawa. Dom pasukat tamo amba aneya gega amena den mu wat nagat mum, ap gapan mu Ge ita anan gega apane venasep piup ma uruga Ge aton gega gan amba nop wait gega wat senamep. Maman Ge mu den pasukat mugawa amba garagat gapan, sunup gapan, at bumak gapan, oma pose gapan, pon gapan, dawara gapan, Ge gindak mum, ap gapan mu Ge amun sitatao gega menan ao waiyamun amba gaup amun gega gapan.  Ipiri Ge gegenat Amun, Ap amba Aro aigap iren, amba Ge gegenat amat, Anuiyanawa  amba yavianawa.","source":"bahaiprayers.net","version":"ecb6a166-fb6a-4755-b1c3-04772a458415","book_cats":{"az":{"cat":"Ruhani inkişaf üçün dualar","cat_order":27,"order_in_cat":16},"bg":{"cat":"Деца и младежи","cat_order":4,"order_in_cat":26},"bs":{"cat":"Duhovno Vijeće","cat_order":6,"order_in_cat":3},"ca":{"cat":"Qualitats Espirituals","cat_order":30,"order_in_cat":10},"da":{"cat":"Åndelige Egenskaber","cat_order":3,"order_in_cat":16},"el":{"cat":"ΠΝΕΥΜΑΤΙΚΗΣ ΑΝΑΠΤΥΞΗΣ","cat_order":34,"order_in_cat":31},"en":{"cat":"Spiritual Growth","cat_order":48,"order_in_cat":21},"es":{"cat":"Cualidades espirituales","cat_order":7,"order_in_cat":9},"fa":{"cat":"راز و نياز- شكر و ستايش","cat_order":15,"order_in_cat":7},"fa-translit":{"cat":"راز و نياز- شكر و ستايش","cat_order":15,"order_in_cat":7},"fr":{"cat":"Qualités spirituelles","cat_order":25,"order_in_cat":16},"ht":{"cat":"Rankont yo","cat_order":48,"order_in_cat":1},"hy":{"cat":"ԱՂՈԹՔՆԵՐ ՀԱՎԱՏԻ ՏԱՐԱԾՄԱՆ ՄԱՍԻՆ","cat_order":1,"order_in_cat":3},"is":{"cat":"Andlegir eiginleikar","cat_order":3,"order_in_cat":18},"lt":{"cat":"Asamblėja","order_in_cat":1},"nl":{"cat":"Geestelijke groei","cat_order":12,"order_in_cat":20},"pl":{"cat":"Rozwój duchowy","cat_order":31,"order_in_cat":17},"pt":{"cat":"Ajuda","order_in_cat":16},"ro":{"cat":"Calităţi Spirituale","cat_order":5,"order_in_cat":18},"tl":{"cat":"Espiritwal Na Mga Katangian","cat_order":5,"order_in_cat":16}},"translations":[{"language":"no","lang_name":"Norwegian"},{"language":"is","lang_name":"Icelandic"},{"language":"ca","lang_name":"Catalan"},{"language":"pt","lang_name":"Portuguese"},{"language":"eu","lang_name":"Basque"},{"language":"ro","lang_name":"Romanian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"el","lang_name":"Greek"},{"language":"nl","lang_name":"Dutch"},{"language":"pl","lang_name":"Polish"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"bs","lang_name":"Bosnian"},{"language":"lt","lang_name":"Lithuanian"},{"language":"tl","lang_name":"Tagalog"},{"language":"es","lang_name":"Spanish"},{"language":"fr","lang_name":"French"},{"language":"hy","lang_name":"Armenian"},{"language":"da","lang_name":"Danish"},{"language":"sr","lang_name":"Serbian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"fa","lang_name":"Persian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"en","lang_name":"English"}]},{"phelps":"AB00065STE","text":"## DAIYO MANIMANI U'URAEWA\n* Travel\nNe mumaget ao yon waingen Ge aeamat gega gapan.  Mamanawa!  Amba at pa nega aeveyan anusumat nega uruga Ge inagap, amba ne inat yonat nega Ge ae amat kwayup gega gwanap.  Amena kwiman gapan dom bain gega kakaewa wasuen nen, amba amat tanege siya pa nega tauwap, den siga ne Ge gogon gega gapan amat tanege imuna Ge gegenat anu sumat kaimaket inagap anu dawagep.  Maman da siga uon go Ge gegenataet di, Ge daiton, Ge om gega da uon, Uruga anuianawa, Uruga amat taianawa.","source":"bahaiprayers.net","version":"d5606adb-16dd-4c30-948e-1d912b953aad","book_cats":{"az":{"cat":"Əhddə möhkəmlik duaları","cat_order":10,"order_in_cat":5},"bg":{"cat":"Непоколебимост в завета","cat_order":18,"order_in_cat":5},"bs":{"cat":"Postojanost u Zavjetu","cat_order":26,"order_in_cat":1},"ca":{"cat":"Fermesa","cat_order":11,"order_in_cat":13},"da":{"cat":"Pagten","cat_order":30,"order_in_cat":5},"el":{"cat":"ΣΤΑΘΕΡΟΤΗΤΑΣ ΣΤΗ ΣΥ