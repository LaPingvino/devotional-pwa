a wareniwa. Ge amun gega wana Yauga Namu irena ge yaibobot paua mega ire yavep.  Irani amena kwiman gapan ge mapa piupa, da Ge om gega mine uon nagaet.  Ge Ayop wande iram, Ge piup kwiman eve use ine bukwa darat wani dawap waran mum ge waup aeamat taianawa ge yavianawa.  Ayop da den sia uon.  Ge gegenataet di Ge dun epara, aro amun, anut ge asik iragi ibariwa.  Wat ganatam O Maman! nao gega nagire gine namup.  Mu den yawagep, den imuberi bigi wara Mu toentane imaetararin nambae gan dotauvep.  Apa amba Ge iraga yave kakayasep, iwa Ge gek ingane matauan dima opata gega magatam taiagi amba Ge dun ganat gega veraut en tomagen.  Ipiri Ge irani piup ge kwiman Ayopewa dawap.","source":"bahaiprayers.net","version":"5c4faaef-b5b8-4af8-aedb-bc7f923e6692","book_cats":{"az":{"cat":"Sabitlik","cat_order":29,"order_in_cat":1},"be":{"cat":"Хвала і ўдзячнасць","cat_order":20,"order_in_cat":1},"ca":{"cat":"Fermesa","cat_order":11,"order_in_cat":5},"de":{"cat":"Standhaftigkeit","cat_order":41,"order_in_cat":2},"el":{"cat":"ΣΤΑΘΕΡΟΤΗΤΑΣ","cat_order":37,"order_in_cat":1},"en":{"cat":"Steadfastness","cat_order":49,"order_in_cat":1},"fr":{"cat":"Protection","cat_order":24,"order_in_cat":11},"fy":{"cat":"Geastlike Groei","cat_order":3,"order_in_cat":3},"ht":{"cat":"Detache ou ak Lavi a","cat_order":5,"order_in_cat":1},"it":{"cat":"Giordo di Dio","cat_order":11,"order_in_cat":1},"nl":{"cat":"Standvastigheid","cat_order":41,"order_in_cat":1},"pl":{"cat":"Wytrwałość","cat_order":46,"order_in_cat":1},"pt":{"cat":"Mulher","cat_order":19,"order_in_cat":6},"sv":{"cat":"Guds dag","cat_order":19,"order_in_cat":1}},"translations":[{"language":"no","lang_name":"Norwegian"},{"language":"ca","lang_name":"Catalan"},{"language":"pt","lang_name":"Portuguese"},{"language":"it","lang_name":"Italian"},{"language":"eu","lang_name":"Basque"},{"language":"sv","lang_name":"Swedish"},{"language":"az","lang_name":"Azerbaijani"},{"language":"ne","lang_name":"Nepali"},{"language":"el","lang_name":"Greek"},{"languag