t":"Vaikai","cat_order":12,"order_in_cat":1},"ml":{"cat":"ഐക്യം","cat_order":8,"order_in_cat":2},"pap":{"cat":"Gatherings","cat_order":3,"order_in_cat":1},"ro":{"cat":"Pentru cei Răposaţi","cat_order":23,"order_in_cat":5},"sq":{"cat":"i përgjithshëm","cat_order":6,"order_in_cat":1},"srn":{"cat":"Algemene Gebeden","order_in_cat":1}},"translations":[{"language":"tet","lang_name":"Tetum"},{"language":"no","lang_name":"Norwegian"},{"language":"ksd","lang_name":"Kuanua"},{"language":"ga","lang_name":"Irish"},{"language":"sq","lang_name":"Albanian"},{"language":"co","lang_name":"Corsican"},{"language":"is","lang_name":"Icelandic"},{"language":"et","lang_name":"Estonian"},{"language":"lg","lang_name":"Ganda"},{"language":"ca","lang_name":"Catalan"},{"language":"sm","lang_name":"Samoan"},{"language":"kgf","lang_name":"Kube"},{"language":"chr","lang_name":"Cherokee"},{"language":"eu","lang_name":"Basque"},{"language":"ro","lang_name":"Romanian"},{"language":"ml","lang_name":"Malayalam"},{"language":"bla","lang_name":"Blackfoot"},{"language":"moh","lang_name":"Mohawk"},{"language":"ttm","lang_name":"Northern Tutchone"},{"language":"lkt","lang_name":"Lakota"},{"language":"haw","lang_name":"Hawaiian"},{"language":"fy","lang_name":"Western Frisian"},{"language":"tk","lang_name":"Turkmen"},{"language":"de","lang_name":"German"},{"language":"pap","lang_name":"Papiamento"},{"language":"hu","lang_name":"Hungarian"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"bs","lang_name":"Bosnian"},{"language":"lt","lang_name":"Lithuanian"},{"language":"gwi","lang_name":"Gwich'in"},{"language":"dgz","lang_name":"Daga"},{"language":"meu","lang_name":"Motu"},{"language":"fr","lang_name":"French"},{"language":"hur","lang_name":"Halkomelem"},{"language":"slh","lang_name":"Sliammon"},{"language":"iba","lang_name":"Iban"},{"language":"gil","lang_name":"Gilbertese"},{"language":"be","lang_name":"Belarusian"},{"language":"sr","lang_name":"Serbian"},{"language":"nv","lang_name":"Navajo"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"ik","lang_name":"Inupiaq"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"one","lang_name":"Oneida"},{"language":"se","lang_name":"Sami"},{"language":"fa","lang_name":"Persian"},{"language":"med","lang_name":"Melpa"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"lut","lang_name":"Lushootseed"},{"language":"en","lang_name":"English"},{"language":"cy","lang_name":"Welsh"},{"language":"shh","lang_name":"Shoshoni"},{"language":"km","lang_name":"Central Khmer"},{"language":"oj","lang_name":"Ojibwe"}]},{"phelps":"BH00154FIR","text":"## EWAT VIRIP TAPEN  U’URAEWA\n* The Fast\n\n* Ewat virip tapen siragam `Alá (Aigap) wam derewa (2) gapan aepi wam apane daiton (20) gapan uon tata.  Yaumak ap gapan ewat go kaum da marek eya dotauvepi gapan nata aepi wam geyarepi pauwa.  Yaumak ma guwanu aro wanapen, ao wasupen wamewa.  Orup en muga (15) gauwarap virip eya tain, waen bagurenawa, orup am nainiwa vek denawa, amba waenapan tanewa den.\n\nNe esuna ewat mega virip taiyangin taba ge kaum den virip taiyangin.  Ap menan bumagana bigi wat, wat aimagam ona da ugupe men eya anup mek Gegenat taet di, anut koewa tantanewa okom taunek, ae amat tanek Ge gaup gega kakaewa ne guwana kwayup tap, amba ap Ge iwa Gegenat genan ae amat Gega tain.","source":"bahaiprayers.net","version":"2e7629c4-b9e1-4f88-8903-76557948a22c","book_cats":{"af":{"cat":"Die Vas","cat_order":12,"order_in_cat":1},"bg":{"cat":"Пости","cat_order":26,"order_in_cat":1},"bi":{"cat":"FASTING","cat_order":5,"order_in_cat":3},"ca":{"cat":"Dejuni","cat_order":4,"order_in_cat":1},"ch":{"cat":"I AYUNAT","cat_order":2,"order_in_cat":1},"el":{"cat":"ΝΗΣΤΕΙΑ","cat_order":25,"order_in_cat":1},"en":{"cat":"The Fast","cat_order":55,"order_in_cat":11},"fi":{"cat":"Paasto","cat_order":27,"order_in_cat":3},"hu":{"cat":"Szökőnapok","cat_order":37,"order_in_cat":2},"is":{"cat":"Fastan","cat_order":10,"order_in_cat":1},"kl":{"cat":"Iisinnginniarneq","cat_order":10,"order_in_cat":3},"ml":{"cat":"ഉപവാസം","cat_order":7,"order_in_cat":1},"nl":{"cat":"Vasten","cat_order":46,"order_in_cat":1},"no":{"cat":"Faste","cat_order":11,"order_in_cat":1},"pl":{"cat":"Post","cat_order":26,"order_in_cat":1},"pt":{"cat":"Ensino","cat_order":10,"order_in_cat":15},"ro":{"cat":"Post","cat_order":25,"order_in_cat":1},"sk":{"cat":"Pôst","cat_order":24,"order_in_cat":1},"sv":{"cat":"Fastan","cat_order":14,"order_in_cat":1}},"translations":[{"language":"bi","lang_name":"Bislama"},{"language":"no","lang_name":"Norwegian"},{"language":"is","lang_name":"Icelandic"},{"language":"ca","lang_name":"Catalan"},{"language":"pt","lang_name":"Portuguese"},{"language":"af","lang_name":"Afrikaans"},{"language":"ro","lang_name":"Romanian"},{"language":"ml","lang_name":"Malayalam"},{"language":"sv","lang_name":"Swedish"},{"language":"az","lang_name":"Azerbaijani"},{"language":"el","lang_name":"Greek"},{"language":"nl","lang_name":"Dutch"},{"language":"pl","lang_name":"Polish"},{"language":"hu","lang_name":"Hungarian"},{"language":"bn","lang_name":"Bengali"},{"language":"tl","lang_name":"Tagalog"},{"language":"sk","lang_name":"Slovak"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ch","lang_name":"Chamorro"},{"language":"en","lang_name":"English"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"}]},{"phelps":"BH09085","text":"## BOP U’URAEWA\n* Burial\n* Bop U’uraewa ma orup bodu muga aonagaet nani yambun uon tan (15) mugenat den wain amba wa munain.  U’ura ma megenat Bahá’í uruga iyam iyam ta wain.  Ma orup daiton megenat wapi amba uruga ao paina yonain.  At bowarewa gambena eya toenta nain.  (Kitáb-i-Aqdas)\n\n\nMaman!  Ma Ge nao gega apanewa osuwa, Ge anusumat tageni amba Ge pauwa gega den, amba gine namu genan toentanen dim dim uruga imuwarat tan Ge gegenat anusumat taiga.  Ge gegenat ipiri, bagusisi nunan anuianawa.  Irewa yao, Ge Da bigip muga imu warat taianawa amba ta bambam nuga wat wagianawa, Ge gese upuru Gega pae pose gapan dotauvep.  Me yaibobot wandep.  Maman da siya uon, Ge gegenat, koewa imuwarat taiyanawa, wamwam nunianawa puiman mine inap ta, amba piup ge kiman eya venaseni Ge bagusisi gega kanama apa wanden.  Maman ra den siga uon Ge gegenat taedi wamwam koewa nuga Imuwarat taianawa, Uruga Nunianawa. \n\n* Ma den wapen pauwa nani yamben daiton (6) gaun Alláh-u-Abhá wata amba den pauwa (19) mugenat nop ma daiton daiton wa vitait.\n\nAlláh-u-Abhá! \n\n Nu uruga ipiri kaut maman inap enuinit. (19)\n\nAlláh-u-Abhá!\n\nNu uruga ipiri omaninu Maman inap poponagianit. (19)\n\nAlláh-u-Abhá!\n\nNu uruga ipiri bumaganu Maman wanianit.(19)\n\nAlláh-u-Abhá !\n\nNu uruga ipiri wat taragat Maman wat taragasinit. (19)\n\nAlláh-u-Abhá!\n\nNu uruga ipiri gaun Maman inap waiyanit. (19)\n\nAlláh-u-Abhá!\n\nNu uruga ipiri Kwataem momon Maman inap taiyanit. (19)","source":"bahaiprayers.net","version":"b171204e-5467-4001-a0b4-4de78e221077","book_cats":{"af":{"cat":"Begrafnis","cat_order":2,"order_in_cat":1},"am":{"cat":"የቀብር ፀሎት  (Funerals)","cat_order":5,"order_in_cat":1},"ar":{"cat":"أدعية الصّيام","cat_order":1,"order_in_cat":6},"ar-translit":{"cat":"أدعية الصّيام","cat_order":1,"order_in_cat":6},"az":{"cat":"Vəfat edənlər üçün namaz və dualar","cat_order":39,"order_in_cat":1},"bg":{"cat":"За покойните","cat_order":9,"order_in_cat":1},"bi":{"cat":"DED  MAN  MO  WOMAN","cat_order":3,"order_in_cat":1},"bn":{"cat":"পরলোকগতদের জন্য প্রার্থনা","cat_order":22,"order_in_cat":1},"ca":{"cat":"Difunts","cat_order":7,"order_in_cat":3},"ch":{"cat":"PARA I MANMATAI","cat_order":8,"order_in_cat":1},"cy":{"cat":"Prayer for the Departed","cat_order":15,"order_in_cat":1},"da":{"cat":"For Den Døde","cat_order":16,"order_in_cat":1},"de":{"cat":"Das Totengebet","cat_order":11,"order_in_cat":1},"el":{"cat":"ΥΠΟΧΡΕΩΤΙΚΗ ΠΡΟΣΕΥΧΗ ΓΙΑ ΤΟΥΣ ΝΕΚΡΟΥΣ","cat_order":42,"order_in_cat":1},"en":{"cat":"Departed","cat_order":13,"order_in_cat":1},"es":{"cat":"Difuntos","