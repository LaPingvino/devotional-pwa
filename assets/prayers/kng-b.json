{"prayers":[{"phelps":"BH11209","text":"# Short Obligatory Prayer\n## To be recited once in twenty-four hours, at noon.\n\nO Nzambi ame, ngina mbangi bonso unganga mu kuzaya ye mu kuzitisa. Yi kuzeyi bungangi mu ngolo zaku ye bumolo bumunu, mu kimvuama kiaku ye kimputu kiamu. Ga nkatu Mfumu nkaka bonso Ngeye, Yu ukunkatula mu kigonsa, Mfumu yani mosi ukiganga. Kongo, South-East: Zombo - Kizombo (Zoombo; Kizoombo) dialect [kon, H.16h] (Angola; Congo) E Nzambi ‘ama, nsidi ‘e kimbangi vo Ngeye wa mpanga mukuzaya ye kukunda. Ewau ntambuluidi ‘e nbovok ‘ama ye ngolo zaku, kimputu kiama ye kimvuama kiaku. Kavena Nzambi ‘e nkaka ko vo ka Ngeye ko, Ona unanga usadisi muna sumbula, Ona unanga muna Yani kibeni.","name":"Short Obligatory Prayer","source":"sop_pdf","version":"7be5defc-408c-41a3-b9b6-cbe933ca035e","v":"7c28g02dagp4z33duapf01vtq","book_cats":{"af:bp":{"cat":"Kort verpligte gebed","order_in_cat":1},"am:bp":{"cat":"አጭሩ (Short)","order_in_cat":1},"ar:bp":{"cat":"الصلاة   الصغيرة","order_in_cat":1},"az:bp":{"cat":"Qısa Namaz","order_in_cat":1},"be:bp":{"cat":"Кароткая абавязковая малітва","order_in_cat":1},"bg:bp":{"cat":"Кратка задължителна молитва","order_in_cat":1},"bi:bp":{"cat":"SOTFALA  OBLIGATORI  PREA","order_in_cat":1},"bs:bp":{"cat":"Kratka Obavezna Molitva","order_in_cat":1},"ca:bp":{"cat":"Oració obligatòria curta","order_in_cat":1},"co:bp":{"cat":"Preghera dì tutti i ghjorni","order_in_cat":1},"cs:bp":{"cat":"Krátká denní modlitba","order_in_cat":1},"cy:bp":{"cat":"Short Obligatory Prayer","order_in_cat":1},"da:bp":{"cat":"Kort Obligatorisk Bøn","order_in_cat":1},"de:bp":{"cat":"Das kurze Pflichtgebet","order_in_cat":1},"dgz:bp":{"cat":"Marek Iyanupe U’uraewa (Short Obligatory Prayer)","order_in_cat":1},"el:bp":{"cat":"ΜΙΚΡΗ ΥΠΟΧΡΕΩΤΙΚΗ ΠΡΟΣΕΥΧΗ","order_in_cat":1},"en:bp":{"cat":"Short Obligatory Prayer","order_in_cat":1},"eo:bp":{"cat":"Devigaj Preĝoj - La Mallonga","order_in_cat":1},"es:bp":{"cat":"Oración obligatoria corta","order_in_cat":1},"eu:bp":{