[{"phelps":"AB01224","text":"## A NIARING AIRA UMANA MINAT\n\nNa vatang ra varvagai a laptikai nae Allah-u-Abha! Ma na vatang gono ra umana pakana tinata ta vinun ma a lavuvat nae. \n\nAllah-u-Abha I \n\nAvet par, ave lotu tadap u mara dovotina Luluai. (a vinun ma aluvat nae) \n\nAllah-u-Abhal \n\nAvet par, ave ruru tadap u Luluai (a vinun ma a lavuvat nae) \n\nAllah-u-Abha: \n\nAvet par, ave tultar avet tuna tam Luluai (a vinun ma a lavuvat nae) \n\nAllah-u-Abha] \n\nAvet par, ave rarange tuna u Luluai (a vinun ma a lavuvat nae) \n\nAllah-u-Abha: \n\n. Avet par, ave pite varpa tam ra Luluai (a vinun ma a lavuvat nae) \n\nAllah-u-Abha: \n\nAve! par, ave tar tavua tuna ma pite pa u Luluai (a vinun ma a lavuvat nae) \n\nAllah-u-Abha! \n\nAvet par, ave kivovon ma kiung varpa upi ra Luluai (a vinun ma a lavuvat nae)","name":"A NIARING AIRA UMANA MINAT","translations":[{"language":"dgz","lang_name":"Daga"},{"language":"ha","lang_name":"Hausa"},{"language":"ko","lang_name":"Korean"},{"language":"ms","lang_name":"Malay"},{"language":"sk","lang_name":"Slovak"},{"language":"te","lang_name":"Telugu"},{"language":"zh-Hant","lang_name":"Traditional Chinese"},{"language":"tvl","lang_name":"Tuvalu"}]},{"phelps":"AB03461MAR","text":"## A VAVALIMA NA TINAULAI\n\nRa vavalima na tinaulai, gora pakana tinata nina a  tutana ma a vavina dir taulai dira vatang varkolono, tara  luai na matai ra tutana ma a vavina nina dir tur mur pa  dir, mur ra nimulaot kai ra Tulungean Pal Tabu, ditumu  ia tara ngatngat na buk, a Kitab-i-Aqdas, aeri.  \n\n\"Datparika, data mur ra mamaingai kai ra Luluai.\"","name":"A VAVALIMA NA TINAULAI","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"bi","lang_name":"Bislama"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"hr","lang_name":"Croatian"},{"language":"dgz","lang_name":"Daga"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"fo","lang_name":"Faroese"},{"language":"fj","lang_name":"Fijian"},{"language":"fr","lang_name":"French"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hz","lang_name":"Herero"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"ja","lang_name":"Japanese"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"ml","lang_name":"Malayalam"},{"language":"meu","lang_name":"Motu"},{"language":"no","lang_name":"Norwegian"},{"language":"kj","lang_name":"Oshikwanyama"},{"language":"pl","lang_name":"Polish"},{"language":"diu","lang_name":"Rugciriku"},{"language":"ru","lang_name":"Russian"},{"language":"tl","lang_name":"Tagalog"}]},{"phelps":"AB07158","text":"## A NIARING UPI RA UMANA TAULAI\n\nA ruru tam ra Luluai, U Kaugu Luluai I Atuna gon, Koum bul kudar ma Koum vavina kudar utar viguve avet takoum malur ma varmari ma ave ki guvai takoum varvadoan ma avarmari iti lia. U Luluai ! Una maravut diat togon koum gunagunan ma Koum minamar ma ki mara umana bona magit na vapuak ma tinabar. U Luluail Vadekdek diat ma maravut diat takoum papalum. Tovo diat upi diata tur vakilang ra iangim tagon ra gunagunan ma balaure diat takaum umana tinabar, nina ilia tuna mapana mutu tagon ra gunagunan matara gunan namur bula. U Luluai! Diati lulul marmari upi koum minamar makoum ngala na varmari ma tar takoum vartulang ba ukaka tikai. A tuna dia taulai mara variru mur koum vartulang. Tago diata vakilang ra mari na kini guvai tuk tara mutuai na bung. A tuna, ura dekdekina a bung bung par, u a ngala tuna ma ongor vatikai","name":"A NIARING UPI RA UMANA TAULAI","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"hy","lang_name":"Armenian"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"bs","lang_name":"Bosnian"},{"language":"ca","lang_name":"Catalan"},{"language":"ch","lang_name":"Chamorro"},{"language":"hr","lang_name":"Croatian"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fo","lang_name":"Faroese"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"el","lang_name":"Greek"},{"language":"ha","lang_name":"Hausa"},{"language":"hi","lang_name":"Hindi"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"it","lang_name":"Italian"},{"language":"naq","lang_name":"Khoekhoegowab"},{"language":"ky","lang_name":"Kirghiz"},{"language":"kgf","lang_name":"Kube"},{"language":"lv","lang_name":"Latvian"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"ms","lang_name":"Malay"},{"language":"ml","lang_name":"Malayalam"},{"language":"mr","lang_name":"Marathi"},{"language":"mh","lang_name":"Marshallese"},{"language":"med","lang_name":"Melpa"},{"language":"mn","lang_name":"Mongolian"},{"language":"ne","lang_name":"Nepali"},{"language":"no","lang_name":"Norwegian"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"sm","lang_name":"Samoan"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"tet","lang_name":"Tetum"},{"language":"tpi","lang_name":"Tok Pisin"},{"language":"zh-Hant","lang_name":"Traditional Chinese"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"uk","lang_name":"Ukrainian"},{"language":"vi","lang_name":"Vietnamese"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"AB09794CHI","text":"## A NIARING UPI RA UMANA BUL\n\nU l.uluai. mataure iau, balaure iau; mal iau dari ra birao na lam ma a matotona tagul U a dekdekina ma aongor vurakit.","name":"A NIARING UPI RA UMANA BUL","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"az","lang_name":"Azerbaijani"},{"language":"ca","lang_name":"Catalan"},{"language":"cs","lang_name":"Czech"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fj","lang_name":"Fijian"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hz","lang_name":"Herero"},{"language":"hu","lang_name":"Hungarian"},{"language":"id","lang_name":"Indonesian"},{"language":"it","lang_name":"Italian"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"lv","lang_name":"Latvian"},{"language":"mg","lang_name":"Malagasy"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"no","lang_name":"Norwegian"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"vi","lang_name":"Vietnamese"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BB00623","text":"## A NIARING UPI RA MARAMARAVUT\n\nI - ia ra Luluai nina na takvue ra umana vartup?  Da vatangia: Pite pa u a Luluai ! Nam ra Luluai !  Diat par kana umana bul kudakudar ma diata  mur kana umana varkurai.","name":"A NIARING UPI RA MARAMARAVUT","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"lan