srn","lang_name":"Sranan Tongo"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"th","lang_name":"Thai"},{"language":"tpi","lang_name":"Tok Pisin"},{"language":"tk","lang_name":"Turkmen"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"cy","lang_name":"Welsh"}]},{"phelps":"BH10505","text":"## A NIARING UPI RA TUNUR GUVAI\n\nKaugu Luluai! Kaugu Luluai! Viguve ra buai kaum umana Kudakudar, ma vakapa diat ta kaum dekdek na vuna. Pi diata mur kaum umana vartulang ma kaum varkurai.Maravut diat, U Luluai, takadia valavalar, ma tabar diat mara dekdek upi diata papalum kaum iat. U Luluail koko una balakane diat, iaka una balaure kadia vinavana ma kaum kapa na minatoto, ma vagaga ra buai diat ma kaum varmari. latuna, U kadia maramaravut ma kadia Luluai.","name":"A NIARING UPI RA TUNUR GUVAI","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"hy","lang_name":"Armenian"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"bn","lang_name":"Bengali"},{"language":"bs","lang_name":"Bosnian"},{"language":"ch","lang_name":"Chamorro"},{"language":"chr","lang_name":"Cherokee"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"cs","lang_name":"Czech"},{"language":"dgz","lang_name":"Daga"},{"language":"dak","lang_name":"Dakota"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fo","lang_name":"Faroese"},{"language":"fj","lang_name":"Fijian"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"el","lang_name":"Greek"},{"language":"gu","lang_name":"Gujarati"},{"langua