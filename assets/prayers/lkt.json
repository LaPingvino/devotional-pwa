is moment, to my powerlessness and to Thy might, to my poverty and to Thy wealth.\n\nThe is none other God but Thee, the Help in Peril, the Self-Subsisting.","name":"Lakota","source":"bahaiprayers.net","version":"a20d5452-a98f-4cfe-839f-936bf2c01494","book_cats":{"af":{"cat":"Kort verpligte gebed","cat_order":18,"order_in_cat":1},"am":{"cat":"አጭሩ (Short)","cat_order":30,"order_in_cat":1},"ar":{"cat":"الصلاة   الصغيرة","cat_order":22,"order_in_cat":1},"ar-translit":{"cat":"الصلاة   الصغيرة","cat_order":22,"order_in_cat":1},"az":{"cat":"Qısa Namaz","cat_order":26,"order_in_cat":1},"be":{"cat":"Кароткая абавязковая малітва","cat_order":13,"order_in_cat":1},"bg":{"cat":"Кратка задължителна молитва","cat_order":13,"order_in_cat":1},"bi":{"cat":"SOTFALA  OBLIGATORI  PREA","cat_order":22,"order_in_cat":1},"bs":{"cat":"Kratka Obavezna Molitva","cat_order":12,"order_in_cat":1},"ca":{"cat":"Oració obligatòria curta","cat_order":24,"order_in_cat":1},"co":{"cat":"Preghera dì tutti i ghjorni","cat_order":4,"order_in_cat":1},"da":{"cat":"Kort Obligatorisk Bøn","cat_order":21,"order_in_cat":1},"de":{"cat":"Das kurze Pflichtgebet","cat_order":7,"order_in_cat":1},"el":{"cat":"ΜΙΚΡΗ ΥΠΟΧΡΕΩΤΙΚΗ ΠΡΟΣΕΥΧΗ","cat_order":24,"order_in_cat":1},"en":{"cat":"Short Obligatory Prayer","cat_order":46,"order_in_cat":1},"eo":{"cat":"Devigaj Preĝoj - La Mallonga","cat_order":1,"order_in_cat":1},"fa":{"cat":"نماز صغیر","cat_order":26,"order_in_cat":1},"fa-translit":{"cat":"نماز صغیر","cat_order":26,"order_in_cat":1},"fi":{"cat":"Lyhyt velvollisuusrukous","cat_order":23,"order_in_cat":1},"fj":{"cat":"NA MASU VAKAROTI LEKALEKA","cat_order":11,"order_in_cat":1},"fr":{"cat":"Prières prescrites","cat_order":22,"order_in_cat":1},"fy":{"cat":"It Koarte Ferplichte","cat_order":9,"order_in_cat":1},"haw":{"cat":"He Pule Koi Pˆkole","cat_order":1,"order_in_cat":1},"ht":{"cat":"Kout Priyè Obligatwa","cat_order":21,"order_in_cat":1},"hz":{"cat":"Rugciriku: Makyatiku","cat_order":10,"order_in_cat":1},"iba":{"cat"