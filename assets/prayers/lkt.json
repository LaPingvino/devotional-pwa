[{"phelps":"AB04427GUI","text":"## O God Guide Me\n\nWakȟáŋ Tȟáŋka, kašká mayúza yo, awáŋmaglaka yo, pȟetížaŋžaŋ wíyakpa na wičháȟpi iléǧa čha makáǧa yo.\nWaníš'akiŋ na wíyoyakihi.","name":"O God, guide me","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"be","lang_name":"Belarusian"},{"language":"bn","lang_name":"Bengali"},{"language":"bi","lang_name":"Bislama"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"ch","lang_name":"Chamorro"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"hai","lang_name":"Haida"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"hz","lang_name":"Herero"},{"language":"hu","lang_name":"Hungarian"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"ik","lang_name":"Inupiaq"},{"language":"it","lang_name":"Italian"},{"language":"kn","lang_name":"Kannada"},{"language":"lo","lang_name":"Lao"},{"language":"lv","lang_name":"Latvian"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"cnr","lang_name":"Montenegrin"},{"language":"ne","lang_name":"Nepali"},{"language":"no","lang_name":"Norwegian"},{"language":"pap","lang_name":"Papiamento"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"pl","lang_name":"Polish"},{"language