n"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"ro","lang_name":"Romanian"},{"language":"slh","lang_name":"Sliammon"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH11209","text":"## Short Obligatory Prayer\nWakȟáŋ Tȟáŋka mitȟáwa kiŋ, slolčhíyiŋ na wakȟáŋčhila kta čha mayákaǧe k'uŋ hé blaátȟaŋiŋ. Miyé wíyowakihi šni na niyé níš waníš'aka, na miyé wamáȟpaničiŋ na niyé níš wínižiča čha hená blatȟáŋiŋ.\nWakȟáŋ Tȟáŋka waŋžíla k'uŋ hé niyé, wókȟokipȟe ičhúŋhaŋ wawóyakiye, oníč'ihi.","name":"Short Obligatory Prayer","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"am","lang_name":"Amharic"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"az","lang_name":"Azerbaijani"},{"language":"be","lang_name":"Belarusian"},{"language":"bi","lang_name":"Bislama"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"cr","lang_name":"Cree"},{"language":"dak","lang_name":"Dakota"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hz","lang_name":"Herero"},{"language":"iba","lang_name":"Iban"},{"language":"is","la