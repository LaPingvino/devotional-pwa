at purpose. May they follow Thy commandments and abide in Thy law. Help them, O God, in their endeavour, and grant them strength to serve Thee.  O God! Leave them not to themselves, but guide their steps by the light of Thy knowledge, and cheer their hearts by Thy love. Verily, Thou art their helper and their Lord.","name":"Lakota","source":"bahaiprayers.net","version":"99782358-f870-4ad9-89a7-86677a30525e","book_cats":{"af":{"cat":"Vergaderings","cat_order":28,"order_in_cat":3},"am":{"cat":"ለመንፈሳዊ ጉባኤ ስብሰባ (Assemblies)","cat_order":3,"order_in_cat":1},"bn":{"cat":"একতার জন্য প্রার্থনা","cat_order":7,"order_in_cat":1},"bs":{"cat":"Jedinstvo","cat_order":10,"order_in_cat":1},"ch":{"cat":"OTRO SIHA NA TINAITAI","cat_order":7,"order_in_cat":2},"co":{"cat":"Unita","cat_order":7,"order_in_cat":1},"cs":{"cat":"Jednota","cat_order":1,"order_in_cat":1},"cy":{"cat":"Unity","cat_order":21,"order_in_cat":3},"da":{"cat":"Enhed","cat_order":12,"order_in_cat":1},"el":{"cat":"ΕΝΟΤΗΤΑΣ","cat_order":17,"order_in_cat":1},"en":{"cat":"Unity","cat_order":58,"order_in_cat":3},"eo":{"cat":"Unueco kaj Paco","cat_order":22,"order_in_cat":1},"et":{"cat":"Ühtsus","cat_order":15,"order_in_cat":2},"fj":{"cat":"NA DUAVATA","cat_order":7,"order_in_cat":1},"fo":{"cat":"Eind","order_in_cat":1},"fr":{"cat":"Unité","cat_order":32,"order_in_cat":2},"fy":{"cat":"Ienheid","cat_order":8,"order_in_cat":1},"gu":{"cat":"એકતા","cat_order":1,"order_in_cat":2},"hi":{"cat":"आरोग्य","cat_order":6,"order_in_cat":5},"hr":{"cat":"Jedinstvo","cat_order":5,"order_in_cat":1},"ht":{"cat":"Linite","cat_order":23,"order_in_cat":2},"hu":{"cat":"Tizenkilenc napi ünnep","cat_order":40,"order_in_cat":2},"hy":{"cat":"ՄԻԱՍՆՈՒԹՅՈՒՆ","cat_order":28,"order_in_cat":1},"hz":{"cat":"Rukwangali: NONDAPERO DIMWE","cat_order":21,"order_in_cat":2},"id":{"cat":"Persatuan","cat_order":32,"order_in_cat":1},"is":{"cat":"Eining","cat_order":7,"order_in_cat":2},"it":{"cat":"Unità","cat_order":35,"order_in_cat":1},"ja":{"cat":"一致和合","cat_orde