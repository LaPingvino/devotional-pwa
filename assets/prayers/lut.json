[{"phelps":"BH00074BLE","text":"Oh kw shet hegus, Poleset toh nehs, kweh eh sheet, hega tah ah yehs, nehs klumes, nehs tah kluk kweh ahs, hega tah t'akt, hega tah tapas, hega tah sapet, hega tah geejah, hega tah cheh, hega tah kwuthys, kw ty ty nigit nons kw shet hegus.  Yeech kw cheh hum. Hega tah nisheeyeok, helh awh nehs. \n\n* Blessed is the spot,and the house,and the place,and the city,and the heart,and the mountain,and the refuge, and the cave,and the valley,and the land,and the sea,and the island,and the meadow where mention of God hath been made and His praise glorified.","name":"Blessed is the Spot","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"sq","lang_name":"Albanian"},{"language":"be","lang_name":"Belarusian"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"bs","lang_name":"Bosnian"},{"language":"ca","lang_name":"Catalan"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"km","lang_name":"Central Khmer"},{"language":"chr","lang_name":"Cherokee"},{"language":"co","lang_name":"Corsican"},{"language":"co","lang_name":"Corsican"},{"language":"en","lang_name":"English"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"et","lang_name":"Estonian"},{"language":"fr","lang_name":"French"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"de","lang_name":"German"},{"language":"gwi","lang_name":"Gwich'in"},{"language":"gwi","lang_name":"Gwich'in"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"hur","lang_name":"Halkomelem"},{"language":"haw","lang_name":"Hawaiian"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hu","lang_name":"Hungarian"},{"language":"hu","lang_name":"Hungaria