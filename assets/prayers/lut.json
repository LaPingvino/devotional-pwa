{"prayers":[{"phelps":"BH00074BLE","text":"Oh kw shet hegus, Poleset toh nehs, kweh eh sheet, hega tah ah yehs, nehs klumes, nehs tah kluk kweh ahs, hega tah t'akt, hega tah tapas, hega tah sapet, hega tah geejah, hega tah cheh, hega tah kwuthys, kw ty ty nigit nons kw shet hegus.  Yeech kw cheh hum. Hega tah nisheeyeok, helh awh nehs. \n\n* Blessed is the spot,and the house,and the place,and the city,and the heart,and the mountain,and the refuge, and the cave,and the valley,and the land,and the sea,and the island,and the meadow where mention of God hath been made and His praise glorified.","name":"Blessed is the Spot","category":"Sliammon","order_in_cat":1,"source":"bahaiprayers.net","version":"3c1f5259-a409-4514-8b4e-1f6202ee2069","v":"3k4yu4gapya28an33ps2tykbt","book":"nai-CA:bpnet","book_cats":{"be:bpapp":{"cat":"Агульныя малітвы","cat_order":2,"order_in_cat":1},"be:bpnet":{"cat":"Блаславёны","order_in_cat":1},"bs:bpnet":{"cat":"Praznik Devetnaest Dana","order_in_cat":1},"ca:bpnet":{"cat":"Qualitats Espirituals","order_in_cat":10},"co:bpnet":{"cat":"Families","order_in_cat":1},"cy:bpnet":{"cat":"Common","order_in_cat":1},"de:bpapp":{"cat":"Allgemeine Gebete","cat_order":2,"order_in_cat":2},"de:bpnet":{"cat":"Allgemein","order_in_cat":1},"dgz:bpnet":{"cat":"Wat Aimagam U’uraewa (Blessed Is the Spot)","order_in_cat":1},"en:bpapp":{"cat":"General Prayers","cat_order":2,"order_in_cat":1},"en:bpnet":{"cat":"Gatherings","order_in_cat":8},"eo:bel-malnova":{"cat":"Bahá'u'lláh","cat_order":2,"order_in_cat":2},"eo:bpapp":{"cat":"Preĝoj revelaciitaj de Bahá’u’lláh","cat_order":2,"order_in_cat":2},"es:bpapp":{"cat":"Oraciones generales","cat_order":2,"order_in_cat":1},"et:bpnet":{"cat":"Katsumused ja raskused","order_in_cat":3},"fa:bpapp":{"cat":"طلب مدد و حمایت","cat_order":3,"order_in_cat":1},"fa:bpnet":{"cat":"طلب مدد و حمایت","order_in_cat":1},"fr:bpapp":{"cat":"Prières ordinaires","cat_order":2,"order_in_cat":1},"fr:bpnet":{"cat":"Familles","order_in_cat":6},"fy:bpnet"