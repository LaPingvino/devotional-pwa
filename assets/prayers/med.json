l","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"th","lang_name":"Thai"},{"language":"tpi","lang_name":"Tok Pisin"},{"language":"tk","lang_name":"Turkmen"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"cy","lang_name":"Welsh"}]},{"phelps":"BH10505","text":"## WAMP TEPA TENTA MUNDI ATENGA\n\nNanga Anatu O!  Nanga Anatu O!  Nemnga kent mant wamp bänga noman bä teken tenta mundui, Nemenga ulg pulg rondolg bä etiken mot dui.  Wamp bä ent Nemnga mi ik bä pepring, Anatu O.  Neminga kongn iting bä tek raipdana, wamb bä ent Neminga kongen bä mara mondok iting.  Anatu O!  Nem wamb bä wak näri,  Nemnga rangalg ent nombulga ping bila rangalg mandana, wete Nem ent wamba bä nga noman etiken kai pinti.  E ama kopa, wamba bä nga Wu e Nem, Nem ent wamb bä teken rapdek ko eten.","name":"WAMP TEPA TENTA MUNDI ATENGA","source":"bahaiprayers.net","version":"3feee065-4c53-49eb-911b-de66256cb796","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"hy","lang_name":"Armenian"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"bn","lang_name":"Bengali"},{"language":"bs","lang_name":"Bosnian"},{"language":"ch","lang_name":"Chamorro"},{"language":"chr","lang_name":"Cherokee"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"cs","lang_name":"Czech"},{"language":"dgz","lang_name":"Daga"},{"language":"dak","lang_name":"Dakota"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fo","lang_name":"Faroese"},{"language":"fj","lang_name":"Fijian"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"el","lang_name":"Greek"},{"language":"gu","lang_name":"Gujarati"},{"langu