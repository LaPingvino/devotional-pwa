me":"Lakota"},{"language":"lt","lang_name":"Lithuanian"},{"language":"lut","lang_name":"Lushootseed"},{"language":"ml","lang_name":"Malayalam"},{"language":"moh","lang_name":"Mohawk"},{"language":"nv","lang_name":"Navajo"},{"language":"oj","lang_name":"Ojibwe"},{"language":"pap","lang_name":"Papiamento"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"ro","lang_name":"Romanian"},{"language":"slh","lang_name":"Sliammon"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH00870","text":"## VEK WAETO U'URAEWA\n* Healing Prayer\n\nGe yauga ne dom gigit negawa, Maman! amba genan anuinawa ap ne inak neniwan.  Mainegap iren ne tauwat anuivin, amba aton Ge genan anuinawa ap ne wat ago negawa.  Ge bagusisi ne inanap taiyanawa ap ne inak neniwan amba wat ago dawap piup ma gapan amba piup namunupe den.  Ge ipiri dim dim irani-nunianawa, Irani-Anuianawa, Irani-Kwayup taianawa.","translations":[{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"hy","lang_name":"Armenian"},{"language":"be","lang_name":"Belarusian"},{"language":"bn","lang_name":"Bengali"},{"language":"bi","lang_name":"Bislama"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hu","lang_name":"Hungarian"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"lt","lang_name":"Lithuanian"},{"language":"ml","lang_name":"Malayalam"},{"language":"no","lang_name":"Norwegian"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"}]},{"phelps":"BH01313NAM","text":"## A Vaaroving i pana Virviraing\n* They name is my healing...\n\nSaaule Nakmai!  Pan a Izaam ka malasing a virviraing ku ni. Pan a nonomaaing pan Nu ka malasing a makara aku. Ga vaasilik pan Nu, xa vazum ni ma a i naxam maalufing pan Nu ka malasing a vilaanago.  A Varamaalufing Sunum ka malasing a virviraing pa ni ka vamada ni wan a roroing aaka re ma roroing mur zaait. Ga xalxal, Gu i tagoning maam na Nu a Baraai a Mazaming ma a Mazampes.","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"bn","lang_name":"Bengali"},{"language":"bi","lang_name":"Bislama"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"ceb","lang_name":"Cebuano"},{"language":"ch","lang_name":"Chamorro"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"cs","lang_name":"Czech"},{"language":"dak","lang_name":"Dakota"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fo","lang_name":"Faroese"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"ha","lang_name":"Hausa"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hz","lang_name":"Herero"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"ik","lang_name":"Inupiaq"},{"language":"it","lang_name":"Italian"},{"language":"ja","lang_name":"Japanese"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"ky","lang_name":"Kirghiz"},{"language":"ko","lang_name":"Korean"},{"language":"lo","lang_name":"Lao"},{"language":"lv","lang_name":"Latvian"},{"language":"lt","lang_name":"Lithuanian"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"mg","lang_name":"Malagasy"},{"language":"ms","lang_name":"Malay"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"mi","lang_name":"Maori"},{"language":"moh","lang_name":"Mohawk"},{"language":"mn","lang_name":"Mongolian"},{"language":"cnr","lang_name":"Montenegrin"},{"language":"nv","lang_name":"Navajo"},{"language":"ne","lang_name":"Nepali"},{"language":"no","lang_name":"Norwegian"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"sr","lang_name":"Serbian"},{"language":"zh-Hans","lang_name":"Simplified Chinese"},{"language":"sk","lang_name":"Slovak"},{"language":"sl","lang_name":"Slovenian"},{"language":"st","lang_name":"Southern Sotho"},{"language":"es","lang_name":"Spanish"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"th","lang_name":"Thai"},{"language":"tk","lang_name":"Turkmen"},{"language":"uk","lang_name":"Ukrainian"},{"language":"ur","lang_name":"Urdu"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH09085","text":"## A Vaaroving i Pana Naande di Waan Fis\n* Prayer for the Dead\n\n* Taaza vilaanaande la maskan a xulutung ka na raraf, kun a vaavis- faaruing ma di na ramaraat.\n\nSaaule Nakmai!  Naan ka re a yaanakilaaing Sunum ma a (naat/natif) a kilaaiing Sunum ma xa vaarungtungaai marase wan Nu ma varaxei wan a mun malagaafnum.  Ma xa tabung tutaawok suaai Nu ma xa tukpazak fataling a mun saan singsaxei Nu be nanga.  Faaratunaan marase, Nu a Baraai a Varamaalufing marase wan a mun faramaalufing sin a zanon.\n\nYaafling sina, ma Gu namtarafing naan kuna xa na puuk pana a mun milunging sina a ubina ma xa na xafun a waraing sin naande.  Fesurunging naan pana a naunaao a raaguling i liaa ma wan a mun faaxaraming sina xu la maskan a magaaf a laman i wan a vakaaf aang Nu.  Falalaxao naan ku la rabaraao xun a tagoning aang naan pan a vuna vaanibuking i mumupis apa liaa.  Ka vit kaarik na roxon taaza a Nakmai na zuaaf Nu.  Nu a Uwaari Gu i puuk pa maam ma Nu a Baraai a i Talasing. \n\nAlláh-u-Abhá!\n\n\nKalxal di vabaraai a Nakmai.\n(Di na welanga fazangaaflu ma vizikfaat.)\n\nAlláh-u-Abhá!\n\nKalxal di varanop pan a Nakmai.\n(Fazangaaflu ma vizikfaat.)\nAlláh-u-Abhá!\n\nKalxal di zaxolising di zin a Nakmai.\n(Fazangaaflu ma vizikfaat.)\n\nAlláh-u-Abhá!\n\nKalxal di vaavisfaaru wan a Nakmai.\n(Fazangaaflu ma vizikfaat.)\n\nAlláh-u-Abhá!\n\nKalxal di vaaulaai zin a Nakmai.\n(Fazangaaflu ma vizikfaat.)\nAlláh-u-Abhá!\n\nKalxal di zi marangingit saxot a Nakmai. (Fazangaaflu ma vizikfaat.)","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"am","lang_name":"Amharic"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"az","lang_name":"Azerbaijani"},{"language":"bn","lang_name":"Bengali"},{"language":"bi","lang_name":"Bislama"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"ch","lang_name":"Chamorro"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hz","lang_name":"Herero"},{"language":"hi","lang_name":"Hindi"},{"language":"hu","lang_name":"Hungarian"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"ik","lang_name":"Inupiaq"},{"language":"it","lang_name":"Italian"},{"language":"kn","lang_name":"Kannada"},{"language":"kiw","lang_name":"Kiwai"},{"language":"mg","lang_name":"Malagasy"},{"language":"ml","lang_name":"Malayalam"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"th","lang_name":"Thai"},{"language":"cy","lang_name":"Welsh"}]},{"phelps":"BH10505","text":"## A Vaaroving i pan a Vatuing\n*...Unite the hearts of they servants...\n\nSaaule Nakmai!  Saaule Nakmai!  Fatuing a mun mamaangon a yaanakilaaing Sunum.  Gu na viaat a divavun a vaamuzesing Sunum.  Ma xa daxo tamon di valos a mun burburaaiing ma ngeiwulut Sunum.  Saaule Nakmai a i naxaaming funfun sin naande ma fadikdik naande xu na varamaraat aang a vaamuzesing si naande.  Saaule Nakmai!  Gu na pen pengin pizin naande ma singsaxei Gu na valos naande wan a vamaravaas aang a rexaasing ma fananaam a mun mamaangon naande wan a nanaming.  Vaaratunaan marase, Nu a Baraai a Pilaning ma Nu a Piraannaande.","name":"Unite the hearts of Thy servants","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"am","lang_name":"Amharic"},{"language":"hy","lang_name":"Armenian"},{"language":"bn","lang_name":"Bengali"},{"language":"bs","lang_name":"Bosnian"},{"language":"ch","lang_name":"Chamorro"},{"language":"chr","lang_name":"Cherokee"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"cs","lang_name":"Czech"},{"language":"dak","lang_name":"Dakota"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fo","lang_name":"Faroese"},{"language":"fj","lang_name":"Fijian"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"el","lang_name":"Greek"},{"language":"gu","lang_name":"Gujarati"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"hz","lang_name":"Herero"},{"language":"hi","lang_name":"Hindi"},{"language":"hu","lang_name":"Hungarian"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"it","lang_name":"Italian"},{"language":"ja","lang_name":"Japanese"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"ko","lang_name":"Korean"},{"language":"lv","lang_name":"Latvian"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"mi","lang_name":"Maori"},{"language":"mh","lang_name":"Marshallese"},{"language":"mic","lang_name":"Mikmaq"},{"language":"mn","lang_name":"Mongolian"},{"language":"nv","lang_name":"Navajo"},{"language":"ne","lang_name":"Nepali"},{"language":"no","lang_name":"Norwegian"},{"language":"pap","lang_name":"Papiamento"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"sm","lang_name":"Samoan"},{"language":"zh-Hans","lang_name":"Simplified Chinese"},{"language":"sk","lang_name":"Slovak"},{"language":"sl","lang_name":"Slovenian"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"te","lang_name":"Telugu"},{"language":"th","lang_name":"Thai"},{"language":"tpi","lang_name":"Tok Pisin"},{"language":"zh-Hant","lang_name":"Traditional Chinese"},{"language":"tk","lang_name":"Turkmen"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"uk","lang_name":"Ukrainian"},{"language":"ur","lang_name":"Urdu"},{"language":"vi","lang_name":"Vietnamese"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH11209","text":"## A Vaaroving i la Waanas\n* Short Obligatory Prayer\n\n*(La raan gu na vaarovaai la mun taan saksaxei la biru la waanas, gu na rutaawok suaai a Bina Vaarala o Israel xa zi vatok a yaas ka si ma gu na mainung pan a vaaroving i la waanas.)\n\nO a vaartulaaiing a ku Nakmai, Nu a wanga na vaaribuking aang ni kuna ga na rexaasing ma vaaroving Nu.  Naambare be ga xalxal adu ni a vupiran ma Nu nanga a Uwaari ma pan a balagofing surugu ma pan a uwaagangnum.  Ka vit kaarik na roxun taaza a Nakmai.  Nu a Vaaratulaaiing la raan a rouzaat ma Nu nanga Gu paazaai wan Nu.","name":"Short Obligatory Prayer","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"am","lang_name":"Amharic"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"az","lang_name":"Azerbaijani"},{"language":"be","lang_name":"Belarusian"},{"language":"bi","lang_name":"Bislama"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"cr","lang_name":"Cree"},{"language":"dak","lang_name":"Dakota"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hz","lang_name":"Herero"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"ik","lang_name":"Inupiaq"},{"language":"it","lang_name":"Italian"},{"language":"ja","lang_name":"Japanese"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"kiw","lang_name":"Kiwai"},{"language":"lkt","lang_name":"Lakota"},{"language":"lv","lang_name":"Latvian"},{"language":"lt","lang_name":"Lithuanian"}