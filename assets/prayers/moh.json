ni ne-eh a-tie-na-wa-séh-je-ra te-tśia-ron ne-ken yon-wen-jía-te ta-non noh-ya-tá-we non-kwa-na-ke-rah-se-ra. Ih-se, wáh-ih ne Se-ya-wis-kó-wa non-kwe-hó-kon, A-kwé-kon Sa-te-rién-ta-re, ó-ni Sat-thok-ha-kó-wa.\n\n \n\nThy name is my healing, O my God, and remembrance of Thee is my remedy. Nearness to Thee is my hope, and love for Thee is my companion. Thy mercy to me is my healing and my succour in both this world and the world to come. Thou, verily, art the All-Bountiful, the All-Knowing, the All-Wise.","name":"Iroquois","source":"bahaiprayers.net","version":"53efbf56-e7e1-49f6-b155-31c06ffc9e02","book_cats":{"ceb":{"cat":"Pag-alim","cat_order":10,"order_in_cat":3},"cy":{"cat":"Healing","cat_order":8,"order_in_cat":1},"en":{"cat":"Bahá’í Reference Library","cat_order":6,"order_in_cat":44},"fj":{"cat":"NA VEIVAKABULAI","cat_order":14,"order_in_cat":1},"ha":{"cat":"Neman Lahiya","cat_order":8,"order_in_cat":1},"hi":{"cat":"आरोग्य","cat_order":6,"order_in_cat":3},"hu":{"cat":"Gyógyulás","cat_order":15,"order_in_cat":1},"hy":{"cat":"ԱՊԱՔԻՆՈՒՄ","cat_order":5,"order_in_cat":1},"hz":{"cat":"Otjiherero: OMBERUKIRO","cat_order":1,"order_in_cat":1},"iba":{"cat":"PENGERAI","cat_order":20,"order_in_cat":2},"ja":{"cat":"治癒ちゆ","cat_order":30,"order_in_cat":5},"ko":{"cat":"원조","cat_order":24,"order_in_cat":1},"ky":{"cat":"ДАБА","cat_order":5,"order_in_cat":1},"lb":{"cat":"Heelung a Stäerkt","cat_order":7,"order_in_cat":1},"lo":{"cat":"ບົດອະທິຖານຂໍການຮັກສາປິ່ນປົວ","cat_order":7,"order_in_cat":1},"mi":{"cat":"MŌ TE WHAKAORA","cat_order":18,"order_in_cat":2},"mn":{"cat":"ӨВЧНӨӨС АНАГААХУЙ","cat_order":5,"order_in_cat":1},"ms":{"cat":"KESEMBUHAN","cat_order":22,"order_in_cat":1},"ny":{"cat":"KUCHIRITSA","cat_order":5,"order_in_cat":1},"sk":{"cat":"Uzdravenie","cat_order":36,"order_in_cat":2},"sr":{"cat":"ISCELJENJE","cat_order":2,"order_in_cat":2},"srn":{"cat":"Genezing","cat_order":3,"order_in_cat":1},"sw":{"cat":"KUPONYA","cat_order":4,"order_in_cat":1},"th":{"cat":"บทอธิษฐานเพื่อ