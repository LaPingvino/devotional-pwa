[{"phelps":"BB00623","text":"## Iroquois\n\nKa-en-keń na-kó-ren ne én-na-ya-ko-wké-nion ne éh-ren a-ye há-wih-te ne wen-do-réh-shon ji-ni-ho-gwé-nion ne Ni-yo! Se-weń-ron Ron-wa-sen-na-yen-ek Ni-yo! Ra-hon-ha ne Ni-yo! A-gwé-gon ron-was-yoh-ten-seh ta-non a-gwé-gon ra-ti-kwe-niéns-thane Ra-ho-wén-na.\n\nIs there any Remover of difficulties save God? Say: Praised be God! He is God! All are His servants, and all abide by His bidding!","name":"Iroquois","source":"bahaiprayers.net","version":"25e142ce-10bd-4524-8b25-63d52c961eb6","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"be","lang_name":"Belarusian"},{"language":"bn","lang_name":"Bengali"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"ch","lang_name":"Chamorro"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"cs","lang_name":"Czech"},{"language":"dgz","lang_name":"Daga"},{"language":"da","lang_name":"Danish"},{"language":"en","lang_name":"English"},{"language":"fo","lang_name":"Faroese"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"gux","lang_name":"Gourmanchéma"},{"language":"el","lang_name":"Greek"},{"language":"gu","lang_name":"Gujarati"},{"language":"ha","lang_name":"Hausa"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hz","lang_name":"Herero"},{