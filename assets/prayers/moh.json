ng_name":"Simplified Chinese"},{"language":"sk","lang_name":"Slovak"},{"language":"sl","lang_name":"Slovenian"},{"language":"st","lang_name":"Southern Sotho"},{"language":"es","lang_name":"Spanish"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"th","lang_name":"Thai"},{"language":"tk","lang_name":"Turkmen"},{"language":"uk","lang_name":"Ukrainian"},{"language":"ur","lang_name":"Urdu"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH07775","text":"yodásgats ji? yojisdóhgwale? kale? ji nú niganuhzode?, kale ji? ganådáyΛ? okale?n awéli, okuni ji? yonudényu, okuni jinú niyudahzehdákwa, okale? ji? yocdΛhlagálΛt, okunín ohluwagúsu?, okalé ji? yuhw Λjadé, okunín ji? ganyadále? okale ji? gahwénode? oakle ji? gahΛdáyΛ? ji? nu ne? lawΛniyó luwatlolí okuni? luwahzΛnowanáta?, okale?\nluwaya?dadelisduh\n\n* Blessed is the spot, and the house, and the place, and the city, and the heart, and the mountain, and the refuge, and the cave, and the valley, and the land, and the sea, and the island, and the meadow where mention of God hath been made, and His praise glorified.","name":"Blessed is the Spot","source":"bahaiprayers.net","version":"e2530991-11da-4dbd-a7af-0fed58337505","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"am","lang_name":"Amharic"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"az","lang_name":"Azerbaijani"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"bi","lang_name":"Bislama"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"gux","lang_name":"Gourmanchéma"},{"language":"el","lang_name":"Greek"},{"language":"hi","lang_name":"Hindi"},{"language":"hu","lang_name":"Hungarian"},{"language":"is","lang_name":"Icelandic"},{"language":"it","lang_name":"Italian"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"ky","lang_name":"Kirghiz"},{"language":"ko","lang_name":"Korean"},{"language":"lv","lang_name":"Latvian"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"mn","lang_name":"Mongolian"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"zh-Hant","lang_name":"Traditional Chinese"},{"language":"tk","lang_name":"Turkmen"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"uk","lang_name":"Ukrainian"},{"language":"vi","lang_name":"Vietnamese"}]},{"phelps":"BH11209","text":"Wa-geh-ni-wha-gwa-risi, Ook Nkyo, Neh Ihse dá-ká-dis-son ne á-gon/yen-dé-rih-hok ta-non dá-gon-non-whc-ra-don-sek. wá-geh-ri-wha-oi-rot, nook-non-wa, ji-niah-teh-geh-suts-teh ta-non Ihse, ji-ni-seh-sots-tens-seh-ro-waneh, ji-ni-wá-ki-don ta-non ji-ni-sah-gwo-nya-ts-nen. Ihya-gonega oya ne niyo néok Ihse, ne-gah-yeh-na-wa-tsérá neh-yo-da-ri-hok ne-ihse sa-ri-wha-gwa-noh.\n\n* I bear witness, O my God, that Thou hast created me to know Thee and to worship Thee. I testify, at this moment, to my powerlessness and to Thy might, to my poverty and to Thy wealth.\n* There is none other God but Thee, the Help in Peril, the Self-Subsisting.","name":"Short Obligatory Prayer","source":"bahaiprayers.net","version":"1110f5c9-adbe-499a-bbc3-7555b6a20177","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"am","lang_name":"Amharic"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"ay","lang_name":"Aymara"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"be","lang_name":"Belarusian"},{"language":"bi","lang_name":"Bislama"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"cr","lang_name":"Cree"},{"language":"dgz","lang_name":"Daga"},{"language":"dak","lang_name":"Dakota"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"fo","lang_name":"Faroese"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"ha","lang_name":"Hausa"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hz","lang_name":"Herero"},{"language":"ho","lang_name":"Hiri Motu"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"ik","lang_name":"Inupiaq"},{"language":"it","lang_name":"Italian"},{"language":"ja","lang_name":"Japanese"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","l