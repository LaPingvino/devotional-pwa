},{"language":"es","lang_name":"Spanish"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"th","lang_name":"Thai"},{"language":"tpi","lang_name":"Tok Pisin"},{"language":"tk","lang_name":"Turkmen"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"uk","lang_name":"Ukrainian"},{"language":"wam","lang_name":"Wampanoag"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH00074BLE","text":"Yo-tás-kat ka-non-ni-yo-kweń-ra-re noń-kwe ji-ka-non-so-te ó-ni ji-ye-ná-ke-re-ó-ni ji-non ni-ka-na-do-wá-nen-ó -ni ne a-wéh-ri ó-ni ne ji-yo-noń-te, o-ni ji-yon-tah-seh-tá-kwa ó-ni ne on-wen-jió-kon, ó-ni ji-te-yo-non-to-kenh-shon, o-ni ne on-wen-jia-ke ó-ni ne ka-nia-ta-ra-ke-kó-wa, ó-ni ne ji-ka-wéh-no-te-ó-ni ne ji-ka-hén-ta-yen a-kwá ji-ók-non ni-hon-wá-na-tons ne Ni-yo ó-ni Ra-oh-ren-sa-ron-je-ra Ka-rih-ho-wa-náh-ton.\n\n* Blessed is the spot, and the house, and the place, and the city, and the heart, and the mountain, and the refuge, and the cave, and the valley, and the land, and the sea, and the island, and the meadow where mention of God hath been made, and His praise glorified.","name":"Blessed is the Spot","source":"bahaiprayers.net","version":"07e0faa4-3a85-4444-8e39-e9b92c75186a","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"eu","lang_name":"Basque"},{"language":"be","lang_name":"Belarusian"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"chr","lang_name":"Cherokee"},{"language":"co","lang_name":"Corsican"},{"language":"dgz","lang_name":"Daga"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"gwi","lang_name":"Gwich'in"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"ik","lang_name":"Inupiaq"},{"language":"ga","lang_name":"Irish"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kiw","lang_name":"Kiwai"},{"language":"ksd","lang_name":"Kuanua"},{"language":"kgf","lang_name":"Kube"},{"language":"lkt","lang_name":"Lakota"},{"language":"lt","lang_name":"Lithuanian"},{"language":"lut","lang_name":"Lushootseed"},{"language":"ml","lang_name":"Malayalam"},{"language":"med","lang_name":"Melpa"},{"language":"meu","lang_name":"Motu"},{"language":"nv","lang_name":"Navajo"},{"language":"ttm","lang_name":"Northern Tutchone"},{"language":"no","lang_name":"Norwegian"},{"language":"oj","lang_name":"Ojibwe"},{"language":"one","lang_name":"Oneida"},{"language":"pap","lang_name":"Papiamento"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"ro","lang_name":"Romanian"},{"language":"se","lang_name":"Sami"},{"language":"sm","lang_name":"Samoan"},{"language":"sr","lang_name":"Serbian"},{"language":"shh","lang_name":"Shoshoni"},{"language":"slh","lang_name":"Sliammon"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"tet","lang_name":"Tetum"},{"language":"tk","lang_name":"Turkmen"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH01313NAM","text":"## Iroquois\n\nSah-sén-na ne se-wa-kie-wen-tá-kwa O a-ge-Ni-yo, ta-non, ji-kon-yeh-ya-ráh-kwa ne a-ke-nonh-kwa-i-ken. Ak-ta ni-séh-ke ne na-ke-rha-rá-je-ra ta-non ne a-kwa-wen skah-ne Te-te-ni-yah-se-há-tíe. Sen-ten-ni-ten-réh-se-ra \n\ni-ih-neh, ne wa-ke-jhen-tha ta-nón ó-ni ne-eh a-tie-na-wa-séh-je-ra te-tśia-ron ne-ken yon-wen-jía-te ta-non noh-ya-tá-we non-kwa-na-ke-rah-se-ra. Ih-se, wáh-ih ne Se-ya-wis-kó-wa non-kwe-hó-kon, A-kwé-kon Sa-te-rién-ta-re, ó-ni Sat-thok-ha-kó-wa.\n\n \n\nThy name is my healing, O my God, and remembrance of Thee is my remedy. Nearness to Thee is my hope, and love for Thee is my companion. Thy mercy to me is my healing and my succour in both this world and the world to come. Thou, verily, art the All-Bountiful, the All-Knowing, the All-Wise.","name":"Iroquois","source":"bahaiprayers.net","version":"53efbf56-e7e1-49f6-b155-31c06ffc9e02","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"bn","lang_name":"Bengali"},{"language":"bi","lang_name":"Bislama"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"ceb","lang_name":"Cebuano"},{"language":"ch","lang_name":"Chamorro"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"cs","lang_name":"Czech"},{"language":"dgz","lang_name":"Daga"},{"language":"dak","lang_name":"Dakota"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fo","lang_name":"Faroese"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"gux","lang_name":"Gourmanchéma"},{"