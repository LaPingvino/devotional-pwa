{"prayers":[{"phelps":"BB00623","text":"## Iroquois\n\nKa-en-keń na-kó-ren ne én-na-ya-ko-wké-nion ne éh-ren a-ye há-wih-te ne wen-do-réh-shon ji-ni-ho-gwé-nion ne Ni-yo! Se-weń-ron Ron-wa-sen-na-yen-ek Ni-yo! Ra-hon-ha ne Ni-yo! A-gwé-gon ron-was-yoh-ten-seh ta-non a-gwé-gon ra-ti-kwe-niéns-thane Ra-ho-wén-na.\n\nIs there any Remover of difficulties save God? Say: Praised be God! He is God! All are His servants, and all abide by His bidding!","name":"Iroquois","source":"bahaiprayers.net","version":"25e142ce-10bd-4524-8b25-63d52c961eb6","book_cats":{"ar":{"cat":"الامتحانات والبلايا","cat_order":7,"order_in_cat":7},"ar-translit":{"cat":"الامتحانات والبلايا","cat_order":7,"order_in_cat":7},"az":{"cat":"Sinaq və çətinliklərdə oxunan dualar","cat_order":34,"order_in_cat":5},"be":{"cat":"Выпрабаванні і цяжкасці","cat_order":5,"order_in_cat":1},"bg":{"cat":"Помощ в изпитания","cat_order":22,"order_in_cat":3},"bn":{"cat":"পরীক্ষা ও  বিপদের সময়ের প্রার্থনা","cat_order":23,"order_in_cat":2},"bs":{"cat":"Pomoć u Nevolji","cat_order":22,"order_in_cat":3},"ca":{"cat":"Proves i Dificultats","cat_order":29,"order_in_cat":12},"ch":{"cat":"OTRO SIHA NA TINAITAI","cat_order":7,"order_in_cat":6},"cnr":{"cat":"Teškoće","cat_order":8,"order_in_cat":2},"co":{"cat":"Assistenza","order_in_cat":1},"cs":{"cat":"Pomoc a podpora","cat_order":7,"order_in_cat":2},"cy":{"cat":"Assistance","order_in_cat":2},"da":{"cat":"Prøvelser Og Vanskeligheder","cat_order":31,"order_in_cat":7},"de":{"cat":"Prüfungen und Schwierigkeiten","cat_order":37,"order_in_cat":9},"el":{"cat":"∆ΟΚΙΜΑΣΙΩΝ ΚΑΙ ∆ΥΣΚΟΛΙΩΝ","cat_order":1,"order_in_cat":6},"en":{"cat":"Tests and Difficulties","cat_order":54,"order_in_cat":11},"eu":{"cat":"Laguntza","cat_order":11,"order_in_cat":1},"fi":{"cat":"Koettelemukset","cat_order":19,"order_in_cat":2},"fj":{"cat":"NA VEIVUKEI KEI NA VEIVAKATOVOLEI","cat_order":21,"order_in_cat":1},"fo":{"cat":"Royndir og Trupulleikar","cat_order":2,"order_in_cat":1},"fr":{"cat":"Réconfort dans les ép