[{"phelps":"BB00623","text":"Aláahdi Diyin Nilíinii ts’ídá daats’í ’éí t’éiyá yá’át’éehgo hasht’e’ ninánihidoo’nilgo haz’á? Dooda, ‘éí doo ‘ákót’ée da.   Aláshdi Diyin Nilíinii t’óó nahdéé’ nihá yik’eh áhósingo dóó yee nihich’i yálti’íí bik’ehgóó ániit’éego ‘éí bee t’áá nihí ‘ádíká ‘anídiilwolgo haz’á. Bee ha’hóníinii dóó bee ‘adsiil nilíinii ts’ídá ‘éí t’éiya nihá hólóogo ‘ayósin Aláahdi Diyin Nilíinii. ‘Ayóó ‘ádayíníi’níigo bich’i’ ntsídeikeesígíí ‘éí Bá nideilnishii ‘ádaniit’é, áádóó ‘índa ts’ídá lá kót’éego ‘áda’joolíil dooleel ni niho’níigo yee nihich’i’ ntsékeesígíí t’aa nihil béédahózinígi ‘altso bik’ehgóó ádaniit’é, t’áá ‘altso bida’ííníilzin.\n\n* Is there any Remover of difficulties save God? Say: Praised be God! He is God! All are His servants, and all abide by His bidding!.","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"be","lang_name":"Belarusian"},{"language":"bn","lang_name":"Bengali"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"ch","lang_name":"Chamorro"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"cs","lang_name":"Czech"},{"language":"da","lang_name":"Danish"},{"language":"en","lang_name":"English"},{"language":"fo","lang_name":"Faroese"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hz","lang_name":"Herero"},{"language":"hi","lang_name":"Hindi"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"ik","lang_name":"Inupiaq"},{"language":"ga","lang_name":"Irish"},{"language":"it","lang_name":"Italian"},{"language":"ja","lang_name":"Japanese"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"kiw","lang_name":"Kiwai"},{"language":"ko","lang_name":"Korean"},{"language":"lkt","lang_name":"Lakota"},{"language":"lo","lang_name":"Lao"},{"language":"lv","lang_name":"Latvian"},{"language":"mg","lang_name":"Malagasy"},{"language":"ms","lang_name":"Malay"},{"language":"ml","lang_name":"Malayalam"},{"language":"mi","lang_name":"Maori"},{"language":"mh","lang_name":"Marshallese"},{"language":"moh","lang_name":"Mohawk"},{"language":"mn","lang_name":"Mongolian"},{"language":"cnr","lang_name":"Montenegrin"},{"language":"meu","lang_name":"Motu"},{"language":"ne","lang_name":"Nepali"},{"language":"no","lang_name":"Norwegian"},{"language":"pap","lang_name":"Papiamento"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"sm","lang_name":"Samoan"},{"language":"zh-Hans","lang_name":"Simplified Chinese"},{"language":"sk","lang_name":"Slovak"},{"language":"sl","lang_name":"Slovenian"},{"language":"es","lang_name":"Spanish"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"th","lang_name":"Thai"},{"language":"tpi","lang_name":"Tok Pisin"},{"language":"tk","lang_name":"Turkmen"},{"language":"uk","lang_name":"Ukrainian"},{"language":"wam","lang_name":"Wampanoag"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH00074BLE","text":"Bik’ihojidlíigo haz’á lahgo, ‘índa dahooghangóó dóó dabinaagóó dóó kin hadaas áágóó. dóó hajéí dabiyi’góó, dóó nléí dzil dani’áágóó, dóó nléí yisdádahwiit’ééhgóó, dóó tsé’áán góne’ dóó tééh góyáá, dóó kéyah dah naazkaad bikáá’góó, dóó tálkáá’góó, dóó nléí kéyah tálkáá’ dah naaznilgóó, dóó dahootsogóó, dóó ha’át’éegi da ‘Aláahdi Diyin Nilíinii bee ‘ahil dahani’ góó dóó ‘Aláahdi Diyin Nilíinii dadílzingóó.\n\n* Blessed is the spot, and the house, and the place, and the city, and the heart, and the mountain, and the refuge, and the cave, and the valley, and the land, and the sea, and the island, and the meadow where mention of God hath been made, and His praise glorified.","name":"Blessed is the Spot","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"be","lang_name":"Belarusian"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"chr","lang_name":"Cherokee"},{"language":"co","lang_name":"Corsican"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"gwi","lang_name":"Gwich'in"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hu","lang_name":"Hungarian"},{"language":"is","lang_name":"Icelandic"},{"language":"ga","lang_name":"Irish"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kiw","lang_name":"Kiwai"},{"language":"lkt","lang_name":"Lakota"},{"language":"lt","lang_name":"Lithuanian"},{"language":"lut","lang_name":"Lushootseed"},{"language":"ml","lang_name":"Malayalam"},{"language":"moh","lang_name":"Mohawk"},{"language":"meu","lang_name":"Motu"},{"language":"oj","lang_name":"Ojibwe"},{"language":"pap","lang_name":"Papiamento"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"ro","lang_name":"Romanian"},{"language":"slh","lang_name":"Sliammon"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH01313NAM","text":"Yízhí bee Ni’dóójíinii ‘éí náshííldzii’, shi Diyin Nílíinii, áádóó bee nééhanihii ‘éí bee náádiisdzá.\nNíighahgii anísht’é dooleel ‘éí laanaa nisin ‘áádóó shee ayóó’ó’ó’ni Nil hólóó ‘éí bee náás yiisháál. Bee shaajíníba’ígíí ‘éí    \nnashííldzíí’ ‘áádóó ‘éí náásdóó shiká ‘anánílwo’ díí kwe’é t’áá ‘álah Nahaasdzáán bikáa’gii dóó náasdi nááda’iináá dooleel di.\nNi, t’áá ‘aní, t’áá ‘altsoní Baanidlee’ t’áá ‘altsóní  Nil Bééhózin, t’áá ‘altsoní bee Honíyá.\n\n* Thy name is my healing, O my God, and remembrance of Thee is my remedy. Nearness to Thee is my hope, and love for Thee is my companion. Thy mercy to me is my healing and my succour in both this world and the world to come. Thou, verily, art the All-Bountiful, the All-Knowing, the All-Wise.","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"bn","lang_name":"Bengali"},{"language":"bi","lang_name":"Bislama"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"ceb","lang_name":"Cebuano"},{"language":"ch","lang_name":"Chamorro"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"cs","lang_name":"Czech"},{"language":"dak","lang_name":"Dakota"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fo","lang_name":"Faroese"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"ha","lang_name":"Hausa"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hz","lang_name":"Herero"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"ik","lang_name":"Inupiaq"},{"language":"it","lang_name":"Italian"},{"language":"ja","lang_name":"Japanese"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"ky","lang_name":"Kirghiz"},{"language":"ko","lang_name":"Korean"},{"language":"lo","lang_name":"Lao"},{"language":"lv","lang_name":"Latvian"},{"language":"lt","lang_name":"Lithuanian"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"mg","lang_name":"Malagasy"},{"language":"ms","lang_name":"Malay"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"mi","lang_name":"Maori"},{"language":"moh","lang_name":"Mohawk"},{"language":"mn","lang_name":"Mongolian"},{"language":"cnr","lang_name":"Montenegrin"},{"language":"meu","lang_name":"Motu"},{"language":"ne","lang_name":"Nepali"},{"language":"no","lang_name":"Norwegian"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"sr","lang_name":"Serbian"},{"language":"zh-Hans","lang_name":"Simplified Chinese"},{"language":"sk","lang_name":"Slovak"},{"language":"sl","lang_name":"Slovenian"},{"language":"st","lang_name":"Southern Sotho"},{"language":"es","lang_name":"Spanish"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"th","lang_name":"Thai"},{"language":"tk","lang_name":"Turkmen"},{"language":"uk","lang_name":"Ukrainian"},{"language":"ur","lang_name":"Urdu"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH10505","text":"Shidiyin nilíinii!  Shidiyin nilíinii!\nNá Nidaala’í danilíinii bejéí yee lá’í nilíigo ánílééh áádóó ‘Aláahdi Biniiyé ‘Anít’íinni bil’ííshja ‘anílééh ‘dooleel. Bee  Nahwííni’áanii bik’ehgo náádeiikáah dooleel áádóó Nibee haz’áanii bik’ehgo ‘ádaat’éedo. Biká  anánílwo’, Diyin nílíinii, binidaanish ‘ádayósinígíí ‘aadoo bee ‘adziilii baa diní’aahgo ‘éí yee Ná nidaal’a’ do.\nDiyin nílinii! Doo t’áá sáhí Bidíílnih da, ‘ééhózinii bee ‘adini’díínígíí bee biyíílaal do,  ‘áádóó Ni ‘ayóó’ó’ó ni’ bijéí bee bil dahózhóo doo.\nT’áá “aaníí, Ni bíká ‘anánílwo’í í Nílí áádóó Binanit’a’í Nílí.\n\n* O my God! O my God! Unite the hearts of Thy servants, and reveal to them Thy great purpose. May they follow Thy commandments and abide in Thy law. Help them, O God, in their endeavour, and grant them strength to serve Thee.  O God! Leave them not to themselves, but guide their steps by the light of Thy knowledge, and cheer their hearts by Thy love. Verily, Thou art their helper and their Lord.","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"am","lang_name":"Amharic"},{"language":"hy","lang_name":"Armenian"},{"language":"bn","lang_name":"Bengali"},{"language":"bs","lang_name":"Bosnian"},{"language":"ch","lang_name":"Chamorro"},{"language":"chr","lang_name":"Cherokee"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"cs","lang_name":"Czech"},{"language":"dak","lang_name":"Dakota"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fo","lang_name":"Faroese"},{"language":"fj","lang_name":"Fijian"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"el","lang_name":"Greek"},{"language":"gu","lang_name":"Gujarati"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"hz","lang_name":"Herero"},{"language":"hi","lang_name":"Hindi"},{"language":"hu","lang_name":"Hungarian"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"it","lang_name":"Italian"},{"language":"ja","lang_name":"Japanese"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"ko","lang_name":"Korean"},{"language":"lv","lang_name":"Latvian"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"mi","lang_name":"Maori"},{"language":"mh","lang_name":"Marshallese"},{"language":"mic","lang_name":"Mikmaq"},{"language":"mn","lang_name":"Mongolian"},{"language":"meu","lang_name":"Motu"},{"language":"ne","lang_name":"Nepali"},{"language":"no","lang_name":"Norwegian"},{"language":"pap","lang_name":"Papiamento"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"sm","lang_name":"Samoan"},{"language":"zh-Hans","lang_name":"Simplified Chinese"},{"language":"sk","lang_name":"Slovak"},{"language":"sl","lang_name":"Slovenian"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"te","lang_name":"Telugu"},{"language":"th","lang_name":"Thai"},{"language":"tpi","lang_name":"Tok Pisin"},{"language":"zh-Hant","lang_name":"Traditional Chinese"},{"language":"tk","lang_name":"Turkmen"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"uk","lang_name":"Ukrainian"},{"language":"ur","lang_name":"Urdu"},{"language":"vi","lang_name":"Vietnamese"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH11209","text":"Shil beehozin, Diyin Shitaa’ Nínílíni, éí nééhodeessiilgo biniighé  iiná shaa dííní’ á áádóó Niji’ sodiizin do. T’áá k’ad bee haszíí’ shich’i’ nahwii’ná áádóó Ni t’éiyá Nidziil, té’é’í shidaah ndahkai áádóó Ni t’áá altsoní Niholó.\nT’áá Ni t’éiyá Aláadi Diyin nilí, Nihich’i’ Nahwiilná’ígíí\nT’áá línínsin, Hool’áágóó Hooniló.\n\n* I bear witness, O my God, that Thou hast created me to know Thee and to worship Thee. I testify, at this moment, to my powerlessness and to Thy might, to my poverty and to Thy wealth.\nThere is none other God but Thee, the Help in Peril, the Self-Subsisting.","name":"Short Obligatory Prayer","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"am","lang_name":"Amharic"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"az","lang_name":"Azerbaijani"},{"language":"be","lang_name":"Belarusian"},{"language":"bi","lang_name":"Bislama"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"cr","lang_name":"Cree"},{"language":"dak","lang_name":"Dakota"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hz","lang_name":"Herero"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"ik","lang_name":"Inupiaq"},{"language":"it","lang_name":"Italian"},{"language":"ja","lang_name":"Japanese"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"kiw","lang_name":"Kiwai"},{"language":"ko","lang_name":"Korean"},{"language":"lkt","lang_name":"Lakota"},{"language":"lv","lang_name":"Latvian"},{"language":"lt","lang_name":"Lithuanian"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"mg","lang_name":"Malagasy"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"mi","lang_name":"Maori"},{"language":"mh","lang_name":"Marshallese"},{"language":"moh","lang_name":"Mohawk"},{"language":"mn","lang_name":"Mongolian"},{"language":"meu","lang_name":"Motu"},{"language":"no","lang_name":"Norwegian"},{"language":"oj","lang_name":"Ojibwe"},{"language":"pap","lang_name":"Papiamento"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"pot","lang_name":"Potawatomi"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"shs","lang_name":"Shuswap (Secwepemctsín)"},{"language":"sk","lang_name":"Slovak"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"th","lang_name":"Thai"},{"language":"tk","lang_name":"Turkmen"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"ur","lang_name":"Urdu"},{"language":"fy","lang_name":"Western Frisian"}]}]
