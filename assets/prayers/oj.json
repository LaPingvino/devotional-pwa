[{"phelps":"AB00553","text":"O Gitchi - Manitou! Kegagwetchemin chiminut, ni - manitoum chi - min - ain - dung. Beniton, nedae. Wasseiasiwin - meeng - ni - gashkiewisiwin. Ni - we - pakitinan kakina - danokeen - pindig - Kinindg. Keen - chiweechi - we - un, gaie ni - iningimowin. Kaween, minawa - Kashkendamowessi, gaie, Kaween - inaninawendaman. Ga - aiaa, chi - menaindaman, gaie, gaminawanigos. O Gitchi - Manitou! Kaween, gamoshkinase - chi - migoshkadjidewian, gaie, kaween - niwe - pakitinase - ewai - Kashkendamowin chi - megoshkadjian. Kaween ga - nindabisse eway - kaygo - kamanatuk pematisewin. \u2028O Gitchi - Manitou! Keen - nawatch - ne nikanis, nawatch eway - neen. Ni - meenin ne - pematisewin Gitchi - Manitou.\n\n\n\n\u2028\u2028O God! Refresh and gladden my spirit. Purify my heart. Illumine my powers. I lay all my affairs in Thy hand. Thou art my Guide and my Refuge. I will no longer be sorrowful and grieved; I will be a happy and joyful being. O God! I will no longer be full of anxiety, nor will I let trouble harass me. I will not dwell on the unpleasant things of life.\u2028O God! Thou are more friend to me than I am to myself. I dedicate myself to Thee, O Lord.","translations":[{"language":"am","lang_name":"Amharic"},{"language":"hy","lang_name":"Armenian"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"az","lang_name":"Azerbaijani"},{"language":"bg","lang_name":"Bulgarian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"ca","lang_name":"Catalan"},{"language":"da","lang_name":"Danish"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"en","lang_name":"English"},{"language":"fi","lang_name":"Finnish"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"el","lang_name":"Greek"},{"language":"haw","lang_name":"Hawaiian"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hi","lang_name":"Hindi"},{"language":"hi","lang_name":"Hindi"},{"language":"hu","lang_name":"Hungarian"},{"language":"hu","lang_name":"Hungarian"},{"language":"is","lang_name":"Icelandic"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"id","lang_name":"Indonesian"},{"language":"it","lang_name":"Italian"},{"language":"it","lang_name":"Italian"},{"language":"ja","lang_name":"Japanese"},{"language":"ja","lang_name":"Japanese"},{"language":"ky","lang_name":"Kirghiz"},{"language":"ky","lang_name":"Kirghiz"},{"language":"ko","lang_name":"Korean"},{"language":"ko","lang_name":"Korean"},{"language":"ms","lang_name":"Malay"},{"language":"ms","lang_name":"Malay"},{"language":"mt","lang_name":"Maltese"},{"language":"mt","lang_name":"Maltese"},{"language":"mn","lang_name":"Mongolian"},{"language":"mn","lang_name":"Mongolian"},{"language":"ne","lang_name":"Nepali"},{"language":"ne","lang_name":"Nepali"},{"language":"pl","lang_name":"Polish"},{"language":"pl","lang_name":"Polish"},{"language":"ro","lang_name":"Romanian"},{"language":"ro","lang_name":"Romanian"},{"language":"zh-Hans","lang_name":"Simplified Chinese"},{"language":"zh-Hans","lang_name":"Simplified Chinese"},{"language":"sk","lang_name":"Slovak"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"es","lang_name":"Spanish"},{"language":"sv","lang_name":"Swedish"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"ta","lang_name":"Tamil"},{"language":"zh-Hant","lang_name":"Traditional Chinese"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"uk","lang_name":"Ukrainian"},{"language":"uk","lang_name":"Ukrainian"}]},{"phelps":"BH00074BLE","text":"Sigakundjigauso peendji okitahgisiwinug dibishko wigiwam, gahyay o-ahbinass, odaynah, odayimah, owahjiw, ininizhimowin, wimbakbikamagud, tahwandinah, akki, gitchegahmi, miniss, gahyay, mashkossigan auneendi gigitowin O Gitche Manito Kosaynaun Missigaygo Gaugezhetod gabyay ahwaineen gezhegoong aindaut, ahwainsen ondji ozhitchigauday ondji.\n\n* Blessed is the spot, and the house, and the place, and the city, and the heart, and the mountain, and the refuge, and the cave, and the valley, and the land, and the sea, and the island, and the meadow where mention of God hath been made, and His praise glorified.","name":"Blessed is the Spot","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"sq","lang_name":"Albanian"},{"language":"be","lang_name":"Belarusian"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"bs","lang_name":"Bosnian"},{"language":"ca","lang_name":"Catalan"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"km","lang_name":"Central Khmer"},{"language":"chr","lang_name":"Cherokee"},{"language":"co","lang_name":"Corsican"},{"language":"co","lang_name":"Corsican"},{"language":"en","lang_name":"English"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"et","lang_name":"Estonian"},{"language":"fr","lang_name":"French"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"de","lang_name":"German"},{"language":"gwi","lang_name":"Gwich'in"},{"language":"gwi","lang_name":"Gwich'in"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"hur","lang_name":"Halkomelem"},{"language":"haw","lang_name":"Hawaii