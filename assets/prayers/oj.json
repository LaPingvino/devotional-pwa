ng_name":"Norwegian"},{"language":"pap","lang_name":"Papiamento"},{"language":"pap","lang_name":"Papiamento"},{"language":"fa","lang_name":"Persian"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"pl","lang_name":"Polish"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"pt","lang_name":"Portuguese"},{"language":"pot","lang_name":"Potawatomi"},{"language":"ro","lang_name":"Romanian"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"ru","lang_name":"Russian"},{"language":"shs","lang_name":"Shuswap (Secwepemctsín)"},{"language":"sk","lang_name":"Slovak"},{"language":"sk","lang_name":"Slovak"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"sv","lang_name":"Swedish"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"ta","lang_name":"Tamil"},{"language":"th","lang_name":"Thai"},{"language":"th","lang_name":"Thai"},{"language":"tk","lang_name":"Turkmen"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"ur","lang_name":"Urdu"},{"language":"ur","lang_name":"Urdu"},{"language":"fy","lang_name":"Western Frisian"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"TMP00334","text":"O Manitou Ogwissiman!\u2028Neen - nitam - gegitowin - oway: Nin - dan Benidewin, Kijewadisiwin, gaie, Wasseiasiwin kide, eway - Keen, che - atake, Kitchi - Ogimawin, Gete, Gashkiewisiwin gaie kagige.\u2028\u2028\n\nO Son of Spirit! \u2028My first counsel is this: Possess a pure, kindly and radiant heart, that thine may be a sovereignty ancient, imperishable and everlasting."}]
