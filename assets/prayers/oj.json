e","lang_name":"German"},{"language":"lut","lang_name":"Lushootseed"},{"language":"bs","lang_name":"Bosnian"},{"language":"is","lang_name":"Icelandic"},{"language":"es","lang_name":"Spanish"},{"language":"med","lang_name":"Melpa"},{"language":"bla","lang_name":"Blackfoot"},{"language":"hur","lang_name":"Halkomelem"},{"language":"meu","lang_name":"Motu"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"sq","lang_name":"Albanian"},{"language":"tet","lang_name":"Tetum"},{"language":"cy","lang_name":"Welsh"},{"language":"ttm","lang_name":"Northern Tutchone"},{"language":"gil","lang_name":"Gilbertese"},{"language":"lt","lang_name":"Lithuanian"},{"language":"slh","lang_name":"Sliammon"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"fa","lang_name":"Persian"},{"language":"ksd","lang_name":"Kuanua"},{"language":"lkt","lang_name":"Lakota"},{"language":"en","lang_name":"English"},{"language":"chr","lang_name":"Cherokee"},{"language":"ny","lang_name":"Chichewa"},{"language":"ml","lang_name":"Malayalam"},{"language":"tk","lang_name":"Turkmen"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"gwi","lang_name":"Gwich'in"},{"language":"nl","lang_name":"Dutch"},{"language":"shh","lang_name":"Shoshoni"},{"language":"ik","lang_name":"Inupiaq"},{"language":"ms","lang_name":"Malay"},{"language":"ro","lang_name":"Romanian"},{"language":"lg","lang_name":"Ganda"},{"language":"sm","lang_name":"Samoan"},{"language":"sv","lang_name":"Swedish"},{"language":"kiw","lang_name":"Kiwai"},{"language":"dgz","lang_name":"Daga"},{"language":"pt","lang_name":"Portuguese"},{"language":"it","lang_name":"Italian"},{"language":"kgf","lang_name":"Kube"}]},{"phelps":"BH00386A01","text":"O Manitou Ogwissiman!\u2028Neen - nitam - gegitowin - oway: Nin - dan Benidewin, Kijewadisiwin, gaie, Wasseiasiwin kide, eway - Keen, che - atake, Kitchi - Ogimawin, Gete, Gashkiewisiwin gaie kagige.\u2028\u2028\n\nO Son of Spirit! \u2028My first counsel is this: Possess a pure, kindly and radiant heart, that thine may be a sovereignty ancient, imperishable and everlasting.","source":"bahaiprayers.net","version":"d19614bc-bc77-49a8-8ae8-89ef2f211aed","notes":"Theory: Ojibwe/Chippewa text of the first Arabic Hidden Word by BH -- \"O Manitou Ogwissiman!\" = \"O Son of Spirit!\"; \"Neen - nitam - gegitowin - oway: Nin - dan Benidewin, Kijewadisiwin...\" = \"My first counsel is this: Possess a pure, kindly and radiant heart, that thine may be a sovereignty ancient, imperishable and everlasting.\" English translation is appended in the record. Duplicate record exists (same source_id with/without ## Chippewa header). Needs correct Hidden Words Phelps code assignment.","book_cats":{"en":{"cat":"Other prayers by Bahá’u’lláh (research)","cat_order":62,"order_in_cat":117}},"translations":[{"language":"fr","lang_name":"French"}]},{"phelps":"BH11209","text":"Gee Kayne dah mah zon, Ke shay Manito, che ke kayne ne me nan, Shegwah che mah wim we to nan, Che mean e ge e ze yan. Che ke kayne ne me nan ke kaye da ma zon ke zong e ze win she quah neen aye pee chee nay. sou e ze yan, shegwa ka a pe chee we note e ze yun. She gwah neen apee chee ke tee mak e ze anne. Keen aye ta go ka Manito win, ka we che tas so win, Apee saig e ze an, kah ke kay kah ah ya yin.\n\n* I bear witness, O my God, that Thou hast created me to know Thee and to worship Thee. I testify, at this moment, to my powerlessness and to Thy might, to my poverty and to Thy wealth.\nThere is none other God but Thee, the Help in Peril, the Self-Subsisting.","name":"Short Obligatory Prayer","source":"bahaiprayers.net","version":"58a866f9-f971-4322-8161-25a628eab906","book_cats":{"af":{"cat":"Kort verpligte gebed","cat_order":18,"order_in_cat":1},"am":{"cat":"አጭሩ (Short)","cat_order":30,"order_in_cat":1},"ar":{"cat":"الصلاة   الصغيرة","cat_order":22,"order_in_cat":1},"ar-translit":{"cat":"الصلاة   الصغيرة","cat_order":22,"order_in_cat":1},"az":{"cat":"Qısa Namaz","cat_order":26,"order_in_cat":1},"be":{