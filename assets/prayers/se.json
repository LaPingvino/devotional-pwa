nan Tongo"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"tpi","lang_name":"Tok Pisin"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"vi","lang_name":"Vietnamese"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH00074BLE","text":"## Čoahkkaneapmi\n\nSivdniduvvon lea báiki ja dállu ja guovlu ja gávpot ja váibmu ja várri ja suodji ja biedju ja ávži ja eana ja mearra ja suolu ja gieddi, gos Ipmila namma lea muitaluvvon ja Su gudni bajiduvvon.","name":"Čoahkkaneapmi","source":"bahaiprayers.net","version":"1832354f-f95e-48bb-8c3b-81f2afdf25b8","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"eu","lang_name":"Basque"},{"language":"be","lang_name":"Belarusian"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"chr","lang_name":"Cherokee"},{"language":"co","lang_name":"Corsican"},{"language":"dgz","lang_name":"Daga"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"gwi","lang_name":"Gwich'in"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"ik","lang_name":"Inupiaq"},{"language":"ga","lang_name":"Irish"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kiw","lang_name":"Kiwai"},{"language":"ksd","lang_name":"Kuanua"},{"language":"kgf","lang_name":"Kube"},{"language":"lkt","lang_name":"Lakota"},{"language":"lt","lang_name":"Lithuanian"},{"language":"lut","lang_name":"Lushootseed"},{"language":"ml","lang_name":"Malayalam"},{"language":"med","lang_name":"Melpa"},{"language":"moh","lang_name":"Mohawk"},{"language":"meu","lang_name":"Motu"},{"language":"nv","lang_name":"Navajo"},{"language":"ttm","lang_name":"Northern Tutchone"},{"language":"no","lang_name":"Norwegian"},{"language":"oj","lang_name":"Ojibwe"},{"language":"one","lang_name":"Oneida"},{"language":"pap","lang_name":"Papiamento"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"ro","lang_name":"Romanian"},{"language":"sm","lang_name":"Samoan"},{"language":"sr","lang_name":"Serbian"},{"language":"shh","lang_name":"Shoshoni"},{"language":"slh","lang_name":"Sliammon"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"tet","lang_name":"Tetum"},{"language":"tk","lang_name":"Turkmen"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH03562","text":"## Lagašvuohta Ipmilii\n\nO Ipmil! Láide mu, várjal mu, cahkket mu čuovgga ja daga mu šerres nástin. Don guhte leat Fámolaš ja Gievra.","name":"Lagašvuohta Ipmilii","source":"bahaiprayers.net","version":"78c60241-ea1f-4718-9353-f4888502c41c","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"fi","lang_name":"Finnish"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"gu","lang_name":"Gujarati"},{"language":"hu","lang_name":"Hungarian"},{"language":"is","lang_name":"Icelandic"},{"language":"it","lang_name":"Italian"},{"language":"ja","lang_name":"Japanese"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"lv","lang_name":"Latvian"},{"language":"mt","lang_name":"Maltese"},{"language":"mn","lang_name":"Mongolian"},{"language":"no","lang_name":"Norwegian"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"sr","lang_name":"Serbian"},{"language":"tl","lang_name":"Tagalog"},{"language":"tk","lang_name":"Turkmen"},{"language":"tvl","lang_name":"Tuvalu"}]},{"phelps":"BH04421HEA","text":"## Lagašvuohta Ipmilii\n\nAtte munnje buhtes váimmu, O Ipmilan, ja ođasmahte ráfálaš diđolašvuođa mu siste, O Doaivun. Fámu  vuoiŋŋain  nanusmahte mu Du áššis, O Ráhkkásepmosan, ja Du gudni čuovggain čájet munnje bálgát, O Don guhte leat mu hálu Ulbmil. Du geažehis fámu mávttain bajit mu Du bassivuođa albmái, O Don guhte leat mu leahkima Gáldu, ja Du agálašvuođa vuoiŋŋanasaiguin ilosmahte mu, O Don guhte leat mu Ipmil. Divtte Du agálaččat bisti šuoŋaid addit ráfi munnje, O Guoibmán, ja divtte Du dološ lohkameahttun riggodagaid luvvet mu buot earás earet Dus, O Meaštáran, ja divtte Du billašuvakeahtes siskkimučča almmustusa sivdnádusaid buktit munnje ilu. O Don guhte leat buot almmustuhttimiid almmustuhttin ja buot čihkosamos čihkosepmosiid siste.","name":"Lagašvuohta Ipmilii","source":"bahaiprayers.net","version":"a9eaa3dc-c5ab-4208-96d8-41c9e7b3ab21","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"be","lang_name":"Belarusian"},{"language":"bn","lang_name":"Bengali"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"cs","lang_name":"Czech"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fj","lang_name":"Fijian"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"el","lang_name":"Greek"},{"language":"gu","lang_name":"Gujarati"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"ha","lang_name":"Hausa"},{"language":"hz","lang_name":"Herero"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"it","lang_name":"Italian"},{"language":"ky","lang_name":"Kirghiz"},{"language":"lt","lang_name":"Lithuanian"},{"language":"mg","lang_name":"Malagasy"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"cnr","lang_name":"Montenegrin"},{"language":"ne","lang_name":"Nepali"},{"language":"no","lang_name":"Norwegian"},{"language":"kj","lang_name":"Oshikwanyama"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"diu","lang_name":"Rugciriku"},{"language":"ru","lang_name":"Russian"},{"language":"sm","lang_name":"Samoan"},{"language":"sr","lang_name":"Serbian"},{"language":"st","lang_name":"Southern Sotho"},{"language":"es","lang_name":"Spanish"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"tet","lang_name":"Tetum"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH04990","text":"## Dearvvasvuohta\n\nDu namma lea mu buorideapmi, O Ipmil, ja Du muitin lea munnje dálkkas. Lagašvuohta Dutnje lea mu doaivu ja ráhkisvuohta Dutnje lea mu guoibmi. Du árbmu mu guovdu lea mu buorideapmi ja mu dorvu sihke dán máilmmis ja dan máilmmis, mii boahtá. Duođalaččat, Don leat buotveagalaš, buotdiehtti, buotviissis.","name":"Dearvvasvuohta","source":"bahaiprayers.net","version":"856e5ec7-8279-4f5f-a42e-ebe8ec4bc008","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"eu","lang_name":"Basque"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fr","lang_name":"French"},{"language":"gux","lang_name":"Gourmanchéma"},{"language":"el","lang_name":"Greek"},{"language":"gu","lang_name":"Gujarati"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hu","lang_name":"Hungarian"},{"language":"id","lang_name":"Indonesian"},{"language":"ik","lang_name":"Inupiaq"},{"language":"it","lang_name":"Italian"},{"language":"ky","lang_name":"Kirghiz"},{"language":"mg","lang_name":"Malagasy"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"no","lang_name":"Norwegian"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"sr","lang_name":"Serbian"},{"language":"es","lang_name":"Spanish"},{"language":"sv","lang_name":"Swedish"},{"language":"tet","lang_name":"Tetum"},{"language":"tk","lang_name":"Turkmen"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"uk","lang_name":"Ukrainian"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH06296","text":"## Lagašvuohta Ipmilii\n\nDu njálgga hájat agálašvuođa rávnnjiin atte mu juhkat, O Ipmilan, ja Du leahkima muora heđemiid divtte mu smáhket, O Doaivun. Du ráhkisvuođa kristállagálduin divtte mu juhkat, O Gudnán, ja Du agibai' bisti láđisvuođa suoivanii divtte mu ásaiduvvat, O Čuovgan. Du lagašvuođa niittuin, Du leahkima ovddas divtte mu nagodit vádjolit, O Ráhkásan, ja Du árpmu ruvnnu olgešgieđa bealde atte munnje čohkkánsaji, O Hállun. Du njálggahájat ilu vuoiŋŋanasaid divtte bossut badjelasan, O Ulbmilan, ja Du duohtavuođa paradiissa allodagaide divtte mu beassat sisa, O mu Hervošeami mearri. Du oktavuođa duvvá šuoŋaid atte mu gullat, O Don guhte leat čuovgi, ja Du fámu vuoiŋŋa ja mávtta bokte ealáskahte mu, O Sállejeaddján. Du ráhkisvuođa vuoiŋŋain doala mu nanusin, O mu Biebmi ja Du miellabuori bálgá alde daga lávkkiidan sihkkarin, O Sivdnideaddján! Jápmemeahttunvuođat šaddogárddis, Du čábbodaga ovddas, divtte mu orodit agibeaivve, O Don guhte leat árbmugas munnje, ja Du gudni čohkkánsaji ala bija mu, O Don guhte leat mu Oamasteaddji. Du ráhkisteaddji láđisvuođa albmái bajit mu, O mu Ealáskahtti, ja Du oahpistusa guovssonásttiin láide mu, O Don mu Geasuheaddji. Atte mu leat Du oaidnemeahttun almmustusa ovddas, O Don guhte leat mu álgu ja stuorimus doaivva, ja Du čábbodaga njálgga hájaid sisa, maid Don almmustuhtát, divtte mu máhccat, O Don guhte leat mu Ipmil. Fámolaš leat Don dahkat dan, maid háliidat. Don leat duođalaččat Rámiduvvon, Šearradamos, Buot Alimus.","name":"Lagašvuohta Ipmilii","source":"bahaiprayers.net","version":"157b1079-e2dd-430b-a873-b6191fdab1c1","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"gux","lang_name":"Gourmanchéma"},{"language":"el","lang_name":"Greek"},{"language":"gu","lang_name":"Gujarati"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hu","lang_name":"Hungarian"},{"language":"is","lang_name":"Icelandic"},{"language":"it","lang_name":"Italian"},{"language":"ky","lang_name":"Kirghiz"},{"language":"ko","lang_name":"Korean"},{"language":"mg","lang_name":"Malagasy"},{"language":"no","lang_name":"Norwegian"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"sm","lang_name":"Samoan"},{"language":"sr","lang_name":"Serbian"},{"language":"es","lang_name":"Spanish"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"tk","lang_name":"Turkmen"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"uk","lang_name":"Ukrainian"},{"language":"cy","lang_name":"Welsh"}]},{"phelps":"BH07682","text":"## Oktavuohta\n\nO Ipmilan! O Ipmilan! Ovttas bálvaleaddjiidat váimmuid ja almmut sidjiide Du stuorra ulbmila. Čuvvoset sii Du báhkkomiid ja elloset Du lága mielde. Veahket sin, O Ipmil, sin figgamušain ja atte sidjiide nanusvuođa bálvalit Du. O Ipmil! Ale guođe sin okto, oahpis sin lávkkiid Dieđut čuovggain ja ilosmahte sin váimmuid ráhkisvuođainat. Duođalaččat, Don leat sin Veahkeheaddji ja Hearrá.","name":"Oktavuohta","source":"bahaiprayers.net","version":"c6033e47-08c5-4fdc-bc16-ea5b08e19206","translations":[{"language":"eu","lang_name":"Basque"},{"language":"en","lang_name":"English"},{"language":"de","lang_name":"German"},{"language":"gux","lang_name":"Gourmanchéma"},{"language":"mr","lang_name":"Marathi"},{"language":"no","lang_name":"Norwegian"},{"language":"sr","lang_name":"Serbian"},{"language":"tpi","lang_name":"Tok Pisin"}]},{"phelps":"BH09289","text":"## Luovvaneapmi\n\nO Ipmil, Du lusa válmmaštan mun báhtaransaji ja Du mearkkaid guvlui divun váibmun. O Ipmil, mátkki alde dahje ruovttus, doaimmainan dahje barggustan, bijan buot luohttámuššan Dutnje. Udno munnje dasto buotveagalaš veahkkát, nu ahte sáhtán luovvanit buot máilmmálaččas, O Don gean árbmu lea geažeheapmi. Láže munnje oassán, O Hearrá, nugo Don dáhtot ja atte mu duhtat dasa, maid Don leat munnje mearridan. Dus lea dievas váldi mearridit.","name":"Luovvaneapmi","source":"bahaiprayers.net","version":"64eaf577-a22a-42f7-a674-abb332c682bb","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"de","lang_name":"German"},{"language":"el","lang_name":"Greek"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hu","lang_name":"Hungarian"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"it","lang_name":"Italian"},{"language":"ky","lang_name":"Kirghiz"},{"language":"lv","lang_name":"Latvian"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"ml","lang_name":"Malayalam"},{"language":"mh","lang_name":"Marshallese"},{"language":"no","lang_name":"Norwegian"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"ru","lang_name":"Russian"},{"language":"sm","lang_name":"Samoan"},{"language":"sr","lang_name":"Serbian"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"tl","lang_name":"Tagalog"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"uk","lang_name":"Ukrainian"}]},{"phelps":"BH10076","text":"## Mánát\n\nO Hearrá! Bija dán njuoras vesá šaddat valljodagaidat šaddogárdái, njuoskat dan Láđisvuođat gálduin ja divtte dan šaddat Oiddut ja Árpmut rávnnjiid vehkiin válljugas šaddun. Don leat mávttalaš ja fámolaš.","name":"Mánát","source":"bahaiprayers.net","version":"a00b5db6-ee2c-41e4-89fa-83829b6d088f","translations":[{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"ca","lang_name":"Catalan"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"gux","lang_name":"Gourmanchéma"},{"language":"el","lang_name":"Greek"},{"language":"gu","lang_name":"Gujarati"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"it","lang_name":"Italian"},{"language":"ky","lang_name":"Kirghiz"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"mr","lang_name":"Marathi"},{"language":"mn","lang_name":"Mongolian"},{"language":"no","lang_name":"Norwegian"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"sr","lang_name":"Serbian"},{"language":"sk","lang_name":"Slovak"},{"language":"es","lang_name":"Spanish"},{"language":"ta","lang_name":"Tamil"},{"language":"tet","lang_name":"Tetum"},{"language":"zh-Hant","lang_name":"Traditional Chinese"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"uk","lang_name":"Ukrainian"}]},{"phelps":"BH11209","text":"## Geatnegasvuohta\n\nDuođaštan, O Ipmilan, ahte leat sivdnidan mu dovdat Du ja bálvalit Du. Buvttán ovdan dán bottus iežan geahnohisvuođa ja Du fámolašvuođa, iežan geafivuođa ja Du riggodaga. Ii leat mihkkige eará Ipmiliid, go Don, Veahkki heađis, Iešalddes bissovaš.","name":"Geatnegasvuohta","source":"bahaiprayers.net","version":"9fbee344-74f8-41e4-b77d-eed9a10c2d11","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"langua