[{"phelps":"BH00074BLE","text":"## Shoshone\n\nNA SOON DI SEEKH, DEAS DA GANIH, DEAS SOOKH DEAS DA SOH GANIH, DEAS DA BEYUH, DEAS DA DOYA BEH, DEAS BUNGH DA NAMA GWEEJOOH NI KHANDH DEAS DA DIMBEE GANIH, DEAS DA DOIYA HU-NO HA-BEEDTH DEAS DA SO-GOP-H DEAS DA BAH, DEAS DA SO-GOP-H-BAH DE-BEE-YANDH, DEAS DA ZA BOOWHEE NEH-SOO GA KHANDH DOIYA BA B-UT OGOI PU-INH. BUNGH DAUMEH UPEH NAN-IH DUN DA-GWAP. DEAS OOH NE-SHOO-WOO GINDH SUCA NANA-SOO-WOO GINDH.\n\n \n\nBlessed is the spot, and the house, and the place, and the city, and the heart, and the mountain, and the refuge, and the cave, and the valley, and the land, and the sea, and the island, and the meadow where mention of God hath been made, and His praise glorified.","name":"Shoshone","source":"bahaiprayers.net","version":"8cea9877-76f0-4907-8eaf-3aaeb739e244","notes":"Theory: Shoshone prayer 2 (section header: Shoshone). Opening: \"NA SOON DI SEEKH, DEAS DA GANIH, DEAS SOOKH DEAS DA SOH GANIH, DEAS DA BEYUH, DEAS DA DOYA BEH...\" No English translation available. Challenge: Shoshone transcription in non-standard format.","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"be","lang_name":"Belarusian"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"chr","lang_name":"Cherokee"},{"language":"co","lang_name":"Corsican"},{"language":"dgz","lang_name":"Daga"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"gwi","lang_name":"Gwich'in"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"ik","lang_name":"Inupiaq"},{"language":"ga","lang_name":"Irish"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kiw","lang_name":"Kiwai"},{"language":"ksd","lang_name":"Kuanua"},{"language":"kgf","lang_name":"Kube"},{"language":"lkt","lang_name":"Lakota"},{"language":"lt","lang_name":"Lithuanian"},{"language":"lut","lang_name":"Lushootseed"},{"language":"ml","lang_name":"Malayalam"},{"language":"med","lang_name":"Melpa"},{"language":"moh","lang_name":"Mohawk"},{"language":"meu","lang_name":"Motu"},{"language":"nv","lang_name":"Navajo"},{"language":"ttm","lang_name":"Northern Tutchone"},{"language":"oj","lang_name":"Ojibwe"},{"language":"one","lang_name":"Oneida"},{"language":"pap","lang_name":"Papiamento"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"ro","lang_name":"Romanian"},{"language":"se","lang_name":"Sami"},{"language":"sm","lang_name":"Samoan"},{"language":"slh","lang_name":"Sliammon"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"tet","lang_name":"Tetum"},{"language":"tk","lang_name":"Turkmen"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH10505","text":"## Shoshone\n\nDA-MEH UPEH, DA-MEH UPEH,\n\nSEMES DA-NEH-MEH-NEH HA BEYUH MEH, DEAS MA-DE-ZA-POING DA BE-YAH NA-HA-NEE-DOH SOO- WI-KH DA-MEH UPEH DE-NEE TA GWAP DEAS DA DE-NEE-TA-GWAP KOOPH NAHK. MA DE DE-MA-ZI, UPEH, SU-KA MA-DEH HA-NEE DOH, DEAS GU-TA MA DEH M-EH SOO-NEEK SEE-DEH U-MA-BEE-ZA-KHON-DOH. DAMEH UPEH. GA DEAS MA-DEH ZA-PEH-TINDH, MA-DEH-DAH-TI-GEEK, MA-DEH NA-SOO BA-DU KHAN DOH, SOO-KA DA-NA-BOO-IPH. DEAS MA-DEH BE-YUH ZA-NEE-SHOON-GAH, MA-DEH GA-ME-NGH.\n\nO my God! O my God! Unite the hearts of Thy servants, and reveal to them Thy great purpose. May they follow Thy commandments and abide in Thy law. Help them, O God, in their endeavour, and grant them strength to serve Thee.  O God! Leave them not to themselves, but guide their steps by the light of Thy knowledge, and cheer their hearts by Thy love. Verily, Thou art their helper and their Lord.","name":"Shoshone","source":"bahaiprayers.net","version":"8bf3298a-77ef-4932-97b9-47f8c7a72849","notes":"Theory: Shoshone prayer 1 (section header: Shoshone). Opening: \"DA-MEH UPEH, DA-MEH UPEH, SEMES DA-NEH-MEH-NEH HA BEYUH MEH...\" No English translation available. Challenge: Shoshone transcription in non-standard format; critically endangered language.","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"hy","lang_name":"Armenian"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"bn","lang_name":"Bengali"},{"language":"bs","lang_name":"Bosnian"},{"language":"ch","lang_name":"Chamorro"},{"language":"chr","lang_name":"Cherokee"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"cs","lang_name":"Czech"},{"language":"dgz","lang_name":"Daga"},{"language":"dak","lang_name":"Dakota"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fo","lang_name":"Faroese"},{"language":"fj","lang_name":"Fijian"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"el","lang_name":"Greek"},{"language":"gu","lang_name":"Gujarati"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"hz","lang_name":"Herero"},{"language":"hi","lang_name":"Hindi"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"ik","lang_name":"Inupiaq"},{"language":"it","lang_name":"Italian"},{"language":"ja","lang_name":"Japanese"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name