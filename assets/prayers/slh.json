[{"phelps":"BH00074BLE","text":"*\"Blessed is the Spot\"   in the Sliammon Language\n\nOh kw shet hegus\n\nPoleset toh nehs\nkweh eh sheet\nhega tah ah yehs,\nnehs klumes,\nnehs tah kluk kweh nahs,\nhega tah t'akt,\nhega tah tapas,\nhega tah sapet,\nhega tah geejah,\nhega tah cheh,\nhega tah kwuthys,\nkw ty ty nigit nons kw shet hegus.\nYeech kw cheh hum.\nHega tah nisheeyeok,\nhelh awh nehs.","name":"Blessed is the Spot","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"be","lang_name":"Belarusian"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"chr","lang_name":"Cherokee"},{"language":"co","lang_name":"Corsican"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"gwi","lang_name":"Gwich'in"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"ga","lang_name":"Irish"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kiw","lang_name":"Kiwai"},{"language":"lkt","lang_name":"Lakota"},{"language":"lt","lang_name":"Lithuanian"},{"language":"lut","lang_name":"Lushootseed"},{"language":"ml","lang_name":"Malayalam"},{"language":"moh","lang_name":"Mohawk"},{"language":"meu","lang_name":"Motu"},{"language":"nv","lang_name":"Navajo"},{"language":"oj","lang_name":"Ojibwe"},{"language":"pap","lang_name":"Papiamento"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"ro","lang_name":"Romanian"},{"language":"sm","lang_name":"Samoan"},{"language":"srn