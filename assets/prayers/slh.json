{"prayers":[{"phelps":"BH00074BLE","text":"## Tla'amin Nation\n\n\"Blessed is the Spot\"   in the Sliammon Language\n\nOh kw shet hegus\n\nPoleset toh nehs\n\nkweh eh sheet\n\nhega tah ah yehs,\n\nnehs klumes,\n\nnehs tah kluk kweh nahs,\n\nhega tah t'akt,\n\nhega tah tapas,\n\nhega tah sapet,\n\nhega tah geejah,\n\nhega tah cheh,\n\nhega tah kwuthys,\n\nkw ty ty nigit nons kw shet hegus.\n\nYeech kw cheh hum.\n\nHega tah nisheeyeok,\n\nhelh awh nehs.","name":"Tla'amin Nation","category":"Tla'amin Nation","order_in_cat":1,"source":"bahaiprayers.net","version":"81980652-ce91-465a-87fb-cd400562fee5","v":"7o79edca7z00oynfwqii3ckpx","book":"nai-CA:bpnet","book_cats":{"be:bpapp":{"cat":"Агульныя малітвы","cat_order":2,"order_in_cat":1},"be:bpnet":{"cat":"Блаславёны","order_in_cat":1},"bs:bpnet":{"cat":"Praznik Devetnaest Dana","order_in_cat":1},"ca:bpnet":{"cat":"Qualitats Espirituals","order_in_cat":10},"co:bpnet":{"cat":"Families","order_in_cat":1},"cy:bpnet":{"cat":"Common","order_in_cat":1},"de:bpapp":{"cat":"Allgemeine Gebete","cat_order":2,"order_in_cat":2},"de:bpnet":{"cat":"Allgemein","order_in_cat":1},"dgz:bpnet":{"cat":"Wat Aimagam U’uraewa (Blessed Is the Spot)","order_in_cat":1},"en:bpapp":{"cat":"General Prayers","cat_order":2,"order_in_cat":1},"en:bpnet":{"cat":"Gatherings","order_in_cat":8},"eo:bel-malnova":{"cat":"Bahá'u'lláh","cat_order":2,"order_in_cat":2},"eo:bpapp":{"cat":"Preĝoj revelaciitaj de Bahá’u’lláh","cat_order":2,"order_in_cat":2},"es:bpapp":{"cat":"Oraciones generales","cat_order":2,"order_in_cat":1},"et:bpnet":{"cat":"Katsumused ja raskused","order_in_cat":3},"fa:bpapp":{"cat":"طلب مدد و حمایت","cat_order":3,"order_in_cat":1},"fa:bpnet":{"cat":"طلب مدد و حمایت","order_in_cat":1},"fr:bpapp":{"cat":"Prières ordinaires","cat_order":2,"order_in_cat":1},"fr:bpnet":{"cat":"Familles","order_in_cat":6},"fy:bpnet":{"cat":"Tafelgebedens","order_in_cat":1},"gil:bpnet":{"cat":"Tataro aika a Taabangaki","order_in_cat":1},"haw:bpnet":{"cat":"General Pray