{"prayers":[{"phelps":"BH00074BLE","text":"## Tla'amin Nation\n\n\"Blessed is the Spot\"   in the Sliammon Language\n\nOh kw shet hegus\n\nPoleset toh nehs\n\nkweh eh sheet\n\nhega tah ah yehs,\n\nnehs klumes,\n\nnehs tah kluk kweh nahs,\n\nhega tah t'akt,\n\nhega tah tapas,\n\nhega tah sapet,\n\nhega tah geejah,\n\nhega tah cheh,\n\nhega tah kwuthys,\n\nkw ty ty nigit nons kw shet hegus.\n\nYeech kw cheh hum.\n\nHega tah nisheeyeok,\n\nhelh awh nehs.","name":"Tla'amin Nation","category":"Tla'amin Nation","order_in_cat":1,"source":"bahaiprayers.net","version":"81980652-ce91-465a-87fb-cd400562fee5","v":"7o79edca7z00oynfwqii3ckpx","book":"nai-CA:bpnet","book_cats":{"be:bpnet":{"cat":"Блаславёны","order_in_cat":1},"bs:bpnet":{"cat":"Praznik Devetnaest Dana","order_in_cat":1},"ca:bpnet":{"cat":"Qualitats Espirituals","order_in_cat":10},"co:bpnet":{"cat":"Families","order_in_cat":1},"cy:bpnet":{"cat":"Common","order_in_cat":1},"de:bpnet":{"cat":"Allgemein","order_in_cat":1},"dgz:bpnet":{"cat":"Wat Aimagam U’uraewa (Blessed Is the Spot)","order_in_cat":1},"en:bpnet":{"cat":"Gatherings","order_in_cat":8},"eo:bel-malnova":{"cat":"Bahá'u'lláh","cat_order":2,"order_in_cat":2},"et:bpnet":{"cat":"Katsumused ja raskused","order_in_cat":3},"fa:bpnet":{"cat":"طلب مدد و حمایت","order_in_cat":1},"fr:bpnet":{"cat":"Familles","order_in_cat":6},"fy:bpnet":{"cat":"Tafelgebedens","order_in_cat":1},"gil:bpnet":{"cat":"Tataro aika a Taabangaki","order_in_cat":1},"haw:bpnet":{"cat":"General Prayers","order_in_cat":1},"ht:bpnet":{"cat":"Lwanj ak Rekonesans","order_in_cat":5},"hu:bpnet":{"cat":"Család","order_in_cat":3},"iba:bpnet":{"cat":"RABAN GELUMU","order_in_cat":1},"ik:bpnet":{"cat":"Iñupiaq - North Slope Dialect","order_in_cat":13},"is:bpnet":{"cat":"Lofgjörð og þökk","order_in_cat":12},"kgf:bpnet":{"cat":"Uŋwambuŋga Baecsêc","order_in_cat":1},"kl:bpnet":{"cat":"Katerisimaarnerit","order_in_cat":1},"km:bpnet":{"cat":"General Prayers","order_in_cat":1},"ksd:bpnet":{"cat":"A VAKAK NA PAK