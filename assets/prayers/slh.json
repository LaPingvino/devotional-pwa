{"prayers":[{"phelps":"BH00074BLE","text":"## Tla'amin Nation\n\n\"Blessed is the Spot\"   in the Sliammon Language\n\nOh kw shet hegus\n\nPoleset toh nehs\n\nkweh eh sheet\n\nhega tah ah yehs,\n\nnehs klumes,\n\nnehs tah kluk kweh nahs,\n\nhega tah t'akt,\n\nhega tah tapas,\n\nhega tah sapet,\n\nhega tah geejah,\n\nhega tah cheh,\n\nhega tah kwuthys,\n\nkw ty ty nigit nons kw shet hegus.\n\nYeech kw cheh hum.\n\nHega tah nisheeyeok,\n\nhelh awh nehs.","name":"Tla'amin Nation","source":"bahaiprayers.net","version":"81980652-ce91-465a-87fb-cd400562fee5","book_cats":{"be":{"cat":"Блаславёны","order_in_cat":1},"ca":{"cat":"Qualitats Espirituals","order_in_cat":10},"de":{"cat":"Allgemein","order_in_cat":1},"en":{"cat":"Gatherings","order_in_cat":8},"et":{"cat":"Katsumused ja raskused","order_in_cat":3},"fa":{"cat":"طلب مدد و حمایت","order_in_cat":1},"fr":{"cat":"Familles","order_in_cat":6},"hu":{"cat":"Család","order_in_cat":3},"is":{"cat":"Lofgjörð og þökk","order_in_cat":12},"kl":{"cat":"Katerisimaarnerit","order_in_cat":1},"km":{"cat":"General Prayers","order_in_cat":1},"lt":{"cat":"Vaikai","order_in_cat":1},"ml":{"cat":"ഐക്യം","order_in_cat":2},"pt":{"cat":"Orações","order_in_cat":1},"ro":{"cat":"Pentru cei Răposaţi","order_in_cat":2},"sq":{"cat":"i përgjithshëm","order_in_cat":1},"tk":{"cat":"Dostluk We Agzybirlik","order_in_cat":5}},"translations":[{"language":"ga","lang_name":"Irish"},{"language":"pap","lang_name":"Papiamento"},{"language":"ttm","lang_name":"Northern Tutchone"},{"language":"es","lang_name":"Spanish"},{"language":"ksd","lang_name":"Kuanua"},{"language":"ro","lang_name":"Romanian"},{"language":"kgf","lang_name":"Kube"},{"language":"shh","lang_name":"Shoshoni"},{"language":"meu","lang_name":"Motu"},{"language":"sv","lang_name":"Swedish"},{"language":"dgz","lang_name":"Daga"},{"language":"gwi","lang_name":"Gwich'in"},{"language":"med","lang_name":"Melpa"},{"language":"bla","lang_name":"Blackfoot"},{"language":"gil","lang_name":"Gilbertese"},{"languag