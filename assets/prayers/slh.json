[{"phelps":"BH00074BLE","text":"## Tla'amin Nation\n\n\"Blessed is the Spot\"   in the Sliammon Language\n\nOh kw shet hegus\n\nPoleset toh nehs\n\nkweh eh sheet\n\nhega tah ah yehs,\n\nnehs klumes,\n\nnehs tah kluk kweh nahs,\n\nhega tah t'akt,\n\nhega tah tapas,\n\nhega tah sapet,\n\nhega tah geejah,\n\nhega tah cheh,\n\nhega tah kwuthys,\n\nkw ty ty nigit nons kw shet hegus.\n\nYeech kw cheh hum.\n\nHega tah nisheeyeok,\n\nhelh awh nehs.","name":"Tla'amin Nation","source":"bahaiprayers.net","version":"81980652-ce91-465a-87fb-cd400562fee5","translations":[{"language":"sq","lang_name":"Albanian"},{"language":"be","lang_name":"Belarusian"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"ca","lang_name":"Catalan"},{"language":"km","lang_name":"Central Khmer"},{"language":"chr","lang_name":"Cherokee"},{"language":"co","lang_name":"Corsican"},{"language":"dgz","lang_name":"Daga"},{"language":"en","lang_name":"English"},{"language":"et","lang_name":"Estonian"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"gil","lang_name":"Gilbertese"},{"language":"gwi","lang_name":"Gwich'in"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"ik","lang_name":"Inupiaq"},{"language":"ga","lang_name":"Irish"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kiw","lang_name":"Kiwai"},{"language":"ksd","lang_name":"Kuanua"},{"language":"kgf","lang_name":"Kube"},{"language":"lkt","lang_name":"Lakota"},{"language":"lt","lang_name":"Lithuanian"},{"language":"lut","lang_name":"Lushootseed"},{"language":"ml","lang_name":"Malayalam"},{"language":"med","lang_name":"Melpa"},{"language":"moh","lang_name":"Mohawk"},{"language":"meu","lang_name":"Motu"