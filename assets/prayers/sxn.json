:"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"tpi","lang_name":"Tok Pisin"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"vi","lang_name":"Vietnamese"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH01313NAM","text":"Dien Naam is mien Genäsen, o mien Gott, un dat Dinken an Di is mien Medezin. Di neeg' to sien is mien Hœpen, un Leevde to Di is mien Kumpaan. Dien Gnaad' is mien Genäsen un mien Bistand in düsse Welt as ook in de tokamene Welt. Du büst förwahr de Freegäävsche, de Allwätene, de Allwiese.","name":"Heilungsgebääd","source":"bahaiprayers.org","version":"8a5c9322-fbe4-4d6d-8745-13fe3e1e62dc","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"ar","lang_name":"Arabic"},{"language":"ar-translit","lang_name":"Arabic (Latin)"},{"language":"hy","lang_name":"Armenian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"bn","lang_name":"Bengali"},{"language":"bi","lang_name":"Bislama"},{"language":"bla","lang_name":"Blackfoot"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"ceb","lang_name":"Cebuano"},{"language":"ch","lang_name":"Chamorro"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"cs","lang_name":"Czech"},{"language":"dgz","lang_name":"Daga"},{"language":"dak","lang_name":"Dakota"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"en","lang_name":"English"},{"language":"eo","lang_name":"Esperanto"},{"language":"et","lang_name":"Estonian"},{"language":"fo","lang_name":"Faroese"},{"language":"fj","lang_name":"Fijian"},{"language":"fi","lang_name":"Finnish"},{"language":"fr","lang_name":"French"},{"language":"lg","lang_name":"Ganda"},{"language":"de","lang_name":"German"},{"language":"gux","lang_name":"Gourmanchéma"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"hur","lang_name":"Halkomelem"},{"language":"ha","lang_name":"Hausa"},{"language":"haw","lang_name":"Hawaiian"},{"language":"hz","lang_name":"Herero"},{"language":"hu","lang_name":"Hungarian"},{"language":"iba","lang_name":"Iban"},{"language":"is","lang_name":"Icelandic"},{"language":"id","lang_name":"Indonesian"},{"language":"ik","lang_name":"Inupiaq"},{"language":"it","lang_name":"Italian"},{"language":"ja","lang_name":"Japanese"},{"language":"kl","lang_name":"Kalaallisut"},{"language":"kn","lang_name":"Kannada"},{"language":"naq","lang_name":"Khoekhoegowab"},{"language":"ky","lang_name":"Kirghiz"},{"language":"ko","lang_name":"Korean"},{"language":"ksd","lang_name":"Kuanua"},{"language":"kgf","lang_name":"Kube"},{"language":"dih","lang_name":"Kumiai"},{"language":"lkt","lang_name":"Lakota"},{"language":"lo","lang_name":"Lao"},{"language":"lv","lang_name":"Latvian"},{"language":"lt","lang_name":"Lithuanian"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"mg","lang_name":"Malagasy"},{"language":"ms","lang_name":"Malay"},{"language":"ml","lang_name":"Malayalam"},{"language":"mt","lang_name":"Maltese"},{"language":"mi","lang_name":"Maori"},{"language":"mr","lang_name":"Marathi"},{"language":"med","lang_name":"Melpa"},{"language":"moh","lang_name":"Mohawk"},{"language":"mn","lang_name":"Mongolian"},{"language":"cnr","lang_name":"Montenegrin"},{"language":"meu","lang_name":"Motu"},{"language":"nal","lang_name":"Nalik"},{"language":"nv","lang_name":"Navajo"},{"language":"ne","lang_name":"Nepali"},{"language":"no","lang_name":"Norwegian"},{"language":"fa","lang_name":"Persian"},{"language":"fa-translit","lang_name":"Persian (Latin)"},{"language":"pl","lang_name":"Polish"},{"language":"pt","lang_name":"Portuguese"},{"language":"ro","lang_name":"Romanian"},{"language":"diu","lang_name":"Rugciriku"},{"language":"ru","lang_name":"Russian"},{"language":"sr","lang_name":"Serbian"},{"language":"zh-Hans","lang_name":"Simplified Chinese"},{"language":"sk","lang_name":"Slovak"},{"language":"sl","lang_name":"Slovenian"},{"language":"st","lang_name":"Southern Sotho"},{"language":"es","lang_name":"Spanish"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"sw","lang_name":"Swahili"},{"language":"sv","lang_name":"Swedish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ta","lang_name":"Tamil"},{"language":"th","lang_name":"Thai"},{"language":"tk","lang_name":"Turkmen"},{"language":"uk","lang_name":"Ukrainian"},{"language":"ur","lang_name":"Urdu"},{"language":"cy","lang_name":"Welsh"},{"language":"fy","lang_name":"Western Frisian"}]},{"phelps":"BH10505","text":"O mien Gott! O mien Gott! Maak Dien Deners ähr Harten enig, un apenbaar jüm Dien groten Plaan. Mœgt se Dien Geboden nakamen un up Dien Gesett hören. Help jüm, o Gott, in jüm ähr Sträven, un gääv' jüm Kraft Di to denen. O Gott! Laat jüm nich jüm sülven œver, sünnern ledd jüm ähr Träden in dat Licht vun Dien Wäten, un maak jüm ähr Harten blied' mit Dien Leevde. Du büst förwahr jüm ähr Helper un jüm ähr Herr.","name":"Eenheitsgebääd","source":"bahaiprayers.org","version":"05bff034-0cf6-4d13-a21d-0dc44238a167","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"hy","lang_name":"Armenian"},{"language":"ay","lang_name":"Aymara"},{"language":"eu","lang_name":"Basque"},{"language":"sne","lang_name":"Bau Bidayuh"},{"language":"bn","lang_name":"Bengali"},{"language":"bs","lang_name":"Bosnian"},{"language":"ch","lang_name":"Chamorro"},{"language":"chr","lang_name":"Cherokee"},{"language":"ny","lang_name":"Chichewa"},{"language":"chn","lang_name":"Chinook Jargon"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"cs","lang_name":"Czech"},{"language":"dgz","lang_name":"Daga"},{"language":"dak","lang_