[{"phelps":"AB04427","text":"## Sm’algyax\n\nO Miyaani Da'a'ntgi Lusndaamti sü gugweelksm laawksi ada so goy'p'm biyaalsi.and Nüün gu daanmsgit di£ na gatgyedn.        \n\n     \n\n \n\nO God, Guide me protect me make of me a shining lamp and a brilliant star. Thou art the Mighty  And the Powerful.","name":"Sm’algyax","translations":[{"language":"hy","lang_name":"Armenian"},{"language":"bn","lang_name":"Bengali"},{"language":"ny","lang_name":"Chichewa"},{"language":"hi","lang_name":"Hindi"},{"language":"ja","lang_name":"Japanese"},{"language":"ky","lang_name":"Kirghiz"},{"language":"ko","lang_name":"Korean"},{"language":"ms","lang_name":"Malay"},{"language":"mi","lang_name":"Maori"},{"language":"mn","lang_name":"Mongolian"},{"language":"sm","lang_name":"Samoan"},{"language":"sr","lang_name":"Serbian"},{"language":"zh-Hans","lang_name":"Simplified Chinese"},{"language":"ta","lang_name":"Tamil"},{"language":"te","lang_name":"Telugu"},{"language":"tpi","lang_name":"Tok Pisin"},{"language":"zh-Hant","lang_name":"Traditional Chinese"}]},{"phelps":"AB04427GUI","text":"*\"O God, Guide Me\" in Sm'algyax, the language of the Tsimshian Peoples.\n\nO Miyaani               \nDa'a'ntgi               \nLusndaamti              \nsü gugweelksm laawksi   \nada so goy'p'm biyaalsi.and  \nNüün gu daanmsgit        \ndi£ na gatgyedn","name":"O God, guide me","translations":[{"language":"af","lang_name":"Afrikaans"},{"language":"sq","lang_name":"Albanian"},{"language":"az","lang_name":"Azerbaijani"},{"language":"eu","lang_name":"Basque"},{"language":"be","lang_name":"Belarusian"},{"language":"bn","lang_name":"Bengali"},{"language":"bi","lang_name":"Bislama"},{"language":"bs","lang_name":"Bosnian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ca","lang_name":"Catalan"},{"language":"ch","lang_name":"Chamorro"},{"language":"co","lang_name":"Corsican"},{"language":"hr","lang_name":"Croatian"},{"language":"da","lang_name":"Danish"},{"language":"nl","lang_name":"Dutch"},{"language":"