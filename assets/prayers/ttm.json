{"prayers":[{"phelps":"BH00074BLE","text":"## Northern Tutchone\n\n(Na  Ité ithui, ethui ninghinta sothan eyínjyái Hutsha-dun, itsua, iney, imiua, ijya:\n\n Blessed is the Spot\n\nNinghinta Sothan Jaül\n\nNinghinta sothan jaül,\n\n na ku, na jaül, na kashee,\n\nNa etsi, \n\nna dhawe, \n\nso-aji, nund ninachi,\n\nNa unclout, \n\nna nünd, \n\nmun sa'cho, \n\nchui, \n\ntl'ok caüa\n\nJáüa úzhi Ilé ilsi, \n\nIlé uhuaná sulhan.","name":"Northern Tutchone","source":"bahaiprayers.net","version":"dcef34e1-724f-4524-bb3b-5ae27d9cb150","book_cats":{"be":{"cat":"Блаславёны","order_in_cat":1},"ca":{"cat":"Qualitats Espirituals","order_in_cat":10},"de":{"cat":"Allgemein","order_in_cat":1},"en":{"cat":"Gatherings","order_in_cat":8},"et":{"cat":"Katsumused ja raskused","order_in_cat":3},"fa":{"cat":"طلب مدد و حمایت","order_in_cat":1},"fr":{"cat":"Familles","order_in_cat":6},"hu":{"cat":"Család","order_in_cat":3},"is":{"cat":"Lofgjörð og þökk","order_in_cat":12},"kl":{"cat":"Katerisimaarnerit","order_in_cat":1},"km":{"cat":"General Prayers","order_in_cat":1},"lt":{"cat":"Vaikai","order_in_cat":1},"ml":{"cat":"ഐക്യം","order_in_cat":2},"pt":{"cat":"Orações","order_in_cat":1},"ro":{"cat":"Pentru cei Răposaţi","order_in_cat":2},"sq":{"cat":"i përgjithshëm","order_in_cat":1},"tk":{"cat":"Dostluk We Agzybirlik","order_in_cat":5}},"translations":[{"language":"kl","lang_name":"Kalaallisut"},{"language":"es","lang_name":"Spanish"},{"language":"it","lang_name":"Italian"},{"language":"eo","lang_name":"Esperanto"},{"language":"mt","lang_name":"Maltese"},{"language":"pap","lang_name":"Papiamento"},{"language":"ms","lang_name":"Malay"},{"language":"kgf","lang_name":"Kube"},{"language":"ga","lang_name":"Irish"},{"language":"hur","lang_name":"Halkomelem"},{"language":"bla","lang_name":"Blackfoot"},{"language":"lut","lang_name":"Lushootseed"},{"language":"se","lang_name":"Sami"},{"language":"meu","lang_name":"Motu"},{"language":"pt","lang_name":"Portuguese"},{"language":"slh","lang_name":"Sliammon"}