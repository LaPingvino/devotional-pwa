{"prayers":[{"phelps":"BH00074BLE","text":"## Northern Tutchone\n\n(Na  Ité ithui, ethui ninghinta sothan eyínjyái Hutsha-dun, itsua, iney, imiua, ijya:\n\n Blessed is the Spot\n\nNinghinta Sothan Jaül\n\nNinghinta sothan jaül,\n\n na ku, na jaül, na kashee,\n\nNa etsi, \n\nna dhawe, \n\nso-aji, nund ninachi,\n\nNa unclout, \n\nna nünd, \n\nmun sa'cho, \n\nchui, \n\ntl'ok caüa\n\nJáüa úzhi Ilé ilsi, \n\nIlé uhuaná sulhan.","name":"Northern Tutchone","category":"Northern Tutchone","order_in_cat":1,"source":"bahaiprayers.net","version":"dcef34e1-724f-4524-bb3b-5ae27d9cb150","v":"d2vhjegxx6zwd7t0vaw064swg","book":"nai-CA:bp","book_cats":{"be:bp":{"cat":"Блаславёны","order_in_cat":1},"bs:bp":{"cat":"Praznik Devetnaest Dana","order_in_cat":1},"ca:bp":{"cat":"Qualitats Espirituals","order_in_cat":10},"co:bp":{"cat":"Families","order_in_cat":1},"cy:bp":{"cat":"Common","order_in_cat":1},"de:bp":{"cat":"Allgemein","order_in_cat":1},"dgz:bp":{"cat":"Wat Aimagam U’uraewa (Blessed Is the Spot)","order_in_cat":1},"en:bp":{"cat":"Gatherings","order_in_cat":8},"et:bp":{"cat":"Katsumused ja raskused","order_in_cat":3},"fa:bp":{"cat":"طلب مدد و حمایت","order_in_cat":1},"fr:bp":{"cat":"Familles","order_in_cat":6},"fy:bp":{"cat":"Tafelgebedens","order_in_cat":1},"gil:bp":{"cat":"Tataro aika a Taabangaki","order_in_cat":1},"haw:bp":{"cat":"General Prayers","order_in_cat":1},"ht:bp":{"cat":"Lwanj ak Rekonesans","order_in_cat":5},"hu:bp":{"cat":"Család","order_in_cat":3},"iba:bp":{"cat":"RABAN GELUMU","order_in_cat":1},"ik:bp":{"cat":"Iñupiaq - North Slope Dialect","order_in_cat":13},"is:bp":{"cat":"Lofgjörð og þökk","order_in_cat":12},"kgf:bp":{"cat":"Uŋwambuŋga Baecsêc","order_in_cat":1},"kl:bp":{"cat":"Katerisimaarnerit","order_in_cat":1},"km:bp":{"cat":"General Prayers","order_in_cat":1},"ksd:bp":{"cat":"A VAKAK NA PAKANA","order_in_cat":1},"lg:bp":{"cat":"OKUBEERWA","order_in_cat":2},"lt:bp":{"cat":"Vaikai","order_in_cat":1},"med:bp":{"cat":"ANATU TEK OUDUI ENGA ATENGA E","order_in_