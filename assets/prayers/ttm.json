{"prayers":[{"phelps":"BH00074BLE","text":"## Northern Tutchone\n\n(Na  Ité ithui, ethui ninghinta sothan eyínjyái Hutsha-dun, itsua, iney, imiua, ijya:\n\n Blessed is the Spot\n\nNinghinta Sothan Jaül\n\nNinghinta sothan jaül,\n\n na ku, na jaül, na kashee,\n\nNa etsi, \n\nna dhawe, \n\nso-aji, nund ninachi,\n\nNa unclout, \n\nna nünd, \n\nmun sa'cho, \n\nchui, \n\ntl'ok caüa\n\nJáüa úzhi Ilé ilsi, \n\nIlé uhuaná sulhan.","name":"Northern Tutchone","source":"bahaiprayers.net","version":"dcef34e1-724f-4524-bb3b-5ae27d9cb150","book_cats":{"be":{"cat":"Блаславёны","cat_order":4,"order_in_cat":1},"bs":{"cat":"Praznik Devetnaest Dana","cat_order":29,"order_in_cat":1},"ca":{"cat":"Qualitats Espirituals","cat_order":30,"order_in_cat":15},"co":{"cat":"Families","cat_order":1,"order_in_cat":1},"cy":{"cat":"Common","cat_order":2,"order_in_cat":1},"de":{"cat":"Allgemein","cat_order":1,"order_in_cat":1},"en":{"cat":"Gatherings","cat_order":23,"order_in_cat":1},"et":{"cat":"Katsumused ja raskused","cat_order":8,"order_in_cat":5},"fa":{"cat":"طلب مدد و حمایت","cat_order":20,"order_in_cat":1},"fa-translit":{"cat":"طلب مدد و حمایت","cat_order":20,"order_in_cat":1},"fr":{"cat":"Familles","cat_order":9,"order_in_cat":1},"fy":{"cat":"Tafelgebedens","cat_order":15,"order_in_cat":1},"haw":{"cat":"General Prayers","order_in_cat":2},"ht":{"cat":"Lwanj ak Rekonesans","cat_order":26,"order_in_cat":5},"hu":{"cat":"Család","cat_order":7,"order_in_cat":2},"is":{"cat":"Lofgjörð og þökk","cat_order":21,"order_in_cat":1},"kl":{"cat":"Katerisimaarnerit","cat_order":19,"order_in_cat":1},"km":{"cat":"General Prayers","order_in_cat":1},"lg":{"cat":"OKUBEERWA","cat_order":17,"order_in_cat":2},"lt":{"cat":"Vaikai","cat_order":12,"order_in_cat":1},"ml":{"cat":"ഐക്യം","cat_order":8,"order_in_cat":2},"pap":{"cat":"Gatherings","cat_order":3,"order_in_cat":1},"ro":{"cat":"Pentru cei Răposaţi","cat_order":23,"order_in_cat":5},"sq":{"cat":"i përgjithshëm","cat_order":6,"order_in_cat":1},"srn":{"cat":"Algemen