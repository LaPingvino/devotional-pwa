{"prayers":[{"phelps":"BH00074BLE","text":"## Northern Tutchone\n\n(Na  Ité ithui, ethui ninghinta sothan eyínjyái Hutsha-dun, itsua, iney, imiua, ijya:\n\n Blessed is the Spot\n\nNinghinta Sothan Jaül\n\nNinghinta sothan jaül,\n\n na ku, na jaül, na kashee,\n\nNa etsi, \n\nna dhawe, \n\nso-aji, nund ninachi,\n\nNa unclout, \n\nna nünd, \n\nmun sa'cho, \n\nchui, \n\ntl'ok caüa\n\nJáüa úzhi Ilé ilsi, \n\nIlé uhuaná sulhan.","name":"Northern Tutchone","category":"Northern Tutchone","order_in_cat":1,"source":"bahaiprayers.net","version":"dcef34e1-724f-4524-bb3b-5ae27d9cb150","v":"d2vhjegxx6zwd7t0vaw064swg","book":"nai-CA:bpnet","book_cats":{"be:bpapp":{"cat":"Агульныя малітвы","cat_order":2,"order_in_cat":1},"be:bpnet":{"cat":"Блаславёны","order_in_cat":1},"bs:bpnet":{"cat":"Praznik Devetnaest Dana","order_in_cat":1},"ca:bpnet":{"cat":"Qualitats Espirituals","order_in_cat":10},"co:bpnet":{"cat":"Families","order_in_cat":1},"cy:bpnet":{"cat":"Common","order_in_cat":1},"de:bpapp":{"cat":"Allgemeine Gebete","cat_order":2,"order_in_cat":2},"de:bpnet":{"cat":"Allgemein","order_in_cat":1},"dgz:bpnet":{"cat":"Wat Aimagam U’uraewa (Blessed Is the Spot)","order_in_cat":1},"en:bpapp":{"cat":"General Prayers","cat_order":2,"order_in_cat":1},"en:bpnet":{"cat":"Gatherings","order_in_cat":8},"eo:bel-malnova":{"cat":"Bahá'u'lláh","cat_order":2,"order_in_cat":2},"eo:bpapp":{"cat":"Preĝoj revelaciitaj de Bahá’u’lláh","cat_order":2,"order_in_cat":2},"es:bpapp":{"cat":"Oraciones generales","cat_order":2,"order_in_cat":1},"et:bpnet":{"cat":"Katsumused ja raskused","order_in_cat":3},"fa:bpapp":{"cat":"طلب مدد و حمایت","cat_order":3,"order_in_cat":1},"fa:bpnet":{"cat":"طلب مدد و حمایت","order_in_cat":1},"fr:bpapp":{"cat":"Prières ordinaires","cat_order":2,"order_in_cat":1},"fr:bpnet":{"cat":"Familles","order_in_cat":6},"fy:bpnet":{"cat":"Tafelgebedens","order_in_cat":1},"gil:bpnet":{"cat":"Tataro aika a Taabangaki","order_in_cat":1},"haw:bpnet":{"cat":"General Prayers","order_in_cat":1},"ht