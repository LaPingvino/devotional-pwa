#!/usr/bin/env python3
"""Scrape bahai.org library books and import into the `writings` table.

Targets section-paginated bahai.org URLs (e.g. paris-talks/1..N). For each
section, extracts <p> paragraphs and stores them with synthetic 11-char
phelps codes:
   <5-char base prefix> + <2-digit section> + <3-digit paragraph>

Each work registers a writings/<key> i18n metadata row so gen_hugo_data.go
picks it up automatically.

Usage:
  python3 scripts/scrape_bahai_org.py [--only paristalks]
"""
import argparse
import json
import re
import subprocess
import sys
import time
import urllib.request
import urllib.error

DOLT_DIR = "/home/joop/bahaiwritings"
MIN_PARA_LEN = 30
UA = "Mozilla/5.0 (compatible; BahaiTextAligner/1.0)"

# (key, code_prefix_5, base_url_template, section_range, language,
#  author, author_prefix, title, order, single_book, source_tag)
