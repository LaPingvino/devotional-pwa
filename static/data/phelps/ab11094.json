{"pin":"AB11094","subcodes":[{"code":"AB11094","anchor":"","title":"Prayer for the departed.","first_line":"O my God! O Thou forgiver of sins, bestower of gifts, dispeller of afflictions!","word_count":"50","subjects":"@prayer for the departed, @soul; spirit after death, @forgiveness; grace; bounty; mercy; compassion of God","full_text_parts":["O my God!  O Thou forgiver of sins, bestower of gifts, dispeller of afflictions!\nVerily, I beseech thee to forgive the sins of such as have abandoned the physical garment and have ascended to the spiritual world.\nO my Lord!  Purify them from trespasses, dispel their sorrows, and change their darkness into light.  Cause them to enter the garden of happiness, cleanse them with the most pure water, and grant them to behold Thy splendors on the loftiest mount."],"translations":[{"language":"hr","lang_name":"Croatian"},{"language":"bs","lang_name":"Bosnian"},{"language":"sm","lang_name":"Samoan"},{"language":"ko","lang_name":"Korean"},{"language":"ne","lang_name":"Nepali"},{"language":"ml","lang_name":"Malayalam"},{"language":"kj","lang_name":"Oshikwanyama"},{"language":"is","lang_name":"Icelandic"},{"language":"tl","lang_name":"Tagalog"},{"language":"el","lang_name":"Greek"},{"language":"ch","lang_name":"Chamorro"},{"language":"ja","lang_name":"Japanese"},{"language":"ky","lang_name":"Kirghiz"},{"language":"se","lang_name":"Sami"},{"language":"fr","lang_name":"French"},{"language":"naq","lang_name":"Khoekhoegowab"},{"language":"lv","lang_name":"Latvian"},{"language":"kgf","lang_name":"Kube"},{"language":"srn","lang_name":"Sranan Tongo"},{"language":"ta","lang_name":"Tamil"},{"language":"nds","lang_name":"Low Saxon"},{"language":"mg","lang_name":"Malagasy"},{"language":"pt","lang_name":"Portuguese"},{"language":"ca","lang_name":"Catalan"},{"language":"gil","lang_name":"Gilbertese"},{"language":"cnr","lang_name":"Montenegrin"},{"language":"en","lang_name":"English"},{"language":"pl","lang_name":"Polish"},{"language":"diu","lang_n