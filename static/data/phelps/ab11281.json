{"pin":"AB11281","subcodes":[{"code":"AB11281","anchor":"","first_line":"O my Lord! O my Lord! This is a lamp lighted by the fire of Thy love and ablaze with the flame","word_count":"40","subjects":"@thankfulness; gratitude, @prayer for spiritual recognition, @love as fire, @divine grace, bounty, confirmations; spiritual capacity","full_text_parts":["O my Lord! O my Lord! This a lamp lighted by the fire of Thy love and ablaze with the flame which is ignited in the tree of Thy mercy. O my Lord! Increase his enkindlement, heat and flame, with the fire which is kindled in the Sinai of Thy Manifestation. Verily, Thou art the Confirmer, the Assister, the Powerful, the Generous, the Loving."],"translations":[{"language":"es","lang_name":"Spanish"},{"language":"zh-Hans","lang_name":"Simplified Chinese"},{"language":"de","lang_name":"German"},{"language":"no","lang_name":"Norwegian"},{"language":"tpi","lang_name":"Tok Pisin"},{"language":"zh-Hant","lang_name":"Traditional Chinese"},{"language":"kn","lang_name":"Kannada"},{"language":"lv","lang_name":"Latvian"},{"language":"ht","lang_name":"Haitian Creole"},{"language":"mt","lang_name":"Maltese"},{"language":"it","lang_name":"Italian"},{"language":"lb","lang_name":"Luxembourgish"},{"language":"tl","lang_name":"Tagalog"},{"language":"ms","lang_name":"Malay"},{"language":"pl","lang_name":"Polish"},{"language":"sm","lang_name":"Samoan"},{"language":"is","lang_name":"Icelandic"},{"language":"fr","lang_name":"French"},{"language":"mg","lang_name":"Malagasy"},{"language":"hy","lang_name":"Armenian"},{"language":"bg","lang_name":"Bulgarian"},{"language":"ne","lang_name":"Nepali"},{"language":"mn","lang_name":"Mongolian"},{"language":"nl","lang_name":"Dutch"},{"language":"iba","lang_name":"Iban"},{"language":"el","lang_name":"Greek"},{"language":"az","lang_name":"Azerbaijani"},{"language":"tvl","lang_name":"Tuvalu"},{"language":"af","lang_name":"Afrikaans"},{"language":"ky","lang_name":"Kirghiz"},{"language":"ro","lang_name":"Romani