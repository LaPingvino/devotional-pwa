{"pin":"BH00113P46","subcodes":[{"code":"BH00113P46","anchor":"","full_text_parts":["O Companion of My Throne! Hear no evil, and see no evil, abase not thyself, neither sigh and weep. Speak no evil, that thou mayest not hear it spoken unto thee, and magnify not the faults of others that thine own faults may not appear great; and wish not the abasement of anyone, that thine own abasement be not exposed. Live then the days of thy life, that are less than a fleeting moment, with thy mind stainless, thy heart unsullied, thy thoughts pure, and thy nature sanctified, so that, free and content, thou mayest put away this mortal frame, and repair unto the mystic paradise and abide in the eternal kingdom forevermore."],"translations":[{"language":"mh","lang_name":"Marshallese"},{"language":"gil","lang_name":"Gilbertese"}],"writing_refs":[{"type":"hidden-words","type_name":"The Hidden Words","language":"cs","lang_name":"Czech"},{"type":"hidden-words","type_name":"The Hidden Words","language":"da","lang_name":"Danish"},{"type":"hidden-words","type_name":"The Hidden Words","language":"it","lang_name":"Italian"},{"type":"hidden-words","type_name":"The Hidden Words","language":"lt","lang_name":"Lithuanian"},{"type":"hidden-words","type_name":"The Hidden Words","language":"sm","lang_name":"Samoan"},{"type":"hidden-words","type_name":"The Hidden Words","language":"tvl","lang_name":"Tuvalu"},{"type":"hidden-words","type_name":"The Hidden Words","language":"ar","lang_name":"Arabic"},{"type":"hidden-words","type_name":"The Hidden Words","language":"es","lang_name":"Spanish"},{"type":"hidden-words","type_name":"The Hidden Words","language":"lg","lang_name":"Ganda"},{"type":"hidden-words","type_name":"The Hidden Words","language":"tr","lang_name":"Turkish"},{"type":"hidden-words","type_name":"The Hidden Words","language":"en","lang_name":"English"},{"type":"hidden-words","type_name":"The Hidden Words","language":"fr","lang_name":"French"},{"type":"hidden-words","type_name":"The Hidden Wo