{"pin":"BH02035","subcodes":[{"code":"BH02035","anchor":"","first_line":"O Mustafa! Thy letter hath reached Our presence, and We have read it, for verily We have ever been the Reader thereof, and We have hearkened unto the yearning of thy heart [3.5s]... ...Recall thou to mind My sorrows, My cares and anxieties, My woes and trials, the state of My captivity, the tears that I have shed, the bitterness of Mine anguish","first_line_orig":"ان یا مصطفی قد حضر بین یدینا کتابک و قرأناه و انا کنا قارئین و سمعنا حنین قلبک  ","language":"1","word_count":"430","subjects":"@suffering and imprisonment, @rejection, opposition and persecution, @acquiescence and resignation; contentment","notes":" \u003ca href=\"http://web.archive.org/web/20070930181707/http://bahai-library.com/resources/leiden.list/leiden.list.html#416\"\u003eLL#416\u003c/a\u003e","translations":[],"writing_refs":[{"type":"gleanings","type_name":"Gleanings","language":"nl","lang_name":"Dutch"},{"type":"gleanings","type_name":"Gleanings","language":"de","lang_name":"German"},{"type":"gleanings","type_name":"Gleanings","language":"el","lang_name":"Greek"},{"type":"gleanings","type_name":"Gleanings","language":"ja","lang_name":"Japanese"},{"type":"gleanings","type_name":"Gleanings","language":"lv","lang_name":"Latvian"},{"type":"gleanings","type_name":"Gleanings","language":"ro","lang_name":"Romanian"},{"type":"gleanings","type_name":"Gleanings","language":"sq","lang_name":"Albanian"},{"type":"gleanings","type_name":"Gleanings","language":"te","lang_name":"Telugu"},{"type":"gleanings","type_name":"Gleanings","language":"en","lang_name":"English"},{"type":"gleanings","type_name":"Gleanings","language":"es","lang_name":"Spanish"},{"type":"gleanings","type_name":"Gleanings","language":"ta","lang_name":"Tamil"},{"type":"gleanings","type_name":"Gleanings","language":"tvl","lang_name":"Tuvalu"},{"type":"gleanings","type_name":"Gleanings","language":"vi","lang_name":"Vietnamese"},{"type":"gleanings","type_name":"Gleanings",