{"pin":"BH04607","subcodes":[{"code":"BH04607","anchor":"","first_line":"I praise and give thanks unto Him Who hath caused me to be enraptured by the sweet fragrances of Thy utterance. I glorify and sanctify Him Who hath made me to be stirred by the manifestations [3.5s]... ...The world is in travail, and its agitation waxeth day by day. Its face is turned towards waywardness and unbelief.","first_line_orig":"احمد و اشکر من جعلنی فائزا بنفحات بیانکم اسبح و اقدس من جعلنی مهتزا بظهورات  ","language":"5","word_count":"1180","translations":[],"writing_refs":[{"type":"gleanings","type_name":"Gleanings","language":"zh-Hant","lang_name":"Traditional Chinese"},{"type":"gleanings","type_name":"Gleanings","language":"de","lang_name":"German"},{"type":"gleanings","type_name":"Gleanings","language":"el","lang_name":"Greek"},{"type":"gleanings","type_name":"Gleanings","language":"es","lang_name":"Spanish"},{"type":"gleanings","type_name":"Gleanings","language":"fa","lang_name":"Persian"},{"type":"gleanings","type_name":"Gleanings","language":"ja","lang_name":"Japanese"},{"type":"gleanings","type_name":"Gleanings","language":"ko","lang_name":"Korean"},{"type":"gleanings","type_name":"Gleanings","language":"lv","lang_name":"Latvian"},{"type":"gleanings","type_name":"Gleanings","language":"pl","lang_name":"Polish"},{"type":"gleanings","type_name":"Gleanings","language":"ro","lang_name":"Romanian"},{"type":"gleanings","type_name":"Gleanings","language":"ru","lang_name":"Russian"},{"type":"gleanings","type_name":"Gleanings","language":"sq","lang_name":"Albanian"},{"type":"gleanings","type_name":"Gleanings","language":"sv","lang_name":"Swedish"},{"type":"gleanings","type_name":"Gleanings","language":"te","lang_name":"Telugu"},{"type":"gleanings","type_name":"Gleanings","language":"ar","lang_name":"Arabic"},{"type":"gleanings","type_name":"Gleanings","language":"fr","lang_name":"French"},{"type":"gleanings","type_name":"Gleanings","language":"hu","lang_name":"Hungarian"},{"type":"glean