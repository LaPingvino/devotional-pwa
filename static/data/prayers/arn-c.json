{"prayers":[{"phelps":"BH11209","text":"# Short Obligatory Prayer\n## To be recited once in twenty-four hours, at noon.\n\nFeipiaei, ülkantueael, rafi antüle zeuma.\nWül zuiñun ta inche, Awem Nünechen, eimi mi tremumol, tami kimafiel, tami poieneael Mupiii, feula tami wezakoñañen, ka tami newen ñen, tañi kunifall ñen ka tami ulmen ñen. Eka ñelai Nünechen Eimi müten, Kellukelu ta kuütu meo, Kizu Moñen ñelu.","name":"Short Obligatory Prayer","source":"bw17","version":"717443fb-e253-47cd-a0b9-b684a3874d93","v":"6psx78iuoy6k2wqaw8jth9m6r","book_cats":{"af:bp":{"cat":"Kort verpligte gebed","order_in_cat":1},"am:bp":{"cat":"አጭሩ (Short)","order_in_cat":1},"ar:bp":{"cat":"الصلاة   الصغيرة","order_in_cat":1},"az:bp":{"cat":"Qısa Namaz","order_in_cat":1},"be:bp":{"cat":"Кароткая абавязковая малітва","order_in_cat":1},"bg:bp":{"cat":"Кратка задължителна молитва","order_in_cat":1},"bi:bp":{"cat":"SOTFALA  OBLIGATORI  PREA","order_in_cat":1},"bs:bp":{"cat":"Kratka Obavezna Molitva","order_in_cat":1},"ca:bp":{"cat":"Oració obligatòria curta","order_in_cat":1},"co:bp":{"cat":"Preghera dì tutti i ghjorni","order_in_cat":1},"cs:bp":{"cat":"Krátká denní modlitba","order_in_cat":1},"cy:bp":{"cat":"Short Obligatory Prayer","order_in_cat":1},"da:bp":{"cat":"Kort Obligatorisk Bøn","order_in_cat":1},"de:bp":{"cat":"Das kurze Pflichtgebet","order_in_cat":1},"dgz:bp":{"cat":"Marek Iyanupe U’uraewa (Short Obligatory Prayer)","order_in_cat":1},"el:bp":{"cat":"ΜΙΚΡΗ ΥΠΟΧΡΕΩΤΙΚΗ ΠΡΟΣΕΥΧΗ","order_in_cat":1},"en:bp":{"cat":"Short Obligatory Prayer","order_in_cat":1},"eo:bp":{"cat":"Devigaj Preĝoj - La Mallonga","order_in_cat":1},"es:bp":{"cat":"Oración obligatoria corta","order_in_cat":1},"eu:bp":{"cat":"Bete beharrezkoa","order_in_cat":1},"fa:bp":{"cat":"نماز صغیر","order_in_cat":1},"fi:bp":{"cat":"Lyhyt velvollisuusrukous","order_in_cat":1},"fj:bp":{"cat":"NA MASU VAKAROTI LEKALEKA","order_in_cat":1},"fo:bp":{"cat":"Skyldu bøn","order_in_cat":1},"fr:bp":{"cat":"Prières prescrites","order_in_cat