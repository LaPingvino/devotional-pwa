nts and abide in Thy law. Help them, O God, in their endeavour, and grant them strength to serve Thee.  O God! Leave them not to themselves, but guide their steps by the light of Thy knowledge, and cheer their hearts by Thy love. Verily, Thou art their helper and their Lord.","source":"bahaiprayers.net","version":"780c536d-830d-4e42-b59f-6fa00fe57316","book_cats":{"af":{"cat":"Vergaderings","order_in_cat":3},"bn":{"cat":"একতার জন্য প্রার্থনা","order_in_cat":1},"cs":{"cat":"Jednota","order_in_cat":1},"da":{"cat":"Enhed","order_in_cat":1},"en":{"cat":"Unity","order_in_cat":1},"et":{"cat":"Ühtsus","order_in_cat":2},"fr":{"cat":"Unité","order_in_cat":2},"gu":{"cat":"એકતા","order_in_cat":2},"hi":{"cat":"एकता","order_in_cat":1},"hr":{"cat":"Jedinstvo","order_in_cat":1},"hy":{"cat":"ՄԻԱՍՆՈՒԹՅՈՒՆ","order_in_cat":1},"is":{"cat":"Eining","order_in_cat":1},"it":{"cat":"Unità","order_in_cat":1},"ja":{"cat":"一致和合","order_in_cat":1},"kl":{"cat":"Ataasiussuseq","order_in_cat":1},"kn":{"cat":"ಐಕ್ಯತೆಗಾಗಿ","order_in_cat":2},"ko":{"cat":"결혼","order_in_cat":2},"lb":{"cat":"Eenheet a Fridden","order_in_cat":1},"lv":{"cat":"Vienotība","order_in_cat":1},"ml":{"cat":"ഐക്യം","order_in_cat":1},"mn":{"cat":"ЭВ НЭГДЭЛ","order_in_cat":2},"ne":{"cat":"एकता","order_in_cat":1},"nl":{"cat":"Eenheid","order_in_cat":1},"no":{"cat":"Enhet","order_in_cat":1},"pl":{"cat":"Jedność","order_in_cat":2},"pt":{"cat":"Ensino","order_in_cat":4},"ro":{"cat":"Viitoare Mame","order_in_cat":1},"sk":{"cat":"Jednota","order_in_cat":1},"sq":{"cat":"Uniteti","order_in_cat":2},"sr":{"cat":"JEDINSTVO","order_in_cat":1},"sv":{"cat":"Enhet","order_in_cat":1},"sw":{"cat":"BAADHI YA SALA NYINGINE","order_in_cat":2},"ta":{"cat":"ஒற்றுமை","order_in_cat":1},"te":{"cat":"మరికొన్ని ప్రార్థనలు","order_in_cat":2},"th":{"cat":"บทอธิษฐานเพื่อเอกภาพ และความสามัคคี","order_in_cat":1},"tk":{"cat":"Dostluk We Agzybirlik","order_in_cat":1},"uk":{"cat":"Єдність","order_in_cat":1},"ur":{"cat":"اتحاد کے لیے","order_in_cat":1},"vi":{"cat":"Dà