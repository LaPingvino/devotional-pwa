{"prayers":[{"phelps":"BH11209","text":"# Short Obligatory Prayer\n## To be recited once in twenty-four hours, at noon.\n\nJayim lagataxanaxanec ñi Dios hua nagui que jayim vi'ichi' ñachalataxaq que ya'yi'iñite' que qami sashila'.\nParaque jayim racataxanaxanqui' nagui quenataxa' que ra iqalaxa chaqai requesaxanxai da yoxoric chaqai raresallaxai.\nQaica ca lya Dios que que qami napacaleq.\nQami yotavañi que na elchiqo'.\nQami qaica viñire'a.","name":"Short Obligatory Prayer","source":"bw18","version":"f6a0aabf-846b-40ef-9f09-085b09cff28b","v":"elmtz52bevjcj9z05ektf1nyj","book_cats":{"af:bpnet":{"cat":"Kort verpligte gebed","order_in_cat":1},"am:bpnet":{"cat":"አጭሩ (Short)","order_in_cat":1},"ar:bpnet":{"cat":"الصلاة   الصغيرة","order_in_cat":1},"az:bpnet":{"cat":"Qısa Namaz","order_in_cat":1},"be:bpapp":{"cat":"Абавязковая малітвы","cat_order":1,"order_in_cat":1},"be:bpnet":{"cat":"Кароткая абавязковая малітва","order_in_cat":1},"bg:bpnet":{"cat":"Кратка задължителна молитва","order_in_cat":1},"bi:bpnet":{"cat":"SOTFALA  OBLIGATORI  PREA","order_in_cat":1},"bs:bpnet":{"cat":"Kratka Obavezna Molitva","order_in_cat":1},"ca:bpnet":{"cat":"Oració obligatòria curta","order_in_cat":1},"co:bpnet":{"cat":"Preghera dì tutti i ghjorni","order_in_cat":1},"cs:bpnet":{"cat":"Krátká denní modlitba","order_in_cat":1},"cy:bpnet":{"cat":"Short Obligatory Prayer","order_in_cat":1},"da:bpnet":{"cat":"Kort Obligatorisk Bøn","order_in_cat":1},"de:bpapp":{"cat":"Pflichtgebete","cat_order":1,"order_in_cat":2},"de:bpnet":{"cat":"Das kurze Pflichtgebet","order_in_cat":1},"dgz:bpnet":{"cat":"Marek Iyanupe U’uraewa (Short Obligatory Prayer)","order_in_cat":1},"el:bpnet":{"cat":"ΜΙΚΡΗ ΥΠΟΧΡΕΩΤΙΚΗ ΠΡΟΣΕΥΧΗ","order_in_cat":1},"en:bpnet":{"cat":"Short Obligatory Prayer","order_in_cat":1},"eo:bel-malnova":{"cat":"Devigaj Preĝoj","cat_order":11,"order_in_cat":1},"eo:bpapp":{"cat":"Devigaj Preĝoj","cat_order":11,"order_in_cat":2},"eo:bpnet":{"cat":"Devigaj Preĝoj - La Mallonga","order_in_cat":1},"es: