{"prayers":[{"phelps":"BH11209","text":"# Short Obligatory Prayer\n## To be recited once in twenty-four hours, at noon.\n\nO me Nyame, medi adanseɛ sɛ Woabɔ me sɛ menhu Wo na mensom Wo. Medi adanseɛ seesei sɛ menni ahoɔden biara na Wo deɛ Woyɛ Otumfoɔ, medi hia buroburo na Woyɛ ɔdefoɔ. Onyame foforɔ biara nni hɔ ka Wo ho, ɔhaw mu Boafoɔ, Wo na wote Wo ho ne W’ase.","name":"Short Obligatory Prayer","source":"sop_pdf","version":"2a35e588-c66f-48e0-bf37-73dcfc2d5b3f","v":"2hynquz4cyj1dd4qy04rax1dr","book_cats":{"af:bpnet":{"cat":"Kort verpligte gebed","order_in_cat":1},"am:bpnet":{"cat":"አጭሩ (Short)","order_in_cat":1},"ar:bpapp":{"cat":"الصلاة"},"ar:bpnet":{"cat":"الصلاة   الصغيرة","order_in_cat":1},"az:bpnet":{"cat":"Qısa Namaz","order_in_cat":1},"be:bpapp":{"cat":"Абавязковая малітвы","cat_order":1,"order_in_cat":1},"be:bpnet":{"cat":"Кароткая абавязковая малітва","order_in_cat":1},"bg:bpnet":{"cat":"Кратка задължителна молитва","order_in_cat":1},"bi:bpnet":{"cat":"SOTFALA  OBLIGATORI  PREA","order_in_cat":1},"bs:bpnet":{"cat":"Kratka Obavezna Molitva","order_in_cat":1},"ca:bpnet":{"cat":"Oració obligatòria curta","order_in_cat":1},"co:bpnet":{"cat":"Preghera dì tutti i ghjorni","order_in_cat":1},"cs:bpnet":{"cat":"Krátká denní modlitba","order_in_cat":1},"cy:bpnet":{"cat":"Short Obligatory Prayer","order_in_cat":1},"da:bpnet":{"cat":"Kort Obligatorisk Bøn","order_in_cat":1},"de:bpapp":{"cat":"Pflichtgebete","cat_order":1,"order_in_cat":2},"de:bpnet":{"cat":"Das kurze Pflichtgebet","order_in_cat":1},"dgz:bpnet":{"cat":"Marek Iyanupe U’uraewa (Short Obligatory Prayer)","order_in_cat":1},"el:bpnet":{"cat":"ΜΙΚΡΗ ΥΠΟΧΡΕΩΤΙΚΗ ΠΡΟΣΕΥΧΗ","order_in_cat":1},"en:bpnet":{"cat":"Short Obligatory Prayer","order_in_cat":1},"eo:bel-malnova":{"cat":"Devigaj Preĝoj","cat_order":11,"order_in_cat":1},"eo:bpapp":{"cat":"Devigaj Preĝoj","cat_order":11,"order_in_cat":2},"eo:bpnet":{"cat":"Devigaj Preĝoj - La Mallonga","order_in_cat":1},"es:bpapp":{"cat":"Oraciones obligatorias"},"es:bpne